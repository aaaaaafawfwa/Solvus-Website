---
import Button from './Button.astro';

export interface Props {
  headline: string;
  subhead?: string;
  primaryText?: string;
  primaryHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
}

const {
  headline,
  subhead,
  primaryText = 'Book the call',
  primaryHref = '/book',
  secondaryText,
  secondaryHref,
} = Astro.props;
---

<section class="cta-band on-dark section">
  <div class="container cta-band__inner">
    <div class="cta-band__content">
      <h2 class="t-h1 cta-band__headline">{headline}</h2>
      {subhead && <p class="cta-band__subhead t-muted">{subhead}</p>}
    </div>
    <div class="cta-band__actions">
      <Button href={primaryHref} variant="primary" size="lg" arrow>{primaryText}</Button>
      {secondaryText && secondaryHref && (
        <Button href={secondaryHref} variant="ghost-dark" size="lg">{secondaryText}</Button>
      )}
    </div>
  </div>
</section>

<style>
  .cta-band {
    background: var(--color-bg);
    color: var(--color-text-on-dark);
    position: relative;
    overflow: hidden;
  }

  .cta-band::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 0%, rgba(232, 85, 61, 0.08), transparent 50%),
      radial-gradient(circle at 80% 100%, rgba(232, 85, 61, 0.05), transparent 50%);
    pointer-events: none;
  }

  .cta-band__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: end;
  }

  @media (min-width: 900px) {
    .cta-band__inner {
      grid-template-columns: 1.5fr 1fr;
      gap: var(--space-16);
    }
  }

  .cta-band__content {
    max-width: 28ch;
  }

  .cta-band__headline {
    color: var(--color-text-on-dark);
  }

  .cta-band__subhead {
    margin-top: var(--space-4);
    font-size: 1.125rem;
    line-height: 1.55;
    color: var(--color-text-muted-dark);
  }

  .cta-band__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  @media (min-width: 900px) {
    .cta-band__actions {
      justify-content: flex-end;
    }
  }
</style>
