---
export interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'text' | 'ghost-dark';
  size?: 'md' | 'lg';
  type?: 'button' | 'submit';
  arrow?: boolean;
  class?: string;
  ariaLabel?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  arrow = false,
  class: className = '',
  ariaLabel,
} = Astro.props;

const Tag = href ? 'a' : 'button';
const classes = `btn btn--${variant} btn--${size} ${className}`;
---

<Tag
  class={classes}
  href={href}
  type={href ? undefined : type}
  aria-label={ariaLabel}
>
  <span class="btn__label"><slot /></span>
  {arrow && (
    <svg class="btn__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M3.5 10.5L10.5 3.5M10.5 3.5H4.5M10.5 3.5V9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  )}
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    border-radius: var(--radius-full);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-body);
    text-decoration: none;
    transition: background var(--duration-fast), color var(--duration-fast), transform var(--duration-fast);
    cursor: pointer;
    white-space: nowrap;
  }

  .btn--md {
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-small);
  }

  .btn--lg {
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-body);
  }

  .btn--primary {
    background: var(--color-bg);
    color: var(--color-text-on-dark);
  }

  .btn--primary:hover {
    background: var(--color-accent);
  }

  .btn--secondary {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
  }

  .btn--secondary:hover {
    border-color: var(--color-text-primary);
    background: var(--color-text-primary);
    color: var(--color-text-on-dark);
  }

  .btn--text {
    background: transparent;
    color: var(--color-text-primary);
    padding-inline: 0;
    border-radius: 0;
  }

  .btn--text .btn__label {
    position: relative;
  }

  .btn--text .btn__label::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: currentColor;
    transform: scaleX(1);
    transform-origin: left;
    transition: transform var(--duration-base) var(--ease-out);
  }

  .btn--text:hover .btn__label::after {
    transform: scaleX(0);
    transform-origin: right;
  }

  .btn--ghost-dark {
    background: transparent;
    color: var(--color-text-on-dark);
    border: 1px solid var(--color-border-dark);
  }

  .btn--ghost-dark:hover {
    background: var(--color-text-on-dark);
    color: var(--color-text-primary);
  }

  .btn__arrow {
    transition: transform var(--duration-base) var(--ease-out);
  }

  .btn:hover .btn__arrow {
    transform: translate(2px, -2px);
  }
</style>
