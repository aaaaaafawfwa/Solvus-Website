---
// A miniature realtor site mockup shown in the hero.
// Restrained idle animation: cursor glides, listing card pops, phone rings.
// All CSS-driven, GPU-accelerated, respects prefers-reduced-motion.
---

<div class="hero-demo" aria-hidden="true" role="img" aria-label="Preview of a Solvus-built realtor website">
  <div class="hero-demo__window">
    <div class="hero-demo__chrome">
      <div class="hero-demo__dots">
        <span></span><span></span><span></span>
      </div>
      <div class="hero-demo__url">
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M7 4V3a2 2 0 0 0-4 0v1M2.5 4h5v4.5h-5z" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>sarahchen.realtor</span>
      </div>
      <div class="hero-demo__chrome-spacer"></div>
    </div>

    <div class="hero-demo__viewport">
      <!-- Mini nav -->
      <div class="mini-nav">
        <div class="mini-nav__logo">Chen <span class="mini-nav__dot"></span></div>
        <div class="mini-nav__links">
          <span>Listings</span>
          <span>About</span>
          <span>Contact</span>
        </div>
        <div class="mini-nav__cta">Call</div>
      </div>

      <!-- Mini hero -->
      <div class="mini-hero">
        <div class="mini-hero__eyebrow">Austin · TX</div>
        <div class="mini-hero__headline">Finding<br/>home,<br/>precisely.</div>
        <div class="mini-hero__meta">
          <span class="mini-hero__stat">
            <span class="mini-hero__stat-num">184</span>
            <span class="mini-hero__stat-label">closed</span>
          </span>
          <span class="mini-hero__stat">
            <span class="mini-hero__stat-num">4.9</span>
            <span class="mini-hero__stat-label">rating</span>
          </span>
        </div>
      </div>

      <!-- Mini listings strip -->
      <div class="mini-listings">
        <div class="mini-listing mini-listing--active">
          <div class="mini-listing__img"></div>
          <div class="mini-listing__meta">
            <span>$840K</span><span>4bd · Travis Heights</span>
          </div>
        </div>
        <div class="mini-listing">
          <div class="mini-listing__img mini-listing__img--b"></div>
          <div class="mini-listing__meta">
            <span>$1.2M</span><span>5bd · Barton Hills</span>
          </div>
        </div>
        <div class="mini-listing">
          <div class="mini-listing__img mini-listing__img--c"></div>
          <div class="mini-listing__meta">
            <span>$595K</span><span>3bd · Mueller</span>
          </div>
        </div>
      </div>

      <!-- Cursor -->
      <div class="hero-demo__cursor" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M2 2L7 14L8.5 9L13 7.5L2 2Z" fill="#0B0B0C" stroke="white" stroke-width="1" stroke-linejoin="round"/>
        </svg>
      </div>

      <!-- Click ring -->
      <div class="hero-demo__click" aria-hidden="true"></div>

      <!-- Callout pill that appears after click -->
      <div class="hero-demo__callout" aria-hidden="true">
        <span class="hero-demo__callout-dot"></span>
        Lead captured
      </div>
    </div>
  </div>

  <!-- Floating meta chips -->
  <div class="hero-demo__chip hero-demo__chip--1" aria-hidden="true">
    <span class="hero-demo__chip-icon">
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
        <circle cx="5" cy="5" r="4" stroke="currentColor" stroke-width="1"/>
        <path d="M5 3v2l1.5 1" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
      </svg>
    </span>
    <span>0.6s load</span>
  </div>

  <div class="hero-demo__chip hero-demo__chip--2" aria-hidden="true">
    <span class="hero-demo__chip-icon">
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
        <path d="M2 7.5L4 5.5L5.5 7L8 3" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
    <span>Lighthouse 98</span>
  </div>
</div>

<style>
  .hero-demo {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3.2;
    max-width: 560px;
    margin-inline: auto;
  }

  .hero-demo__window {
    position: absolute;
    inset: 0;
    background: var(--color-surface-raised);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  /* Browser chrome */
  .hero-demo__chrome {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 10px 14px;
    background: #FAFAF8;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-demo__dots {
    display: flex;
    gap: 5px;
  }

  .hero-demo__dots span {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #E5E3DE;
  }

  .hero-demo__dots span:nth-child(1) { background: #F0A5A0; }
  .hero-demo__dots span:nth-child(2) { background: #EED49C; }
  .hero-demo__dots span:nth-child(3) { background: #9FCFA8; }

  .hero-demo__url {
    flex: 1;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    justify-content: center;
    background: var(--color-surface);
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-text-secondary);
    max-width: 220px;
    margin-inline: auto;
  }

  .hero-demo__chrome-spacer {
    width: 36px;
  }

  /* Viewport */
  .hero-demo__viewport {
    position: relative;
    padding: 16px;
    height: calc(100% - 35px);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* Mini nav */
  .mini-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--color-border);
  }

  .mini-nav__logo {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-weight: var(--weight-semibold);
    font-size: 11px;
    letter-spacing: -0.02em;
  }

  .mini-nav__dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .mini-nav__links {
    display: flex;
    gap: 14px;
    font-size: 9px;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
  }

  .mini-nav__cta {
    padding: 3px 8px;
    background: var(--color-bg);
    color: var(--color-text-on-dark);
    border-radius: var(--radius-full);
    font-size: 9px;
    font-weight: var(--weight-medium);
  }

  /* Mini hero */
  .mini-hero {
    padding-block: 4px;
  }

  .mini-hero__eyebrow {
    font-family: var(--font-mono);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
    margin-bottom: 6px;
  }

  .mini-hero__headline {
    font-size: 28px;
    line-height: 0.95;
    letter-spacing: -0.03em;
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
  }

  .mini-hero__meta {
    display: flex;
    gap: 16px;
    margin-top: 10px;
  }

  .mini-hero__stat {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .mini-hero__stat-num {
    font-weight: var(--weight-semibold);
    font-size: 13px;
    letter-spacing: -0.02em;
  }

  .mini-hero__stat-label {
    font-family: var(--font-mono);
    font-size: 8px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
  }

  /* Listings */
  .mini-listings {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
    margin-top: auto;
  }

  .mini-listing {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 6px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    transition: transform var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
  }

  .mini-listing__img {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-sm);
    background: linear-gradient(135deg, #D4A574 0%, #8B6F47 100%);
  }

  .mini-listing__img--b {
    background: linear-gradient(135deg, #8FA9C0 0%, #4F6A85 100%);
  }

  .mini-listing__img--c {
    background: linear-gradient(135deg, #A8B89F 0%, #6B7D63 100%);
  }

  .mini-listing__meta {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .mini-listing__meta span:first-child {
    font-weight: var(--weight-semibold);
    font-size: 10px;
    letter-spacing: -0.01em;
  }

  .mini-listing__meta span:last-child {
    font-family: var(--font-mono);
    font-size: 8px;
    color: var(--color-text-secondary);
  }

  .mini-listing--active {
    animation: listing-pop 8s var(--ease-out) infinite;
    animation-delay: 3.2s;
  }

  @keyframes listing-pop {
    0%, 35%, 100% {
      transform: translateY(0);
      border-color: var(--color-border);
      box-shadow: none;
    }
    40%, 55% {
      transform: translateY(-3px);
      border-color: var(--color-accent);
      box-shadow: 0 8px 20px rgba(232, 85, 61, 0.12);
    }
  }

  /* Cursor */
  .hero-demo__cursor {
    position: absolute;
    top: 65%;
    left: 50%;
    opacity: 0;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
    animation: cursor-path 8s var(--ease-in-out) infinite;
    animation-delay: 1s;
    pointer-events: none;
  }

  @keyframes cursor-path {
    0% {
      opacity: 0;
      transform: translate(60px, -20px);
    }
    10% { opacity: 1; }
    25% {
      transform: translate(10px, 10px);
    }
    40% {
      transform: translate(0, 0);
    }
    45% {
      transform: translate(0, 0) scale(0.9);
    }
    55% {
      transform: translate(0, 0) scale(1);
    }
    80% { opacity: 1; }
    100% {
      opacity: 0;
      transform: translate(-30px, 30px);
    }
  }

  /* Click ring */
  .hero-demo__click {
    position: absolute;
    top: 66%;
    left: 50%;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 1.5px solid var(--color-accent);
    opacity: 0;
    animation: click-ring 8s var(--ease-out) infinite;
    animation-delay: 1s;
    pointer-events: none;
    transform: translate(-12px, -12px);
  }

  @keyframes click-ring {
    0%, 42%, 100% {
      opacity: 0;
      transform: translate(-12px, -12px) scale(0.5);
    }
    45% {
      opacity: 1;
      transform: translate(-12px, -12px) scale(0.5);
    }
    55% {
      opacity: 0;
      transform: translate(-12px, -12px) scale(1.5);
    }
  }

  /* Callout pill */
  .hero-demo__callout {
    position: absolute;
    top: 16px;
    right: 16px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 8px;
    background: var(--color-bg);
    color: var(--color-text-on-dark);
    border-radius: var(--radius-full);
    font-size: 9px;
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    opacity: 0;
    animation: callout-pop 8s var(--ease-out) infinite;
    animation-delay: 1s;
  }

  .hero-demo__callout-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #5CCB7C;
    box-shadow: 0 0 6px rgba(92, 203, 124, 0.6);
  }

  @keyframes callout-pop {
    0%, 45%, 85%, 100% {
      opacity: 0;
      transform: translateY(-4px);
    }
    50%, 80% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Floating chips */
  .hero-demo__chip {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: 11px;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    color: var(--color-text-primary);
    box-shadow: var(--shadow-md);
    animation: chip-float 6s var(--ease-in-out) infinite;
  }

  .hero-demo__chip-icon {
    display: inline-flex;
    color: var(--color-accent);
  }

  .hero-demo__chip--1 {
    bottom: -12px;
    left: -8%;
    animation-delay: 0s;
  }

  .hero-demo__chip--2 {
    top: -12px;
    right: -8%;
    animation-delay: 3s;
  }

  @keyframes chip-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  /* Reduced motion override */
  @media (prefers-reduced-motion: reduce) {
    .mini-listing--active,
    .hero-demo__cursor,
    .hero-demo__click,
    .hero-demo__callout,
    .hero-demo__chip {
      animation: none !important;
    }
    .hero-demo__cursor,
    .hero-demo__click,
    .hero-demo__callout {
      opacity: 1;
    }
  }

  @media (max-width: 500px) {
    .hero-demo__chip { display: none; }
  }
</style>
