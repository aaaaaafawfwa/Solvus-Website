---
export interface Props {
  number?: string;
}

const { number } = Astro.props;
---

<div class="eyebrow">
  {number && <span class="eyebrow__number">{number}</span>}
  <span class="eyebrow__label"><slot /></span>
</div>

<style>
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    line-height: 1;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    font-weight: var(--weight-regular);
  }

  .eyebrow__number {
    color: var(--color-accent);
  }

  .on-dark .eyebrow { color: var(--color-text-muted-dark); }
  .on-dark .eyebrow__number { color: var(--color-accent); }
</style>
