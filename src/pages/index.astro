            <div class="concept-card hover-target" style="background: linear-gradient(135deg, #1A1C23, #0A0C11);">
                <div class="concept-inner">
                    <h3 class="concept-title" style="color: #F8FAFC;">Finding<br>home,<br>precisely.</h3>
                    <div>
                        <h4 style="font-weight: 300; font-size: 1.5rem; margin: 0 0 0.5rem 0;">Chen Real Estate</h4>
                        <div class="mono-label" style="border:none; padding:0; margin:0; color: var(--c-cyan);">LUXURY · AUSTIN · SOLO AGENT</div>
                    </div>
                </div>
            </div>
            <div class="concept-card hover-target" style="background: #E8DCCB; color: #1A1A1A;">
                <div class="concept-inner">
                    <h3 class="concept-title" style="color: #1A1A1A; font-family: Georgia, serif; font-style: italic;">The home<br>you grow<br>into.</h3>
                    <div>
                        <h4 style="font-weight: 300; font-size: 1.5rem; margin: 0 0 0.5rem 0;">Rivera Homes</h4>
                        <div class="mono-label" style="border:none; padding:0; margin:0; color: #666;">FAMILY REALTOR · TAMPA · WARM BRAND</div>
                    </div>
                </div>
            </div>
            <div class="concept-card hover-target" style="background: #000; border-color: #222;">
                <div class="concept-inner">
                    <h3 class="concept-title" style="color: #FFF; letter-spacing: 0.1em; text-transform: uppercase; font-size: 3rem;">Mountain<br>West<br>Realty</h3>
                    <div>
                        <h4 style="font-weight: 300; font-size: 1.5rem; margin: 0 0 0.5rem 0; color: #FFF;">Mountain West Realty</h4>
                        <div class="mono-label" style="border:none; padding:0; margin:0; color: var(--c-muted);">TEAM BROKERAGE · DENVER · EDITORIAL</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="s5" class="light-sec">
        <div class="bg-giant-text para-text">TIMELINE</div>
        <div style="max-width: 800px;">
            <div class="mono-label">04 / Process</div>
