<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" is:inline></script>

<script is:inline>
    gsap.registerPlugin(ScrollTrigger);

    if (window.matchMedia('(hover: hover)').matches) {
        const dot = document.getElementById('solvusCursor');
        if (dot) {
            let usingTouch = false;
            window.addEventListener('touchstart', () => {
                usingTouch = true;
                dot.style.opacity = '0';
            }, { passive: true });
            window.addEventListener('mousemove', (e) => {
                if (usingTouch) { usingTouch = false; return; }
                dot.style.left    = e.clientX + 'px';
                dot.style.top     = e.clientY + 'px';
                dot.style.opacity = '1';
            }, { passive: true });

            const iframeArea = document.querySelector('.carousel-frames');
            if (iframeArea) {
                iframeArea.addEventListener('mouseenter', () => { dot.style.opacity = '0'; });
                iframeArea.addEventListener('mouseleave', () => { dot.style.opacity = '1'; });
            }
        }
    }

    const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        direction: 'vertical',
        gestureDirection: 'vertical',
        smooth: true,
        mouseMultiplier: 1,
        smoothTouch: false,
        touchMultiplier: 2,
        infinite: false,
    });

    function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);

    const cursorDot = document.getElementById('cursorDot');
    const cursorRing = document.getElementById('cursorRing');
    let mouseX = window.innerWidth / 2;
    let mouseY = window.innerHeight / 2;
    let ringX = mouseX;
    let ringY = mouseY;

    window.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        gsap.to(cursorDot, { x: mouseX, y: mouseY, duration: 0 });
    });

    gsap.ticker.add(() => {
        ringX += (mouseX - ringX) * 0.15;
        ringY += (mouseY - ringY) * 0.15;
        gsap.set(cursorRing, { x: ringX, y: ringY });
    });

    document.querySelectorAll('.hover-target').forEach(link => {
        link.addEventListener('mouseenter', () => {
            gsap.to(cursorRing, { width: 60, height: 60, backgroundColor: 'rgba(0, 229, 255, 0.1)', duration: 0.3 });
            gsap.to(cursorDot, { scale: 0, duration: 0.2 });
        });
        link.addEventListener('mouseleave', () => {
            gsap.to(cursorRing, { width: 40, height: 40, backgroundColor: 'transparent', duration: 0.3 });
            gsap.to(cursorDot, { scale: 1, duration: 0.2 });
        });
    });

    document.querySelectorAll('.concept-card').forEach(card => {
        card.addEventListener('mousemove', (e) => {
            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            const rotateX = ((y - centerY) / centerY) * -10;
            const rotateY = ((x - centerX) / centerX) * 10;
            gsap.to(card, { rotationX: rotateX, rotationY: rotateY, transformPerspective: 1000, duration: 0.5, ease: "power2.out" });
        });
        card.addEventListener('mouseleave', () => {
            gsap.to(card, { rotationX: 0, rotationY: 0, duration: 0.8, ease: "power2.out" });
        });
    });

    gsap.to("#progressBar", {
        scaleX: 1, ease: "none",
        scrollTrigger: { trigger: "body", start: "top top", end: "bottom bottom", scrub: 0.3 }
    });

    document.querySelectorAll('.stagger-wrap').forEach(wrap => {
        gsap.fromTo(wrap.querySelectorAll('.stagger-text span'), 
            { y: "110%" },
            { y: "0%", duration: 1.2, stagger: 0.1, ease: "power4.out", scrollTrigger: { trigger: wrap, start: "top 85%" } }
        );
    });

    document.querySelectorAll('.fade-up').forEach(elem => {
        gsap.fromTo(elem, 
            { y: 30, opacity: 0 },
            { y: 0, opacity: 1, duration: 1, ease: "power3.out", scrollTrigger: { trigger: elem, start: "top 90%" } }
        );
    });

    document.querySelectorAll('.para-text').forEach(text => {
        gsap.to(text, {
            xPercent: -20, ease: "none",
            scrollTrigger: { trigger: text.parentElement, start: "top bottom", end: "bottom top", scrub: true }
        });
    });

    document.querySelectorAll('.float-y').forEach(elem => {
        const speed = elem.getAttribute('data-speed') || 1;
        gsap.to(elem, {
            y: -100 * speed, ease: "none",
            scrollTrigger: { trigger: elem.parentElement, start: "top bottom", end: "bottom top", scrub: true }
        });
    });

    gsap.to("#tlProgress", {
        height: "100%", ease: "none",
        scrollTrigger: { trigger: ".process-timeline", start: "top center", end: "bottom center", scrub: 1 }
    });

    function scaleCarousel() {
        const framesEl = document.querySelector('.carousel-frames');
        if (!framesEl) return;
        const containerW = framesEl.offsetWidth;
        const scale = containerW / 1440;
        framesEl.style.height = Math.round(900 * scale) + 'px';
        framesEl.querySelectorAll('iframe').forEach(el => {
            el.style.transform = `scale(${scale})`;
        });
    }
    scaleCarousel();
    window.addEventListener('load', scaleCarousel);
    window.addEventListener('resize', scaleCarousel);

    const carouselData = [
        { url: 'chenrealestate.com', name: 'Chen Real Estate', desc: 'Luxury · Austin · Solo Agent', href: '/concepts/chen' },
        { url: 'riverahomes.com',    name: 'Rivera Homes',     desc: 'Family Realtor · Tampa · Warm Brand', href: '/concepts/rivera' },
        { url: 'mountainwestrealty.com', name: 'Mountain West Realty', desc: 'Team Brokerage · Denver · Editorial', href: '/concepts/mountain-west' },
    ];
    let currentSlide = 0;

    function goToSlide(idx) {
        document.getElementById('frame-' + currentSlide).classList.remove('active');
        document.querySelectorAll('.carousel-dot')[currentSlide].classList.remove('active');
        currentSlide = (idx + carouselData.length) % carouselData.length;
        document.getElementById('frame-' + currentSlide).classList.add('active');
        document.querySelectorAll('.carousel-dot')[currentSlide].classList.add('active');
        document.getElementById('carouselUrl').textContent   = carouselData[currentSlide].url;
        document.getElementById('carouselLabel').textContent = carouselData[currentSlide].name;
        document.getElementById('carouselDesc').textContent  = carouselData[currentSlide].desc;
        document.getElementById('carouselCounter').textContent = '0' + (currentSlide + 1) + ' / 03';
        const siteLink = document.getElementById('carouselSiteLinkAnchor');
        if (siteLink) siteLink.href = carouselData[currentSlide].href;
    }

    document.getElementById('prevBtn').addEventListener('click', () => goToSlide(currentSlide - 1));
    document.getElementById('nextBtn').addEventListener('click', () => goToSlide(currentSlide + 1));
    document.querySelectorAll('.carousel-dot').forEach(dot => {
        dot.addEventListener('click', () => goToSlide(+dot.dataset.index));
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft')  goToSlide(currentSlide - 1);
        if (e.key === 'ArrowRight') goToSlide(currentSlide + 1);
    });

    // Touch swipe for carousel — on mobile the overlay is hidden so iframes are accessible.
    // Swipe is detected on the browser chrome bar and footer instead.
    function attachCarouselSwipe(el) {
        if (!el) return;
        let sx = 0, sy = 0;
        el.addEventListener('touchstart', (e) => {
            sx = e.changedTouches[0].clientX;
            sy = e.changedTouches[0].clientY;
        }, { passive: true });
        el.addEventListener('touchend', (e) => {
            const dx = sx - e.changedTouches[0].clientX;
            const dy = sy - e.changedTouches[0].clientY;
            if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
                dx > 0 ? goToSlide(currentSlide + 1) : goToSlide(currentSlide - 1);
            }
        }, { passive: true });
    }
    attachCarouselSwipe(document.querySelector('.browser-chrome'));
    attachCarouselSwipe(document.querySelector('.carousel-footer'));
    attachCarouselSwipe(document.querySelector('.carousel-swipe-hint'));

    // Same-origin iframes: detect horizontal swipe inside → change slide, vertical → normal scroll
    document.querySelectorAll('.carousel-frame iframe').forEach((iframe) => {
        function tryAttachIframe() {
            try {
                const doc = iframe.contentDocument || iframe.contentWindow.document;
                if (!doc || !doc.body) return;
                let isx = 0, isy = 0;
                doc.addEventListener('touchstart', (e) => {
                    isx = e.changedTouches[0].clientX;
                    isy = e.changedTouches[0].clientY;
                }, { passive: true });
                doc.addEventListener('touchend', (e) => {
                    const dx = isx - e.changedTouches[0].clientX;
                    const dy = isy - e.changedTouches[0].clientY;
                    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 50) {
                        dx > 0 ? goToSlide(currentSlide + 1) : goToSlide(currentSlide - 1);
                    }
                }, { passive: true });
            } catch(err) { /* cross-origin guard */ }
        }
        iframe.addEventListener('load', tryAttachIframe);
        tryAttachIframe();
    });

    // Mobile hamburger menu
    const hamburger = document.getElementById('navHamburger');
    const mobileNav = document.getElementById('mobileNav');
    if (hamburger && mobileNav) {
        hamburger.addEventListener('click', () => {
            const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
            const next = !isOpen;
            hamburger.setAttribute('aria-expanded', String(next));
            mobileNav.setAttribute('data-open', String(next));
            mobileNav.setAttribute('aria-hidden', String(!next));
            document.body.style.overflow = next ? 'hidden' : '';
        });
        mobileNav.querySelectorAll('.mobile-nav__link').forEach(link => {
            link.addEventListener('click', () => {
                hamburger.setAttribute('aria-expanded', 'false');
                mobileNav.setAttribute('data-open', 'false');
                mobileNav.setAttribute('aria-hidden', 'true');
                document.body.style.overflow = '';
            });
        });
    }

    const canvas = document.getElementById('webgl-canvas');
    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x03060C, 0.002);

    const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = 60;

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const particleGeo = new THREE.BufferGeometry();
    const pCount = 3000;
    const pArray = new Float32Array(pCount * 3);
    for(let i=0; i<pCount*3; i++) {
        pArray[i] = (Math.random() - 0.5) * 200;
    }
    particleGeo.setAttribute('position', new THREE.BufferAttribute(pArray, 3));
    
    const colorCyan = new THREE.Color(0x00E5FF);
    const colorNavy = new THREE.Color(0x03060C);
    
    const particleMat = new THREE.PointsMaterial({ size: 0.15, color: colorCyan, transparent: true, opacity: 0.3 });
    const particles = new THREE.Points(particleGeo, particleMat);
    scene.add(particles);

    const geoGroup = new THREE.Group();
    scene.add(geoGroup);

    const matWire = new THREE.LineBasicMaterial({ color: colorCyan, transparent: true, opacity: 0.1 });
    
    for(let i=0; i<5; i++) {
        const geo = i % 2 === 0 ? new THREE.IcosahedronGeometry(20, 1) : new THREE.OctahedronGeometry(25, 2);
        const mesh = new THREE.LineSegments(new THREE.EdgesGeometry(geo), matWire);
        mesh.position.set((Math.random() - 0.5) * 40, (Math.random() - 0.5) * 40, -i * 50);
        mesh.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, 0);
        geoGroup.add(mesh);
    }

    ScrollTrigger.create({
        trigger: "body", start: "top top", end: "bottom bottom", scrub: 1,
        onUpdate: (self) => {
            camera.position.z = 60 - (self.progress * 250);
            camera.rotation.z = self.progress * 0.5;

            const currentSection = Math.floor(self.progress * 7);
            if (currentSection === 1 || currentSection === 4 || currentSection === 5) {
                particleMat.color.lerp(colorNavy, 0.1);
                matWire.color.lerp(colorNavy, 0.1);
                scene.fog.color.lerp(new THREE.Color(0xF8FAFC), 0.1);
            } else {
                particleMat.color.lerp(colorCyan, 0.1);
                matWire.color.lerp(colorCyan, 0.1);
                scene.fog.color.lerp(colorNavy, 0.1);
            }
        }
    });

    let baseRotY = 0, cursorRotX = 0, cursorRotY = 0;
    window.addEventListener('mousemove', (e) => {
        cursorRotY = ((e.clientX / window.innerWidth) - 0.5) * 0.8;
        cursorRotX = ((e.clientY / window.innerHeight) - 0.5) * 0.5;
    }, { passive: true });

    const clock = new THREE.Clock();
    function animate() {
        requestAnimationFrame(animate);
        const t = clock.getElapsedTime();

        baseRotY += 0.001;
        geoGroup.rotation.x += 0.05 * (cursorRotX + Math.sin(t * 0.1) * 0.2 - geoGroup.rotation.x);
        geoGroup.rotation.y += 0.05 * (baseRotY + cursorRotY - geoGroup.rotation.y);

        particles.position.y = Math.sin(t * 0.2) * 5;
        particles.rotation.y = t * 0.02;

        geoGroup.children.forEach((child, index) => {
            child.rotation.x += 0.002 * (index % 2 === 0 ? 1 : -1);
            child.rotation.y += 0.003;
        });

        renderer.render(scene, camera);
    }
    animate();

    window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
    });
</script>
</body>
</html>
