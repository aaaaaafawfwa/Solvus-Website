<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
(function () {
    'use strict';

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isTouch = !window.matchMedia('(hover: hover) and (pointer: fine)').matches;

    const navToggle = document.getElementById('navToggle');
    const mobileMenu = document.getElementById('mobileMenu');

    navToggle.addEventListener('click', () => {
        const open = navToggle.getAttribute('aria-expanded') === 'true';
        navToggle.setAttribute('aria-expanded', String(!open));
        mobileMenu.classList.toggle('is-open', !open);
        document.body.style.overflow = open ? '' : 'hidden';
    });

    mobileMenu.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
            navToggle.setAttribute('aria-expanded', 'false');
            mobileMenu.classList.remove('is-open');
            document.body.style.overflow = '';
        });
    });

    document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && mobileMenu.classList.contains('is-open')) {
            navToggle.setAttribute('aria-expanded', 'false');
            mobileMenu.classList.remove('is-open');
            document.body.style.overflow = '';
            navToggle.focus();
        }
    });

    const progressBar = document.getElementById('progressBar');
    function updateProgress() {
        const scrolled = window.scrollY;
        const total = document.documentElement.scrollHeight - window.innerHeight;
        progressBar.style.width = (total > 0 ? scrolled / total * 100 : 0) + '%';
    }
    window.addEventListener('scroll', updateProgress, { passive: true });

    if (!reducedMotion) {
        const observer = new IntersectionObserver(entries => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });

        document.querySelectorAll('.reveal-clip, .fade-up').forEach(el => observer.observe(el));
    } else {
        document.querySelectorAll('.reveal-clip, .fade-up').forEach(el => {
            el.style.opacity = '1';
            el.style.transform = 'none';
            el.querySelectorAll('span > span').forEach(s => {
                s.style.transform = 'none';
            });
        });
    }

    if (!reducedMotion) {
        const paraTexts = document.querySelectorAll('.para-text');
        window.addEventListener('scroll', () => {
            const y = window.scrollY;
            paraTexts.forEach(t => {
                const rect = t.parentElement.getBoundingClientRect();
                const progress = -rect.top / (rect.height + window.innerHeight);
                t.style.transform = `translateX(${progress * -15}%)`;
            });
        }, { passive: true });
    }

    if (!reducedMotion) {
        const tlProgress = document.getElementById('tlProgress');
        const timeline = document.getElementById('processTimeline');
        if (tlProgress && timeline) {
            window.addEventListener('scroll', () => {
                const rect = timeline.getBoundingClientRect();
                const viewH = window.innerHeight;
                const progress = Math.min(1, Math.max(0,
                    (-rect.top + viewH * 0.5) / (rect.height - viewH * 0.5)
                ));
                tlProgress.style.height = (progress * 100) + '%';
            }, { passive: true });
        }
    }

    if (!isTouch && !reducedMotion) {
        const dot = document.getElementById('cursorDot');
        const ring = document.getElementById('cursorRing');
        let mx = window.innerWidth / 2;
        let my = window.innerHeight / 2;
        let rx = mx, ry = my;

        window.addEventListener('mousemove', e => {
            mx = e.clientX; my = e.clientY;
            dot.style.transform = `translate(calc(${mx}px - 50%), calc(${my}px - 50%))`;
        });

        function animateRing() {
            rx += (mx - rx) * 0.14;
            ry += (my - ry) * 0.14;
            ring.style.transform = `translate(calc(${rx}px - 50%), calc(${ry}px - 50%))`;
            requestAnimationFrame(animateRing);
        }
        animateRing();

        document.querySelectorAll('.hover-target').forEach(el => {
            el.addEventListener('mouseenter', () => {
                ring.style.width = '60px';
                ring.style.height = '60px';
                ring.style.backgroundColor = 'rgba(0,229,255,0.08)';
                dot.style.transform += ' scale(0)';
            });
            el.addEventListener('mouseleave', () => {
                ring.style.width = '40px';
                ring.style.height = '40px';
                ring.style.backgroundColor = 'transparent';
            });
        });
    }

    if (!isTouch && !reducedMotion) {
        document.querySelectorAll('.concept-card').forEach(card => {
            card.addEventListener('mousemove', e => {
                const r = card.getBoundingClientRect();
                const x = (e.clientX - r.left) / r.width - 0.5;
                const y = (e.clientY - r.top) / r.height - 0.5;
                card.style.transform = `perspective(1000px) rotateX(${y * -12}deg) rotateY(${x * 12}deg)`;
            });
            card.addEventListener('mouseleave', () => {
                card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0)';
                card.style.transition = 'transform 0.7s cubic-bezier(0.16,1,0.3,1)';
                setTimeout(() => card.style.transition = '', 700);
            });
        });
    }

    if (!reducedMotion && typeof THREE !== 'undefined') {
        const canvas = document.getElementById('webgl-canvas');
        const scene = new THREE.Scene();
        scene.fog = new THREE.FogExp2(0x03060C, 0.002);

        const camera = new THREE.PerspectiveCamera(
            60, window.innerWidth / window.innerHeight, 0.1, 1000
        );
        camera.position.z = 60;

        const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));

        const pGeo = new THREE.BufferGeometry();
        const pCount = isTouch ? 1000 : 2500;
        const pArr = new Float32Array(pCount * 3);
        for (let i = 0; i < pCount * 3; i++) pArr[i] = (Math.random() - 0.5) * 200;
        pGeo.setAttribute('position', new THREE.BufferAttribute(pArr, 3));

        const cCyan  = new THREE.Color(0x00E5FF);
        const cNavy  = new THREE.Color(0x03060C);
        const cWhite = new THREE.Color(0xF8FAFC);

        const pMat = new THREE.PointsMaterial({
            size: 0.15, color: cCyan,
            transparent: true, opacity: 0.25
        });
        scene.add(new THREE.Points(pGeo, pMat));

        const gGroup = new THREE.Group();
        scene.add(gGroup);
        const wMat = new THREE.LineBasicMaterial({ color: cCyan, transparent: true, opacity: 0.08 });

        for (let i = 0; i < 5; i++) {
            const geo = i % 2 === 0
                ? new THREE.IcosahedronGeometry(20, 1)
                : new THREE.OctahedronGeometry(25, 2);
            const mesh = new THREE.LineSegments(new THREE.EdgesGeometry(geo), wMat);
            mesh.position.set(
                (Math.random() - 0.5) * 40,
                (Math.random() - 0.5) * 40,
                -i * 50
            );
            mesh.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, 0);
            gGroup.add(mesh);
        }

        let scrollProgress = 0;
        window.addEventListener('scroll', () => {
            const total = document.documentElement.scrollHeight - window.innerHeight;
            scrollProgress = total > 0 ? window.scrollY / total : 0;
        }, { passive: true });

        let isVisible = true;
        document.addEventListener('visibilitychange', () => {
            isVisible = !document.hidden;
        });

        const clock = new THREE.Clock();
        function animate() {
            requestAnimationFrame(animate);
            if (!isVisible) return;

            const t = clock.getElapsedTime();

            camera.position.z = 60 - scrollProgress * 200;
            camera.rotation.z = scrollProgress * 0.4;

            const lightSection = scrollProgress > 0.14 && scrollProgress < 0.28
                || scrollProgress > 0.6 && scrollProgress < 0.85;
            const targetColor = lightSection ? cNavy : cCyan;
            pMat.color.lerp(targetColor, 0.05);
            wMat.color.lerp(targetColor, 0.05);
            scene.fog.color.lerp(lightSection ? cWhite : cNavy, 0.05);

            gGroup.rotation.x = Math.sin(t * 0.08) * 0.15;
            gGroup.rotation.y += 0.0008;
            gGroup.children.forEach((child, i) => {
                child.rotation.x += 0.0015 * (i % 2 === 0 ? 1 : -1);
                child.rotation.y += 0.002;
            });

            pGeo.attributes.position.array;
            scene.children[0].position.y = Math.sin(t * 0.15) * 4;
            scene.children[0].rotation.y = t * 0.015;

            renderer.render(scene, camera);
        }
        animate();

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    }

})();
</script>
