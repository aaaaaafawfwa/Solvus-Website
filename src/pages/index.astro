<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Solvus | Engineered Real Estate</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;200;300;400&family=Space+Mono&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.29/bundled/lenis.min.js" is:inline></script>

<style>
    :root {
        --nav-height: 80px;
        --c-navy: #03060C;
        --c-navy-light: #0A111E;
        --c-white: #F8FAFC;
        --c-cyan: #00E5FF;
        --c-muted: #4A5D7E;
        --font-sans: 'Outfit', sans-serif;
        --font-mono: 'Space Mono', monospace;
    }

    * { box-sizing: border-box; }
    
    html.lenis { height: auto; }
    .lenis.lenis-smooth { scroll-behavior: auto; }
    .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
    .lenis.lenis-stopped { overflow: hidden; }
    .lenis.lenis-scrolling iframe { pointer-events: none; }

    body, html {
        margin: 0; padding: 0;
        font-family: var(--font-sans);
        background-color: var(--c-navy);
        color: var(--c-white);
        overflow-x: hidden;
    }

    @media (hover: hover) {
        * { cursor: none !important; }
    }
    .solvus-cursor {
        position: fixed; width: 8px; height: 8px;
        background: var(--c-cyan); border-radius: 50%;
        pointer-events: none; z-index: 99999;
        opacity: 0; margin-left: -4px; margin-top: -4px;
        transition: opacity 0.15s; will-change: left, top;
    }

    #webgl-canvas {
        position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
        z-index: 0; pointer-events: none;
    }

    nav {
        position: fixed; top: 0; width: 100%; height: var(--nav-height);
        display: flex; justify-content: space-between; align-items: center;
        padding: 0 4vw; z-index: 50; mix-blend-mode: difference; color: #fff;
    }
    .brand { font-weight: 200; letter-spacing: 4px; text-transform: uppercase; font-size: 1.2rem; }
    .nav-links { display: flex; gap: 3vw; font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; }

    main { position: relative; z-index: 10; }

    section {
        min-height: 100vh; width: 100vw;
        padding: calc(var(--nav-height) + 4vw) 5vw 8vw 5vw;
        position: relative;
    }

    h1 {
        font-size: clamp(4rem, 10vw, 11rem); font-weight: 100;
        letter-spacing: -0.05em; line-height: 0.85; margin: 0 0 2rem 0;
    }
    h2 {
        font-size: clamp(2.5rem, 6vw, 6.5rem); font-weight: 100;
        letter-spacing: -0.03em; line-height: 0.95; margin: 0 0 2rem 0;
    }
    h3 { font-weight: 200; font-size: clamp(1.5rem, 3vw, 2.5rem); margin: 0 0 1rem 0; letter-spacing: -0.02em; }
    
    .mono-label {
        font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.15em;
        text-transform: uppercase; margin-bottom: 2rem; display: inline-block;
        padding: 6px 12px; border: 1px solid currentColor; border-radius: 4px;
    }

    p {
        font-size: clamp(1rem, 1.2vw, 1.3rem); line-height: 1.6;
        max-width: 650px; margin: 0 0 1.5rem 0; font-weight: 200; opacity: 0.8;
    }

    .btn {
        display: inline-flex; align-items: center; gap: 1rem;
        padding: 1.2rem 2.5rem; border: 1px solid currentColor;
        background: transparent; color: var(--c-white);
        font-family: var(--font-mono); font-size: 0.75rem; text-transform: uppercase;
        transition: background 0.35s cubic-bezier(0.16,1,0.3,1),
                    color 0.35s cubic-bezier(0.16,1,0.3,1),
                    border-color 0.35s;
        text-decoration: none; letter-spacing: 2px; border-radius: 40px;
    }
    .btn:hover { background: var(--c-cyan); color: var(--c-navy) !important; border-color: var(--c-cyan); }

    .btn-solid { background: var(--c-white); color: var(--c-navy); border-color: var(--c-white); }
    .btn-solid:hover { background: var(--c-cyan); color: var(--c-navy) !important; border-color: var(--c-cyan); }
    .btn-group { display: flex; gap: 1rem; margin-top: 2rem; flex-wrap: wrap; }

    .trust-strip {
        font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 2px;
        color: var(--c-cyan); margin-top: 4rem; display: flex; gap: 2.5rem; opacity: 0.7;
    }

    .dark-sec { color: var(--c-white); background-color: transparent; }
    .light-sec { color: var(--c-navy); background-color: var(--c-white); }
    .light-sec .btn { color: var(--c-navy); border-color: var(--c-navy); }
    .light-sec .btn:hover { background: var(--c-navy); color: var(--c-white) !important; border-color: var(--c-navy); }
    .light-sec .btn-solid { background: var(--c-navy); color: var(--c-white); border-color: var(--c-navy); }
    .light-sec .btn-solid:hover { background: var(--c-cyan); color: var(--c-navy) !important; border-color: var(--c-cyan); }

    .split-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8vw; align-items: center; }
    
    .symmetrical-outcomes {
        width: 100%; max-width: 1400px;
        display: grid; grid-template-columns: 1fr 1fr;
        gap: 2rem; margin: 0 auto;
    }
    .outcome-card {
        background: rgba(2, 6, 13, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.05); padding: 4rem 3rem; border-radius: 4px;
        display: flex; flex-direction: column; align-items: center; text-align: center;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.6s ease, background 0.6s ease;
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    }
    .outcome-card:hover {
        transform: scale(1.02) translateY(-6px); border-color: rgba(0, 229, 255, 0.4); background: rgba(0, 229, 255, 0.03);
    }
    .outcome-card p { opacity: 0.6; transition: opacity 0.4s ease; margin: 0 auto; }
    .outcome-card:hover p { opacity: 1; }

    .carousel-wrap { margin-top: 5rem; position: relative; }
    .carousel-stage {
        border-radius: 12px; overflow: hidden;
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 40px 80px rgba(0,0,0,0.5);
    }
    .browser-chrome {
        display: flex; align-items: center; gap: 1rem; padding: 0.9rem 1.4rem;
        background: #1a1f2e; border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .browser-dots { display: flex; gap: 6px; }
    .browser-dots span { width: 12px; height: 12px; border-radius: 50%; display: block; }
    .browser-url-bar {
        flex: 1; background: rgba(255,255,255,0.06); border-radius: 20px;
        padding: 5px 14px; font-family: var(--font-mono); font-size: 0.7rem;
        color: rgba(255,255,255,0.4); letter-spacing: 0.05em;
        transition: color 0.4s;
    }
    .carousel-frames {
        position: relative; overflow: hidden;
        /* height set dynamically by scaleCarousel() */
    }
    .carousel-frame {
        position: absolute; inset: 0;
        opacity: 0; transition: opacity 0.5s ease;
        pointer-events: none;
    }
    .carousel-frame.active {
        opacity: 1; pointer-events: auto;
    }
    .carousel-frame iframe {
        width: 1440px; height: 900px;
        border: none; display: block;
        transform-origin: top left;
        /* transform: scale(x) injected by scaleCarousel() */
    }
    .carousel-arrow {
        position: absolute; top: 50%; transform: translateY(-50%);
        width: 52px; height: 52px; border-radius: 50%;
        background: rgba(10,17,30,0.85); border: 1px solid rgba(255,255,255,0.15);
        color: var(--c-white); font-size: 1.1rem; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: background 0.3s, border-color 0.3s, transform 0.3s;
        z-index: 20; backdrop-filter: blur(8px);
    }
    .carousel-arrow:hover {
        background: var(--c-cyan); border-color: var(--c-cyan);
        color: var(--c-navy); transform: translateY(-50%) scale(1.1);
    }
    .carousel-arrow.prev { left: -26px; }
    .carousel-arrow.next { right: -26px; }
    .carousel-footer {
        display: flex; justify-content: space-between; align-items: center;
        margin-top: 2rem; padding: 0 0.5rem;
    }
    .carousel-site-info { }
    .carousel-site-name {
        font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.2em;
        text-transform: uppercase; color: var(--c-cyan); margin-bottom: 0.4rem;
    }
    .carousel-site-desc {
        font-size: 1.1rem; font-weight: 200; color: var(--c-white); opacity: 0.7;
    }
    .carousel-dots { display: flex; gap: 0.6rem; align-items: center; }
    .carousel-dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: rgba(255,255,255,0.2); border: none; cursor: pointer;
        transition: background 0.3s, transform 0.3s; padding: 0;
    }
    .carousel-dot.active {
        background: var(--c-cyan); transform: scale(1.3);
    }
    .carousel-counter {
        font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em;
        color: rgba(255,255,255,0.3);
    }

    .process-timeline { position: relative; margin-top: 6rem; padding-left: 2rem; border-left: 1px solid rgba(2,6,13,0.1); }
    .timeline-progress { position: absolute; left: -1px; top: 0; width: 3px; height: 0%; background: var(--c-cyan); }
    .process-step { margin-bottom: 6rem; position: relative; padding-left: 3rem; }
    .step-dot {
        position: absolute; left: -2rem; top: 1rem; width: 15px; height: 15px;
        background: var(--c-white); border: 2px solid var(--c-cyan); border-radius: 50%;
        transform: translateX(-50%); transition: transform 0.3s, background 0.3s;
    }
    .process-step:hover .step-dot { transform: translateX(-50%) scale(1.5); background: var(--c-cyan); }
    .step-meta { font-family: var(--font-mono); font-size: 0.8rem; color: var(--c-cyan); margin-bottom: 1rem; }

    .fit-grid {
        display: grid; grid-template-columns: 1fr 1px 1fr;
        gap: 0; margin-top: 5rem; align-items: start;
    }
    .fit-divider {
        background: rgba(255,255,255,0.08); width: 1px; align-self: stretch;
    }
    .fit-col { padding: 0 4vw; }
    .fit-col:first-child { padding-left: 0; }
    .fit-col:last-child { padding-right: 0; }
    .fit-col-header {
        display: flex; align-items: center; gap: 1.5rem;
        margin-bottom: 3.5rem; padding-bottom: 2rem;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .fit-col-tag {
        font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.2em;
        text-transform: uppercase; padding: 5px 12px; border-radius: 40px;
    }
    .fit-col-tag.yes { background: rgba(0,229,255,0.12); color: var(--c-cyan); border: 1px solid rgba(0,229,255,0.25); }
    .fit-col-tag.no  { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.4); border: 1px solid rgba(255,255,255,0.1); }
    .fit-col-heading {
        font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.15em;
        text-transform: uppercase; opacity: 0.4;
    }
    .fit-row {
        display: flex; gap: 1.5rem; align-items: flex-start;
        margin-bottom: 2.8rem;
    }
    .fit-num {
        font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.1em;
        min-width: 24px; margin-top: 4px; opacity: 0.35;
    }
    .fit-col.yes-col .fit-num { color: var(--c-cyan); opacity: 0.6; }
    .fit-text {
        font-size: clamp(1rem, 1.4vw, 1.2rem); font-weight: 200; line-height: 1.55;
        color: rgba(248,250,252,0.85);
    }
    .fit-text strong { font-weight: 400; color: var(--c-white); }
    .fit-col.no-col .fit-text { color: rgba(248,250,252,0.45); }
    .fit-col.no-col .fit-text strong { color: rgba(248,250,252,0.65); }

    .stagger-text { overflow: hidden; }
    .stagger-text span { display: block; }
    .outline-text { color: var(--c-cyan); }
    
    .bg-giant-text {
        position: absolute; top: 10%; left: -5%; font-size: 25vw; font-weight: 100;
        line-height: 0.8; color: transparent; -webkit-text-stroke: 1px rgba(255,255,255,0.02);
        pointer-events: none; z-index: -1; white-space: nowrap;
    }
    .light-sec .bg-giant-text { -webkit-text-stroke: 1px rgba(2,6,13,0.03); }

    .progress-bar {
        position: fixed; top: 0; left: 0; height: 2px; background: var(--c-cyan);
        width: 0%; z-index: 100; transform-origin: left;
    }

    /* ── MOBILE ─────────────────────────────────────────────────────── */
    @media (max-width: 768px) {
        :root { --nav-height: 64px; }

        body, html { cursor: auto; }

        nav { padding: 0 5vw; }
        .nav-links { display: none; }

        section {
            padding: calc(var(--nav-height) + 6vw) 6vw 12vw 6vw;
            min-height: auto;
        }
        #s1 { height: auto; min-height: 100svh; padding-top: calc(var(--nav-height) + 8vw); }

        h1 { font-size: clamp(3rem, 13vw, 5rem); margin-bottom: 1.5rem; }
        h2 { font-size: clamp(2rem, 9vw, 3.5rem); }
        h3 { font-size: clamp(1.2rem, 5vw, 1.8rem); }

        p { font-size: 1rem; max-width: 100%; }

        .btn { padding: 1rem 1.6rem; font-size: 0.7rem; }
        .btn-group { flex-direction: column; align-items: flex-start; }

        .trust-strip {
            flex-direction: column; gap: 0.8rem; margin-top: 2.5rem;
            font-size: 0.6rem;
        }

        /* Section 2 */
        .split-grid { grid-template-columns: 1fr; gap: 3rem; }

        /* Section 3 */
        #s3 { padding-left: 4vw; padding-right: 4vw; }
        .symmetrical-outcomes { grid-template-columns: 1fr; gap: 1.2rem; }
        .outcome-card { padding: 2.5rem 1.8rem; }

        /* Carousel */
        .carousel-wrap { margin-top: 3rem; }
        .carousel-arrow { width: 40px; height: 40px; font-size: 0.9rem; }
        .carousel-arrow.prev { left: -18px; }
        .carousel-arrow.next { right: -18px; }
        .carousel-footer { flex-direction: column; align-items: flex-start; gap: 1.2rem; }
        .carousel-site-desc { font-size: 0.9rem; }

        /* Section 5 process */
        .process-timeline { padding-left: 1.5rem; }
        .process-step { padding-left: 2rem; margin-bottom: 3.5rem; }
        .step-dot { left: -1.5rem; }

        /* Section 6 fit grid */
        .fit-grid { grid-template-columns: 1fr; gap: 3rem; }
        .fit-divider { display: none; }
        .fit-col { padding: 0; }
        .fit-col.no-col { border-top: 1px solid rgba(255,255,255,0.08); padding-top: 3rem; }

        /* Section 7 CTA */
        #s7 h2 { font-size: clamp(2.2rem, 10vw, 4rem); }
    }

    @media (max-width: 480px) {
        h1 { font-size: clamp(2.6rem, 14vw, 4rem); }
        .mono-label { font-size: 0.65rem; }
        .outcome-card { padding: 2rem 1.4rem; }
        .carousel-arrow { display: none; }
        .carousel-dots { gap: 0.8rem; }
        .carousel-dot { width: 10px; height: 10px; }
    }
</style>
</head>
<body>

<div class="solvus-cursor" id="solvusCursor"></div>
<div class="progress-bar" id="progressBar"></div>

<nav>
    <a href="#" class="brand" style="text-decoration:none;color:inherit;">Solvus</a>
<div class="nav-links">
    <a href="/process" class="hover-target" style="color: inherit; text-decoration: none;">Process</a>
    <a href="/services" class="hover-target" style="color: inherit; text-decoration: none;">Services</a>
    <a href="/about" class="hover-target" style="color: inherit; text-decoration: none;">About</a>
</div>
</nav>

<canvas id="webgl-canvas"></canvas>

<main>
    <section id="s1" class="dark-sec" style="display: flex; flex-direction: column; justify-content: center; height: 100vh;">
        <div style="max-width: 1200px;">
            <div class="mono-label fade-up" style="color: var(--c-cyan); border-color: var(--c-cyan);">SOLVUS · EST. 2026</div>
            <h1 class="stagger-wrap">
                <span class="stagger-text"><span>Top 1% in</span></span>
                <span class="stagger-text"><span class="outline-text">their market.</span></span>
            </h1>
            <p class="fade-up">Custom-built. Fast. Yours to keep. Built specifically for US real estate agents who are done renting templates.</p>
            <div class="btn-group fade-up">
                <a href="#s7" class="btn btn-solid hover-target">Book a 20-minute call ↗</a>
                <a href="/process" class="btn hover-target">See the process</a>
            </div>
            <div class="trust-strip fade-up">
                <span>BUILT FOR NAR COMPLIANCE</span>
                <span>MLS / IDX READY</span>
                <span>FAIR HOUSING COMPLIANT</span>
            </div>
        </div>
    </section>

    <section id="s2" class="light-sec">
        <div class="bg-giant-text para-text">FAILURE</div>
        <div class="split-grid">
            <div style="padding-right: 4vw;">
                <div class="mono-label">01 / The Problem</div>
                <h2>Most realtor websites are built to sell to realtors, not to buyers.</h2>
                <p>Every Wix template, every Fiverr mockup, every "broker-provided" site is designed to look good in a sales pitch to an agent. It uses stock photos of happy couples holding keys. It has a "Featured Listings" grid that no buyer will ever scroll through. It takes six seconds to load.</p>
            </div>
            <div class="float-y" style="background: var(--c-white); padding: 4rem; border: 1px solid rgba(2,6,13,0.1); box-shadow: 0 30px 60px rgba(0,0,0,0.05);">
                <p>Your buyers are not doing a tour of realtor websites. They are on their phone, on Zillow, with their partner in the passenger seat, trying to decide whether you are worth a phone call in the next twenty minutes.</p>
                <h3 style="margin-top: 3rem; font-weight: 300;">That is a different product.<br>That is what we build.</h3>
            </div>
        </div>
    </section>

    <section id="s3" class="dark-sec" style="display: flex; flex-direction: column; align-items: center; text-align: center;">
        <div class="mono-label">02 / What You Get</div>
        <h2 style="margin-bottom: 6rem;">Four outcomes.<br><span class="outline-text">Every site. Every market.</span></h2>
        
        <div class="symmetrical-outcomes">
            <div class="outcome-card hover-target" >
                <div class="mono-label" style="border-color: var(--c-cyan); color: var(--c-cyan);">01 / LOCAL SERP #1</div>
                <h3 style="font-size: clamp(2rem, 3.5vw, 3.5rem); margin-bottom: 1.5rem;">You show up when someone Googles "realtor in [your city]."</h3>
                <p>Every Solvus site is built for local search from day one. Google Business Profile setup, city and neighborhood pages, schema markup, real reviews. You stop being invisible.</p>
            </div>

            <div class="outcome-card hover-target">
                <div class="mono-label" style="border-color: var(--c-cyan); color: var(--c-cyan);">02 / LOAD TIME 0.6s</div>
                <h3 style="font-size: clamp(2rem, 3.5vw, 3.5rem); margin-bottom: 1.5rem;">Your listings load in under a second. On any phone.</h3>
                <p>Most realtor sites take 4 to 6 seconds to load. Buyers leave at 3. We build with Astro and ship less than 100KB of JavaScript. Your site is faster than Zillow.</p>
            </div>

            <div class="outcome-card hover-target">
                <div class="mono-label" style="border-color: var(--c-cyan); color: var(--c-cyan);">03 / CONTACT RATE +340%</div>
                <h3 style="font-size: clamp(2rem, 3.5vw, 3.5rem); margin-bottom: 1.5rem;">Buyers call you because the site tells them to.</h3>
                <p>Click-to-call on every page. Contact forms that route to your email and CRM. Lead capture that works on mobile, where 75% of your traffic lives.</p>
            </div>

            <div class="outcome-card hover-target">
                <div class="mono-label" style="border-color: var(--c-cyan); color: var(--c-cyan);">04 / TRANSFER DAY ONE</div>
                <h3 style="font-size: clamp(2rem, 3.5vw, 3.5rem); margin-bottom: 1.5rem;">You own it. No subscriptions. No lock-in.</h3>
                <p>On launch day, all files, hosting credentials, and the domain transfer to you. No monthly platform fees. No ransom if you stop paying. It is yours.</p>
            </div>
        </div>
    </section>

    <section id="s4" class="dark-sec" style="background-color: var(--c-navy-light);">
        <div class="split-grid" style="align-items: end;">
            <div>
                <div class="mono-label">03 / Concept Work</div>
                <h2>Three sites. Built to show what Solvus delivers.</h2>
            </div>
            <p style="margin-bottom: 2rem;">Solvus is pre-launch. The sites below are fully designed and coded concepts for fictional realtors, built to demonstrate our standard. Your site will be designed from scratch for your market.</p>
        </div>

        <div class="carousel-wrap">
            <div class="carousel-stage">
                <div class="browser-chrome">
                    <div class="browser-dots">
                        <span style="background:#FF5F57;"></span>
                        <span style="background:#FFBD2E;"></span>
                        <span style="background:#28C840;"></span>
                    </div>
                    <div class="browser-url-bar" id="carouselUrl">chenrealestate.com</div>
                </div>
                <div class="carousel-frames" data-lenis-prevent>
                    <div class="carousel-frame active" id="frame-0">
                        <iframe src="/concepts/chen" title="Chen Real Estate" loading="lazy"></iframe>
                    </div>
                    <div class="carousel-frame" id="frame-1">
                        <iframe src="/concepts/rivera" title="Rivera Homes" loading="lazy"></iframe>
                    </div>
                    <div class="carousel-frame" id="frame-2">
                        <iframe src="/concepts/mountain-west" title="Mountain West Realty" loading="lazy"></iframe>
                    </div>
                </div>
            </div>

            <button class="carousel-arrow prev" id="prevBtn" aria-label="Previous site">←</button>
            <button class="carousel-arrow next" id="nextBtn" aria-label="Next site">→</button>

            <div class="carousel-footer">
                <div class="carousel-site-info">
                    <div class="carousel-site-name" id="carouselLabel">Chen Real Estate</div>
                    <div class="carousel-site-desc" id="carouselDesc">Luxury · Austin · Solo Agent</div>
                </div>
                <div style="display:flex; align-items:center; gap:1.5rem;">
                    <div class="carousel-dots">
                        <button class="carousel-dot active" data-index="0" aria-label="Site 1"></button>
                        <button class="carousel-dot" data-index="1" aria-label="Site 2"></button>
                        <button class="carousel-dot" data-index="2" aria-label="Site 3"></button>
                    </div>
                    <div class="carousel-counter" id="carouselCounter">01 / 03</div>
                </div>
            </div>
        </div>
    </section>

    <section id="s5" class="light-sec">
        <div class="bg-giant-text para-text">TIMELINE</div>
        <div style="max-width: 800px;">
            <div class="mono-label">04 / Process</div>
            <h2>Four weeks from call to launch. No surprises.</h2>
        </div>

        <div class="process-timeline">
            <div class="timeline-progress" id="tlProgress"></div>
            
            <div class="process-step hover-target">
                <div class="step-dot"></div>
                <div class="step-meta">01 // 20 MINUTES</div>
                <h3>Discovery call</h3>
                <p>We learn your market, deals, and what you have tried. You get a real quote and timeline. No pitch deck.</p>
            </div>
            <div class="process-step hover-target">
                <div class="step-dot"></div>
                <div class="step-meta">02 // WEEK 1</div>
                <h3>Design concepts</h3>
                <p>Two design directions, built in the browser, not Figma mockups. You click through real pages. You pick one.</p>
            </div>
            <div class="process-step hover-target">
                <div class="step-dot"></div>
                <div class="step-meta">03 // WEEKS 2-3</div>
                <h3>Build and content</h3>
                <p>We build, wire up MLS, write SEO copy for your farm area, and set up Google Business. You review weekly.</p>
            </div>
            <div class="process-step hover-target">
                <div class="step-dot"></div>
                <div class="step-meta">04 // WEEK 4</div>
                <h3>Launch and training</h3>
                <p>Site goes live. We hand over credentials, train you on the CMS in 30 minutes, and stand by for 30 days post-launch.</p>
            </div>
        </div>
    </section>

    <section id="s6" class="dark-sec" style="background: var(--c-navy-light); padding-top: 6vw;">
        <div class="mono-label" style="color: var(--c-cyan); border-color: var(--c-cyan);">05 / Fit</div>
        <h2 style="max-width: 700px;">Solvus is not for<br>every realtor.</h2>
        <p style="opacity: 0.45; font-size: clamp(1rem, 1.4vw, 1.25rem); margin-bottom: 0;">That is the point.</p>

        <div class="fit-grid">
            <div class="fit-col yes-col">
                <div class="fit-col-header">
                    <span class="fit-col-tag yes">Right fit</span>
                    <span class="fit-col-heading">Built for you if</span>
                </div>
                <div class="fit-row">
                    <span class="fit-num">01</span>
                    <p class="fit-text">You close <strong>10 or more deals a year</strong> and treat this like the business it is.</p>
                </div>
                <div class="fit-row">
                    <span class="fit-num">02</span>
                    <p class="fit-text">You have a <strong>real niche or farm area.</strong> A neighborhood, a price band, a buyer type.</p>
                </div>
                <div class="fit-row">
                    <span class="fit-num">03</span>
                    <p class="fit-text">You are tired of looking like <strong>every other agent</strong> on your MLS.</p>
                </div>
            </div>

            <div class="fit-divider"></div>

            <div class="fit-col no-col">
                <div class="fit-col-header">
                    <span class="fit-col-tag no">Wrong fit</span>
                    <span class="fit-col-heading">Not for you if</span>
                </div>
                <div class="fit-row">
                    <span class="fit-num">01</span>
                    <p class="fit-text">You want the <strong>cheapest option.</strong> Fiverr exists and we will point you there.</p>
                </div>
                <div class="fit-row">
                    <span class="fit-num">02</span>
                    <p class="fit-text">You want to <strong>edit everything daily</strong> yourself. Use Squarespace.</p>
                </div>
                <div class="fit-row">
                    <span class="fit-num">03</span>
                    <p class="fit-text">You think a website is a <strong>commodity.</strong> We cannot change that in a sales call.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="s7" class="dark-sec" style="text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <div style="max-width: 1000px; z-index: 2;">
            <h2 class="stagger-wrap" style="font-size: clamp(3rem, 8vw, 9rem); margin-bottom: 2rem;">
                <span class="stagger-text"><span>Twenty minutes.</span></span>
                <span class="stagger-text"><span class="outline-text">No pitch. We tell</span></span>
                <span class="stagger-text"><span>you if we are a fit.</span></span>
            </h2>
            <p class="fade-up" style="margin: 0 auto 3rem auto; font-size: 1.5rem;">Or email solvus@aisolvus.com if you prefer. We read every message.</p>
            <div class="btn-group fade-up" style="justify-content: center;">
                <a href="mailto:solvus@aisolvus.com" class="btn btn-solid hover-target">Book the call ↗</a>
            </div>
        </div>
    </section>
</main>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" is:inline></script>

<script is:inline>
    gsap.registerPlugin(ScrollTrigger);

    if (window.matchMedia('(hover: hover)').matches) {
        const dot = document.getElementById('solvusCursor');
        if (dot) {
            window.addEventListener('mousemove', (e) => {
                dot.style.left    = e.clientX + 'px';
                dot.style.top     = e.clientY + 'px';
                dot.style.opacity = '1';
            }, { passive: true });

            const iframeArea = document.querySelector('.carousel-frames');
            if (iframeArea) {
                iframeArea.addEventListener('mouseenter', () => { dot.style.opacity = '0'; });
                iframeArea.addEventListener('mouseleave', () => { dot.style.opacity = '1'; });
            }
        }
    }

    const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        direction: 'vertical',
        gestureDirection: 'vertical',
        smooth: true,
        mouseMultiplier: 1,
        smoothTouch: false,
        touchMultiplier: 2,
        infinite: false,
    });

    function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);

    const cursorDot = document.getElementById('cursorDot');
    const cursorRing = document.getElementById('cursorRing');
    let mouseX = window.innerWidth / 2;
    let mouseY = window.innerHeight / 2;
    let ringX = mouseX;
    let ringY = mouseY;

    window.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        gsap.to(cursorDot, { x: mouseX, y: mouseY, duration: 0 });
    });

    gsap.ticker.add(() => {
        ringX += (mouseX - ringX) * 0.15;
        ringY += (mouseY - ringY) * 0.15;
        gsap.set(cursorRing, { x: ringX, y: ringY });
    });

    document.querySelectorAll('.hover-target').forEach(link => {
        link.addEventListener('mouseenter', () => {
            gsap.to(cursorRing, { width: 60, height: 60, backgroundColor: 'rgba(0, 229, 255, 0.1)', duration: 0.3 });
            gsap.to(cursorDot, { scale: 0, duration: 0.2 });
        });
        link.addEventListener('mouseleave', () => {
            gsap.to(cursorRing, { width: 40, height: 40, backgroundColor: 'transparent', duration: 0.3 });
            gsap.to(cursorDot, { scale: 1, duration: 0.2 });
        });
    });

    document.querySelectorAll('.concept-card').forEach(card => {
        card.addEventListener('mousemove', (e) => {
            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            const rotateX = ((y - centerY) / centerY) * -10;
            const rotateY = ((x - centerX) / centerX) * 10;
            gsap.to(card, { rotationX: rotateX, rotationY: rotateY, transformPerspective: 1000, duration: 0.5, ease: "power2.out" });
        });
        card.addEventListener('mouseleave', () => {
            gsap.to(card, { rotationX: 0, rotationY: 0, duration: 0.8, ease: "power2.out" });
        });
    });

    gsap.to("#progressBar", {
        scaleX: 1, ease: "none",
        scrollTrigger: { trigger: "body", start: "top top", end: "bottom bottom", scrub: 0.3 }
    });

    document.querySelectorAll('.stagger-wrap').forEach(wrap => {
        gsap.fromTo(wrap.querySelectorAll('.stagger-text span'), 
            { y: "110%" },
            { y: "0%", duration: 1.2, stagger: 0.1, ease: "power4.out", scrollTrigger: { trigger: wrap, start: "top 85%" } }
        );
    });

    document.querySelectorAll('.fade-up').forEach(elem => {
        gsap.fromTo(elem, 
            { y: 30, opacity: 0 },
            { y: 0, opacity: 1, duration: 1, ease: "power3.out", scrollTrigger: { trigger: elem, start: "top 90%" } }
        );
    });

    document.querySelectorAll('.para-text').forEach(text => {
        gsap.to(text, {
            xPercent: -20, ease: "none",
            scrollTrigger: { trigger: text.parentElement, start: "top bottom", end: "bottom top", scrub: true }
        });
    });

    document.querySelectorAll('.float-y').forEach(elem => {
        const speed = elem.getAttribute('data-speed') || 1;
        gsap.to(elem, {
            y: -100 * speed, ease: "none",
            scrollTrigger: { trigger: elem.parentElement, start: "top bottom", end: "bottom top", scrub: true }
        });
    });

    gsap.to("#tlProgress", {
        height: "100%", ease: "none",
        scrollTrigger: { trigger: ".process-timeline", start: "top center", end: "bottom center", scrub: 1 }
    });

    function scaleCarousel() {
        const framesEl = document.querySelector('.carousel-frames');
        if (!framesEl) return;
        const containerW = framesEl.offsetWidth;
        const scale = containerW / 1440;
        framesEl.style.height = Math.round(900 * scale) + 'px';
        framesEl.querySelectorAll('iframe').forEach(el => {
            el.style.transform = `scale(${scale})`;
        });
    }
    scaleCarousel();
    window.addEventListener('resize', scaleCarousel);

    const carouselData = [
        { url: 'chenrealestate.com', name: 'Chen Real Estate', desc: 'Luxury · Austin · Solo Agent' },
        { url: 'riverahomes.com',    name: 'Rivera Homes',     desc: 'Family Realtor · Tampa · Warm Brand' },
        { url: 'mountainwestrealty.com', name: 'Mountain West Realty', desc: 'Team Brokerage · Denver · Editorial' },
    ];
    let currentSlide = 0;

    function goToSlide(idx) {
        document.getElementById('frame-' + currentSlide).classList.remove('active');
        document.querySelectorAll('.carousel-dot')[currentSlide].classList.remove('active');
        currentSlide = (idx + carouselData.length) % carouselData.length;
        document.getElementById('frame-' + currentSlide).classList.add('active');
        document.querySelectorAll('.carousel-dot')[currentSlide].classList.add('active');
        document.getElementById('carouselUrl').textContent   = carouselData[currentSlide].url;
        document.getElementById('carouselLabel').textContent = carouselData[currentSlide].name;
        document.getElementById('carouselDesc').textContent  = carouselData[currentSlide].desc;
        document.getElementById('carouselCounter').textContent = '0' + (currentSlide + 1) + ' / 03';
    }

    document.getElementById('prevBtn').addEventListener('click', () => goToSlide(currentSlide - 1));
    document.getElementById('nextBtn').addEventListener('click', () => goToSlide(currentSlide + 1));
    document.querySelectorAll('.carousel-dot').forEach(dot => {
        dot.addEventListener('click', () => goToSlide(+dot.dataset.index));
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft')  goToSlide(currentSlide - 1);
        if (e.key === 'ArrowRight') goToSlide(currentSlide + 1);
    });

    const canvas = document.getElementById('webgl-canvas');
    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x03060C, 0.002);

    const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = 60;

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const particleGeo = new THREE.BufferGeometry();
    const pCount = 3000;
    const pArray = new Float32Array(pCount * 3);
    for(let i=0; i<pCount*3; i++) {
        pArray[i] = (Math.random() - 0.5) * 200;
    }
    particleGeo.setAttribute('position', new THREE.BufferAttribute(pArray, 3));
    
    const colorCyan = new THREE.Color(0x00E5FF);
    const colorNavy = new THREE.Color(0x03060C);
    
    const particleMat = new THREE.PointsMaterial({ size: 0.15, color: colorCyan, transparent: true, opacity: 0.3 });
    const particles = new THREE.Points(particleGeo, particleMat);
    scene.add(particles);

    const geoGroup = new THREE.Group();
    scene.add(geoGroup);

    const matWire = new THREE.LineBasicMaterial({ color: colorCyan, transparent: true, opacity: 0.1 });
    
    for(let i=0; i<5; i++) {
        const geo = i % 2 === 0 ? new THREE.IcosahedronGeometry(20, 1) : new THREE.OctahedronGeometry(25, 2);
        const mesh = new THREE.LineSegments(new THREE.EdgesGeometry(geo), matWire);
        mesh.position.set((Math.random() - 0.5) * 40, (Math.random() - 0.5) * 40, -i * 50);
        mesh.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, 0);
        geoGroup.add(mesh);
    }

    ScrollTrigger.create({
        trigger: "body", start: "top top", end: "bottom bottom", scrub: 1,
        onUpdate: (self) => {
            camera.position.z = 60 - (self.progress * 250);
            camera.rotation.z = self.progress * 0.5;

            const currentSection = Math.floor(self.progress * 7);
            if (currentSection === 1 || currentSection === 4 || currentSection === 5) {
                particleMat.color.lerp(colorNavy, 0.1);
                matWire.color.lerp(colorNavy, 0.1);
                scene.fog.color.lerp(new THREE.Color(0xF8FAFC), 0.1);
            } else {
                particleMat.color.lerp(colorCyan, 0.1);
                matWire.color.lerp(colorCyan, 0.1);
                scene.fog.color.lerp(colorNavy, 0.1);
            }
        }
    });

    const clock = new THREE.Clock();
    function animate() {
        requestAnimationFrame(animate);
        const t = clock.getElapsedTime();
        
        geoGroup.rotation.x = Math.sin(t * 0.1) * 0.2;
        geoGroup.rotation.y += 0.001;
        
        particles.position.y = Math.sin(t * 0.2) * 5;
        particles.rotation.y = t * 0.02;

        geoGroup.children.forEach((child, index) => {
            child.rotation.x += 0.002 * (index % 2 === 0 ? 1 : -1);
            child.rotation.y += 0.003;
        });

        renderer.render(scene, camera);
    }
    animate();

    window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
    });
</script>
</body>
</html>
