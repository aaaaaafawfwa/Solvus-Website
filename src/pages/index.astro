<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Solvus | Engineered Real Estate</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;200;300;400&family=Space+Mono&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.29/bundled/lenis.min.js" is:inline></script>

<style>
    :root {
        --nav-height: 80px;
        --c-navy: #03060C;
        --c-navy-light: #0A111E;
        --c-white: #F8FAFC;
        --c-cyan: #00E5FF;
        --c-muted: #4A5D7E;
        --font-sans: 'Outfit', sans-serif;
        --font-mono: 'Space Mono', monospace;
    }

    * { box-sizing: border-box; }
    
    html.lenis { height: auto; }
    .lenis.lenis-smooth { scroll-behavior: auto; }
    .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
    .lenis.lenis-stopped { overflow: hidden; }
    .lenis.lenis-scrolling iframe { pointer-events: none; }
    /* Re-enable the active carousel iframe — we handle swipe inside it directly */
    .lenis.lenis-scrolling .carousel-frame.active iframe { pointer-events: auto; }

    body, html {
        margin: 0; padding: 0;
        font-family: var(--font-sans);
        background-color: var(--c-navy);
        color: var(--c-white);
        overflow-x: hidden;
    }

    @media (hover: hover) {
        * { cursor: none !important; }
    }
    .solvus-cursor {
        position: fixed; width: 8px; height: 8px;
        background: var(--c-cyan); border-radius: 50%;
        pointer-events: none; z-index: 99999;
        opacity: 0; margin-left: -4px; margin-top: -4px;
        transition: opacity 0.15s; will-change: left, top;
    }

    #webgl-canvas {
        position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
        z-index: 0; pointer-events: none;
    }

    nav {
        position: fixed; top: 0; width: 100%; height: var(--nav-height);
        display: flex; justify-content: space-between; align-items: center;
        padding: 0 4vw; z-index: 50; mix-blend-mode: difference; color: #fff;
    }
    .brand { font-weight: 200; letter-spacing: 4px; text-transform: uppercase; font-size: 1.2rem; }
    .nav-links { display: flex; gap: 3vw; font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; }

    main { position: relative; z-index: 10; }
    #s1 { height: 100vh; }

    section {
        min-height: 100vh; width: 100%;
        padding: calc(var(--nav-height) + 4vw) 5vw 8vw 5vw;
        position: relative;
    }

    h1 {
        font-size: clamp(4rem, 10vw, 11rem); font-weight: 100;
        letter-spacing: -0.05em; line-height: 0.85; margin: 0 0 2rem 0;
    }
    h2 {
        font-size: clamp(2.5rem, 6vw, 6.5rem); font-weight: 100;
        letter-spacing: -0.03em; line-height: 0.95; margin: 0 0 2rem 0;
    }
    h3 { font-weight: 200; font-size: clamp(1.5rem, 3vw, 2.5rem); margin: 0 0 1rem 0; letter-spacing: -0.02em; }
    
    .mono-label {
        font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.15em;
        text-transform: uppercase; margin-bottom: 2rem; display: inline-block;
        padding: 6px 12px; border: 1px solid currentColor; border-radius: 4px;
    }

    p {
        font-size: clamp(1rem, 1.2vw, 1.3rem); line-height: 1.6;
        max-width: 650px; margin: 0 0 1.5rem 0; font-weight: 200; opacity: 0.8;
    }

    .btn {
        display: inline-flex; align-items: center; gap: 1rem;
        padding: 1.2rem 2.5rem; border: 1px solid currentColor;
        background: transparent; color: var(--c-white);
        font-family: var(--font-mono); font-size: 0.75rem; text-transform: uppercase;
        transition: background 0.35s cubic-bezier(0.16,1,0.3,1),
                    color 0.35s cubic-bezier(0.16,1,0.3,1),
                    border-color 0.35s;
        text-decoration: none; letter-spacing: 2px; border-radius: 40px;
    }
    .btn:hover { background: var(--c-cyan); color: var(--c-navy) !important; border-color: var(--c-cyan); }

    .btn-solid { background: var(--c-white); color: var(--c-navy); border-color: var(--c-white); }
    .btn-solid:hover { background: var(--c-cyan); color: var(--c-navy) !important; border-color: var(--c-cyan); }
    .btn-group { display: flex; gap: 1rem; margin-top: 2rem; flex-wrap: wrap; }

    .trust-strip {
        font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 2px;
        color: var(--c-cyan); margin-top: 4rem; display: flex; gap: 2.5rem; opacity: 0.7;
    }

    .dark-sec { color: var(--c-white); background-color: transparent; }
    .light-sec { color: var(--c-navy); background-color: var(--c-white); }
    .light-sec .btn { color: var(--c-navy); border-color: var(--c-navy); }
    .light-sec .btn:hover { background: var(--c-navy); color: var(--c-white) !important; border-color: var(--c-navy); }
    .light-sec .btn-solid { background: var(--c-navy); color: var(--c-white); border-color: var(--c-navy); }
    .light-sec .btn-solid:hover { background: var(--c-cyan); color: var(--c-navy) !important; border-color: var(--c-cyan); }

    .split-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8vw; align-items: center; }
    
    .outcomes-list { width: 100%; max-width: 1400px; }
    .outcome-row {
        display: grid; grid-template-columns: 50px 220px 1fr;
        align-items: start; gap: 4vw;
        padding: 4rem 0;
        border-top: 1px solid rgba(255,255,255,0.07);
        transition: background 0.5s;
    }
    .outcome-row:last-child { border-bottom: 1px solid rgba(255,255,255,0.07); }
    .outcome-row:hover { background: rgba(0,229,255,0.025); }
    .outcome-idx {
        font-family: var(--font-mono); font-size: 0.65rem;
        color: rgba(255,255,255,0.2); letter-spacing: 0.1em; padding-top: 0.5rem;
    }
    .outcome-metric {
        font-family: var(--font-mono); font-weight: 100;
        font-size: clamp(2.5rem, 4.5vw, 5rem);
        color: var(--c-cyan); line-height: 1; letter-spacing: -0.03em;
    }
    .outcome-tag {
        font-family: var(--font-mono); font-size: 0.65rem;
        letter-spacing: 0.15em; text-transform: uppercase;
        color: rgba(255,255,255,0.3); margin-bottom: 1rem;
    }
    .outcome-title {
        font-size: clamp(1.1rem, 1.8vw, 1.7rem); font-weight: 200;
        line-height: 1.35; margin: 0 0 1rem 0; max-width: 520px;
    }
    .outcome-body {
        font-size: clamp(0.9rem, 1vw, 1.1rem); line-height: 1.6;
        opacity: 0.5; max-width: 500px; margin: 0;
    }

    .carousel-wrap { margin-top: 5rem; position: relative; }
    .carousel-stage {
        border-radius: 12px; overflow: hidden;
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 40px 80px rgba(0,0,0,0.5);
    }
    .browser-chrome {
        display: flex; align-items: center; gap: 1rem; padding: 0.9rem 1.4rem;
        background: #1a1f2e; border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .browser-dots { display: flex; gap: 6px; }
    .browser-dots span { width: 12px; height: 12px; border-radius: 50%; display: block; }
    .browser-url-bar {
        flex: 1; background: rgba(255,255,255,0.06); border-radius: 20px;
        padding: 5px 14px; font-family: var(--font-mono); font-size: 0.7rem;
        color: rgba(255,255,255,0.4); letter-spacing: 0.05em;
        transition: color 0.4s;
    }
    .carousel-frames {
        position: relative; overflow: hidden;
        /* height set dynamically by scaleCarousel() */
    }
    .carousel-frame {
        position: absolute; inset: 0;
        opacity: 0; transition: opacity 0.5s ease;
        pointer-events: none;
    }
    .carousel-frame.active {
        opacity: 1; pointer-events: auto;
    }
    .carousel-frame iframe {
        width: 1440px; height: 900px;
        border: none; display: block;
        transform-origin: top left;
        /* transform: scale(x) injected by scaleCarousel() */
    }
    .carousel-arrow {
        position: absolute; top: 50%; transform: translateY(-50%);
        width: 52px; height: 52px; border-radius: 50%;
        background: rgba(10,17,30,0.85); border: 1px solid rgba(255,255,255,0.15);
        color: var(--c-white); font-size: 1.1rem; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: background 0.3s, border-color 0.3s, transform 0.3s;
        z-index: 20; backdrop-filter: blur(8px);
    }
    .carousel-arrow:hover {
        background: var(--c-cyan); border-color: var(--c-cyan);
        color: var(--c-navy); transform: translateY(-50%) scale(1.1);
    }
    .carousel-arrow.prev { left: -26px; }
    .carousel-arrow.next { right: -26px; }
    .carousel-footer {
        display: flex; justify-content: space-between; align-items: center;
        margin-top: 2rem; padding: 0 0.5rem;
    }
    .carousel-site-info { }
    .carousel-site-name {
        font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.2em;
        text-transform: uppercase; color: var(--c-cyan); margin-bottom: 0.4rem;
    }
    .carousel-site-desc {
        font-size: 1.1rem; font-weight: 200; color: var(--c-white); opacity: 0.7;
    }
    .carousel-dots { display: flex; gap: 0.6rem; align-items: center; }
    .carousel-dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: rgba(255,255,255,0.2); border: none; cursor: pointer;
        transition: background 0.3s, transform 0.3s; padding: 0;
    }
    .carousel-dot.active {
        background: var(--c-cyan); transform: scale(1.3);
    }
    .carousel-counter {
        font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em;
        color: rgba(255,255,255,0.3);
    }

    .process-timeline { position: relative; margin-top: 6rem; padding-left: 2rem; border-left: 1px solid rgba(2,6,13,0.1); }
    .timeline-progress { position: absolute; left: -1px; top: 0; width: 3px; height: 0%; background: var(--c-cyan); }
    .process-step { margin-bottom: 6rem; position: relative; padding-left: 3rem; }
    .step-dot {
        position: absolute; left: -2rem; top: 1rem; width: 15px; height: 15px;
        background: var(--c-white); border: 2px solid var(--c-cyan); border-radius: 50%;
        transform: translateX(-50%); transition: transform 0.3s, background 0.3s;
    }
    .process-step:hover .step-dot { transform: translateX(-50%) scale(1.5); background: var(--c-cyan); }
    .step-meta { font-family: var(--font-mono); font-size: 0.8rem; color: var(--c-cyan); margin-bottom: 1rem; }

    .fit-grid {
        display: grid; grid-template-columns: 1fr 1px 1fr;
        gap: 0; margin-top: 5rem; align-items: start;
    }
    .fit-divider {
        background: rgba(255,255,255,0.08); width: 1px; align-self: stretch;
    }
    .fit-col { padding: 0 4vw; }
    .fit-col:first-child { padding-left: 0; }
    .fit-col:last-child { padding-right: 0; }
    .fit-col-header {
        display: flex; align-items: center; gap: 1.5rem;
        margin-bottom: 3.5rem; padding-bottom: 2rem;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .fit-col-tag {
        font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.2em;
        text-transform: uppercase; padding: 5px 12px; border-radius: 40px;
    }
    .fit-col-tag.yes { background: rgba(0,229,255,0.12); color: var(--c-cyan); border: 1px solid rgba(0,229,255,0.25); }
    .fit-col-tag.no  { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.4); border: 1px solid rgba(255,255,255,0.1); }
    .fit-col-heading {
        font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.15em;
        text-transform: uppercase; opacity: 0.4;
    }
    .fit-row {
        display: flex; gap: 1.5rem; align-items: flex-start;
        margin-bottom: 2.8rem;
    }
    .fit-num {
        font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.1em;
        min-width: 24px; margin-top: 4px; opacity: 0.35;
    }
    .fit-col.yes-col .fit-num { color: var(--c-cyan); opacity: 0.6; }
    .fit-text {
        font-size: clamp(1rem, 1.4vw, 1.2rem); font-weight: 200; line-height: 1.55;
        color: rgba(248,250,252,0.85);
    }
    .fit-text strong { font-weight: 400; color: var(--c-white); }
    .fit-col.no-col .fit-text { color: rgba(248,250,252,0.45); }
    .fit-col.no-col .fit-text strong { color: rgba(248,250,252,0.65); }

    .stagger-text { overflow: hidden; }
    .stagger-text span { display: block; }
    .outline-text { color: var(--c-cyan); }
    
    .bg-giant-text {
        position: absolute; top: 10%; left: -5%; font-size: 25vw; font-weight: 100;
        line-height: 0.8; color: transparent; -webkit-text-stroke: 1px rgba(255,255,255,0.02);
        pointer-events: none; z-index: -1; white-space: nowrap;
    }
    .light-sec .bg-giant-text { -webkit-text-stroke: 1px rgba(2,6,13,0.03); }

    .progress-bar {
        position: fixed; top: 0; left: 0; height: 2px; background: var(--c-cyan);
        width: 0%; z-index: 100; transform-origin: left;
    }

    /* ── MOBILE ─────────────────────────────────────────────────────── */
    @media (max-width: 768px) {
        :root { --nav-height: 64px; }

        body, html { cursor: auto; }

        nav { padding: 0 5vw; mix-blend-mode: normal; background: rgba(3,6,12,0.92); backdrop-filter: blur(16px); }
        .nav-links { display: none; }
        .brand { font-size: 1rem; letter-spacing: 2px; }

        section {
            padding: calc(var(--nav-height) + 6vw) 6vw 12vw 6vw;
            min-height: auto;
        }
        #s1 { height: auto; min-height: 100svh; padding-top: calc(var(--nav-height) + 8vw); }

        h1 { font-size: clamp(3rem, 13vw, 5rem); margin-bottom: 1.5rem; }
        h2 { font-size: clamp(2rem, 9vw, 3.5rem); }
        h3 { font-size: clamp(1.2rem, 5vw, 1.8rem); }

        p { font-size: 1rem; max-width: 100%; }

        .btn { padding: 1rem 1.6rem; font-size: 0.7rem; }
        .btn-group { flex-direction: column; align-items: flex-start; }

        .trust-strip {
            flex-direction: column; gap: 0.8rem; margin-top: 2.5rem;
            font-size: 0.6rem;
        }

        /* Section 2 */
        .split-grid { grid-template-columns: 1fr; gap: 2rem; height: auto !important; }
        .light-sec .float-y { padding: 1.8rem !important; }

        /* Section 3 */
        #s3 { padding-left: 4vw; padding-right: 4vw; }
        #s3 h2 { margin-bottom: 2rem !important; }
        .outcome-row { grid-template-columns: 1fr; padding: 2rem 0; gap: 0.6rem; }
        .outcome-idx { display: none; }
        .outcome-metric { font-size: clamp(2rem, 8vw, 3rem); }
        .outcome-title { max-width: 100%; font-size: clamp(1rem, 4vw, 1.3rem) !important; }
        .outcome-body { max-width: 100%; }

        /* Carousel */
        .carousel-wrap { margin-top: 2rem; }
        .carousel-arrow { width: 40px; height: 40px; font-size: 0.9rem; }
        .carousel-arrow.prev { left: -18px; }
        .carousel-arrow.next { right: -18px; }
        .carousel-footer { flex-direction: column; align-items: flex-start; gap: 1rem; }
        .carousel-site-desc { font-size: 0.9rem; }

        /* Section 5 process */
        .process-timeline { padding-left: 1.5rem; }
        .process-step { padding-left: 2rem; margin-bottom: 3.5rem; }
        .step-dot { left: -1.5rem; }

        /* Section 6 fit grid */
        .fit-grid { grid-template-columns: 1fr; gap: 3rem; }
        .fit-divider { display: none; }
        .fit-col { padding: 0; }
        .fit-col.no-col { border-top: 1px solid rgba(255,255,255,0.08); padding-top: 3rem; }

        /* Section 7 CTA */
        #s7 h2 { font-size: clamp(2.2rem, 10vw, 4rem) !important; }
        #s7 p { font-size: 1.1rem !important; }
    }

    @media (max-width: 480px) {
        h1 { font-size: clamp(2.6rem, 14vw, 4rem); }
        .mono-label { font-size: 0.65rem; }
        .outcome-card { padding: 1.6rem 1.2rem; }
        .carousel-arrow { display: none; }
        .carousel-dots { gap: 0.8rem; }
        .carousel-dot { width: 10px; height: 10px; }
        .outcome-row { padding: 1.8rem 0; }
    }

    /* ── HAMBURGER ──────────────────────────────────────────────────── */
    .nav-hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        width: 36px;
        height: 36px;
        align-items: center;
        justify-content: center;
        background: none;
        border: none;
        cursor: pointer;
        color: inherit;
        padding: 0;
        z-index: 51;
        position: relative;
    }
    .nav-hamburger span {
        width: 20px;
        height: 1.5px;
        background: currentColor;
        display: block;
        transition: transform 0.3s cubic-bezier(0.16,1,0.3,1), opacity 0.3s;
    }
    .nav-hamburger[aria-expanded="true"] span:nth-child(1) {
        transform: translateY(3.25px) rotate(45deg);
    }
    .nav-hamburger[aria-expanded="true"] span:nth-child(2) {
        transform: translateY(-3.25px) rotate(-45deg);
    }

    /* ── MOBILE NAV OVERLAY ─────────────────────────────────────────── */
    .mobile-nav {
        position: fixed;
        inset: 0;
        background: var(--c-navy);
        z-index: 49;
        transform: translateX(100%);
        transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
        display: flex;
        flex-direction: column;
        padding: calc(var(--nav-height) + 2rem) 6vw 5rem;
    }
    .mobile-nav[data-open="true"] {
        transform: translateX(0);
    }
    .mobile-nav__list {
        list-style: none;
        flex: 1;
        margin: 0;
        padding: 0;
    }
    .mobile-nav__link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(248,250,252,0.75);
        text-decoration: none;
        padding: 1.4rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        transition: color 0.2s;
    }
    .mobile-nav__link::after {
        content: '→';
        font-size: 0.8rem;
        opacity: 0.3;
        transition: opacity 0.2s, transform 0.2s;
    }
    .mobile-nav__link:hover { color: var(--c-cyan); }
    .mobile-nav__link:hover::after { opacity: 1; transform: translate(4px, -2px); }
    .mobile-nav__cta {
        display: block;
        text-align: center;
        padding: 1.1rem;
        background: var(--c-cyan);
        color: var(--c-navy);
        font-family: var(--font-mono);
        font-size: 0.75rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        text-decoration: none;
        border-radius: 40px;
        font-weight: 500;
        margin-top: 2rem;
    }

    /* ── CAROUSEL MOBILE ENHANCEMENTS ───────────────────────────────── */
    .carousel-touch-overlay {
        display: none;
        position: absolute;
        inset: 0;
        z-index: 5;
        cursor: grab;
        touch-action: pan-y;
    }
    .carousel-touch-overlay:active { cursor: grabbing; }
    .carousel-site-link {
        display: none;
        margin-top: 1.2rem;
    }
    .carousel-site-link a {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--c-cyan);
        text-decoration: none;
        border: 1px solid rgba(0,229,255,0.3);
        padding: 0.6rem 1.2rem;
        border-radius: 40px;
        transition: background 0.3s, border-color 0.3s;
    }
    .carousel-site-link a:hover {
        background: rgba(0,229,255,0.08);
        border-color: var(--c-cyan);
    }
    .carousel-swipe-hint {
        display: none;
        font-family: var(--font-mono);
        font-size: 0.6rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.2);
        text-align: center;
        margin-top: 1rem;
    }

    @media (max-width: 768px) {
        .nav-hamburger { display: flex; }
        .carousel-site-link { display: block; }
        .carousel-swipe-hint { display: block; }
    }
</style>
</head>
<body>

<div class="solvus-cursor" id="solvusCursor"></div>
<div class="progress-bar" id="progressBar"></div>

<nav>
    <a href="#" class="brand" style="text-decoration:none;color:inherit;">Solvus</a>
<div class="nav-links">
    <a href="/process" class="hover-target" style="color: inherit; text-decoration: none;">Process</a>
    <a href="/services" class="hover-target" style="color: inherit; text-decoration: none;">Services</a>
    <a href="/about" class="hover-target" style="color: inherit; text-decoration: none;">About</a>
</div>
<button class="nav-hamburger" id="navHamburger" aria-label="Open menu" aria-expanded="false">
    <span></span><span></span>
</button>
</nav>

<div class="mobile-nav" id="mobileNav" aria-hidden="true">
    <ul class="mobile-nav__list">
        <li><a href="/process" class="mobile-nav__link">Process</a></li>
        <li><a href="/services" class="mobile-nav__link">Services</a></li>
        <li><a href="/about" class="mobile-nav__link">About</a></li>
