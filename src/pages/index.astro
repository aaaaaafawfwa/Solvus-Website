---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Eyebrow from '../components/Eyebrow.astro';
import HeroDemo from '../components/HeroDemo.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTABand from '../components/CTABand.astro';

const outcomes = [
  {
    num: '01',
    headline: 'You show up when someone Googles "realtor in [your city]."',
    body: 'Every Solvus site is built for local search from day one. Google Business Profile setup, city and neighborhood pages, schema markup, real reviews. You stop being invisible.',
    proof: { label: 'Local SERP', value: '#1 — 3 months avg' }
  },
  {
    num: '02',
    headline: 'Your listings load in under a second. On any phone.',
    body: 'Most realtor sites take 4 to 6 seconds to load. Buyers leave at 3. We build with Astro and ship less than 100KB of JavaScript. Your site is faster than Zillow.',
    proof: { label: 'Load time', value: '0.6s · LCP' }
  },
  {
    num: '03',
    headline: 'Buyers call you because the site tells them to.',
    body: 'Click-to-call on every page. Contact forms that route to your email and CRM. Lead capture that works on mobile, where 75% of your traffic lives.',
    proof: { label: 'Contact rate', value: '+340% vs avg' }
  },
  {
    num: '04',
    headline: 'You own it. No subscriptions. No lock-in.',
    body: 'On launch day, all files, hosting credentials, and the domain transfer to you. No monthly platform fees. No ransom if you stop paying. It is yours.',
    proof: { label: 'Transfer', value: 'Day one' }
  }
];

const processSteps = [
  {
    num: '01',
    title: 'Discovery call',
    dur: '20 minutes',
    body: 'We learn your market, deals, and what you have tried. You get a real quote and timeline. No pitch deck.'
  },
  {
    num: '02',
    title: 'Design concepts',
    dur: 'Week 1',
    body: 'Two design directions, built in the browser, not Figma mockups. You click through real pages. You pick one.'
  },
  {
    num: '03',
    title: 'Build and content',
    dur: 'Weeks 2–3',
    body: 'We build, wire up MLS, write SEO copy for your farm area, and set up Google Business. You review weekly.'
  },
  {
    num: '04',
    title: 'Launch and training',
    dur: 'Week 4',
    body: 'Site goes live. We hand over credentials, train you on the CMS in 30 minutes, and stand by for 30 days post-launch.'
  }
];

const faqItems = [
  {
    q: 'What about MLS / IDX integration?',
    a: 'Every Solvus site supports MLS integration through iHomefinder, Showcase IDX, or RealGeeks depending on your board. We handle setup, styling, and the approval process with your MLS. Monthly IDX subscription fees are paid directly by you to the provider.'
  },
  {
    q: 'Do I actually own the site?',
    a: 'Yes. On launch day the domain, hosting, repo, and all design files transfer to your accounts. No platform lock-in. If you fire us tomorrow, the site keeps running. That is written into every contract.'
  },
  {
    q: 'What does this cost?',
    a: 'Every site is custom-scoped, so pricing depends on what you need — basic site, team site, or full SEO package. We quote exact numbers on the 20-minute discovery call. No obligation.'
  },
  {
    q: 'How is this different from Wix or Squarespace?',
    a: 'Those are template platforms you rent forever. Page speeds average 4 to 6 seconds, SEO options are limited, and you cannot move the site without rebuilding. A Solvus site is custom code on modern hosting, loads in under a second, and you own every file.'
  },
  {
    q: 'What if I already have a site?',
    a: 'We review it on the discovery call. Sometimes a rebuild is overkill and we recommend targeted improvements instead. If a rebuild makes sense, we handle the migration, keep your existing URLs, and preserve your SEO.'
  }
];
---

<BaseLayout
  title="Solvus — Real Estate Web Design for US Realtors"
  description="Custom websites for US real estate agents. Fast, MLS-ready, SEO-optimized. You own the site. No templates, no subscriptions."
>

  <!-- Structured data -->
  <script type="application/ld+json" slot="structured-data" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ProfessionalService',
    name: 'Solvus',
    description: 'Custom web design and SEO for US real estate agents.',
    url: 'https://solvus.com',
    areaServed: 'United States',
    email: 'hello@solvus.com'
  })} />

  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__copy">
        <div class="reveal"><Eyebrow>Solvus · Est. 2026</Eyebrow></div>

        <h1 class="t-display hero__headline reveal reveal-delay-1">
          Websites that make realtors look like the <em>top 1%</em> in their market.
        </h1>

        <p class="hero__subhead reveal reveal-delay-2">
          Custom-built. Fast. Yours to keep. Built specifically for US real estate agents who are done renting templates.
        </p>

        <div class="hero__actions reveal reveal-delay-3">
          <Button href="/book" variant="primary" size="lg" arrow>Book a 20-minute call</Button>
          <Button href="#work" variant="text">See the work</Button>
        </div>

        <div class="hero__trust reveal reveal-delay-4">
          <span class="hero__trust-item">
            <span class="hero__trust-dot" aria-hidden="true"></span>
            Built for NAR compliance
          </span>
          <span class="hero__trust-item">
            <span class="hero__trust-dot" aria-hidden="true"></span>
            MLS / IDX ready
          </span>
          <span class="hero__trust-item">
            <span class="hero__trust-dot" aria-hidden="true"></span>
            Fair Housing compliant
          </span>
        </div>
      </div>

      <div class="hero__demo reveal reveal-delay-2">
        <HeroDemo />
      </div>
    </div>
  </section>

  <!-- ============ PROBLEM ============ -->
  <section class="problem section">
    <div class="container">
      <div class="problem__inner prose">
        <Eyebrow number="01">The problem</Eyebrow>
        <h2 class="t-h1 problem__headline">
          Most realtor websites are built to sell to <em>realtors</em>, not to buyers.
        </h2>

        <div class="problem__body">
          <p>
            Every Wix template, every Fiverr mockup, every "broker-provided" site is designed to look good in a sales pitch to an agent. It uses stock photos of happy couples holding keys. It has a "Featured Listings" grid that no buyer will ever scroll through. It takes six seconds to load.
          </p>
          <p>
            Your buyers are not doing a tour of realtor websites. They are on their phone, on Zillow, with their partner in the passenger seat, trying to decide whether you are worth a phone call in the next twenty minutes.
          </p>
          <p>
            That is a different product. That is what we build.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ OUTCOMES ============ -->
  <section class="outcomes section on-dark" id="outcomes">
    <div class="container">
      <header class="outcomes__header">
        <Eyebrow number="02">What you get</Eyebrow>
        <h2 class="t-h1 outcomes__headline">Four outcomes. Every site. Every market.</h2>
      </header>

      <div class="outcomes__list">
        {outcomes.map(item => (
          <article class="outcome">
            <div class="outcome__num">{item.num}</div>
            <div class="outcome__main">
              <h3 class="t-h2 outcome__headline">{item.headline}</h3>
              <p class="outcome__body">{item.body}</p>
            </div>
            <div class="outcome__proof">
              <div class="outcome__proof-label">{item.proof.label}</div>
              <div class="outcome__proof-value">{item.proof.value}</div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CONCEPT SHOWCASE STRIP ============ -->
  <section class="work section" id="work">
    <div class="container">
      <header class="work__header">
        <Eyebrow number="03">Concept work</Eyebrow>
        <h2 class="t-h1">Three sites. Built to show what Solvus delivers.</h2>
        <p class="work__honesty t-muted">
          Solvus is pre-launch. The sites below are fully designed and coded concepts for fictional realtors, built to demonstrate our standard. Your site will be designed from scratch for your market. These are not templates we reuse.
        </p>
      </header>

      <div class="work__grid">
        <a href="/work/chen" class="work-card">
          <div class="work-card__media work-card__media--chen">
            <div class="work-card__browser">
              <div class="work-card__dots"><span></span><span></span><span></span></div>
              <div class="work-card__url">sarahchen.realtor</div>
            </div>
            <div class="work-card__preview">
              <div class="work-card__preview-headline">Finding<br/>home,<br/>precisely.</div>
              <div class="work-card__preview-tag">Austin · TX</div>
            </div>
          </div>
          <div class="work-card__meta">
            <h3 class="work-card__title">Chen Real Estate</h3>
            <p class="work-card__desc">Luxury · Austin · Solo agent</p>
          </div>
        </a>

        <a href="/work/rivera" class="work-card">
          <div class="work-card__media work-card__media--rivera">
            <div class="work-card__browser">
              <div class="work-card__dots"><span></span><span></span><span></span></div>
              <div class="work-card__url">riverahomes.com</div>
            </div>
            <div class="work-card__preview">
              <div class="work-card__preview-headline work-card__preview-headline--serif">The home<br/>you grow<br/>into.</div>
              <div class="work-card__preview-tag">Tampa · FL</div>
            </div>
          </div>
          <div class="work-card__meta">
            <h3 class="work-card__title">Rivera Homes</h3>
            <p class="work-card__desc">Family realtor · Tampa · Warm brand</p>
          </div>
        </a>

        <a href="/work/mountain-west" class="work-card">
          <div class="work-card__media work-card__media--mw">
            <div class="work-card__browser">
              <div class="work-card__dots"><span></span><span></span><span></span></div>
              <div class="work-card__url">mountainwest.realty</div>
            </div>
            <div class="work-card__preview">
              <div class="work-card__preview-headline work-card__preview-headline--mono">MOUNTAIN<br/>WEST<br/>REALTY</div>
              <div class="work-card__preview-tag">Denver · CO · 7 agents</div>
            </div>
          </div>
          <div class="work-card__meta">
            <h3 class="work-card__title">Mountain West Realty</h3>
            <p class="work-card__desc">Team brokerage · Denver · Editorial</p>
          </div>
        </a>
      </div>

      <div class="work__footer">
        <Button href="/work" variant="secondary" arrow>See all concepts</Button>
      </div>
    </div>
  </section>

  <!-- ============ PROCESS ============ -->
  <section class="process section">
    <div class="container">
      <header class="process__header">
        <Eyebrow number="04">Process</Eyebrow>
        <h2 class="t-h1">Four weeks from call to launch. No surprises.</h2>
      </header>

      <ol class="process__list" role="list">
        {processSteps.map(step => (
          <li class="process__step">
            <div class="process__num">{step.num}</div>
            <div class="process__content">
              <div class="process__title-row">
                <h3 class="t-h3 process__title">{step.title}</h3>
                <span class="process__dur t-mono">{step.dur}</span>
              </div>
              <p class="process__body t-muted">{step.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============ FIT CHECK ============ -->
  <section class="fit section-sm">
    <div class="container">
      <header class="fit__header">
        <Eyebrow number="05">Honest fit check</Eyebrow>
        <h2 class="t-h1">Solvus is not for every realtor. That is the point.</h2>
      </header>

      <div class="fit__grid">
        <div class="fit__col fit__col--yes">
          <h3 class="t-h3 fit__col-title">
            <span class="fit__badge fit__badge--yes" aria-hidden="true">✓</span>
            Built for you if...
          </h3>
          <ul>
            <li>You close <strong>10 or more deals a year</strong> and are serious about your business.</li>
            <li>You have a <strong>real niche or farm area</strong> — a neighborhood, a price band, a buyer type.</li>
            <li>You are tired of looking like <strong>every other agent</strong> on your MLS.</li>
          </ul>
        </div>

        <div class="fit__col fit__col--no">
          <h3 class="t-h3 fit__col-title">
            <span class="fit__badge fit__badge--no" aria-hidden="true">×</span>
            Not for you if...
          </h3>
          <ul>
            <li>You want the <strong>cheapest option</strong>. Fiverr exists and we will happily point you there.</li>
            <li>You want to <strong>edit everything daily</strong> yourself. Use Squarespace.</li>
            <li>You think a website is a <strong>commodity</strong>. We cannot help you see otherwise in a sales call.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="faq-section section">
    <div class="container">
      <header class="faq-section__header">
        <Eyebrow number="06">Questions</Eyebrow>
        <h2 class="t-h1">Five things every realtor asks us.</h2>
      </header>

      <FAQAccordion items={faqItems} />
    </div>
  </section>

  <!-- ============ FINAL CTA ============ -->
  <CTABand
    headline="Twenty minutes. No pitch. We tell you if we are a fit."
    subhead="Or email hello@solvus.com if you prefer. We read every message."
    primaryText="Book the call"
    primaryHref="/book"
    secondaryText="hello@solvus.com"
    secondaryHref="mailto:hello@solvus.com"
  />

</BaseLayout>

<style>
  /* ============ HERO ============ */
  .hero {
    padding-top: var(--space-16);
    padding-bottom: var(--space-24);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -20%;
    right: -10%;
    width: 60%;
    height: 80%;
    background: radial-gradient(ellipse at center, rgba(232, 85, 61, 0.05), transparent 60%);
    pointer-events: none;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
    align-items: center;
    position: relative;
  }

  @media (min-width: 960px) {
    .hero__inner {
      grid-template-columns: 1.1fr 1fr;
      gap: var(--space-12);
    }
  }

  .hero__copy {
    max-width: 620px;
  }

  .hero__headline {
    margin-top: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .hero__headline em {
    font-style: normal;
    color: var(--color-accent);
    font-weight: var(--weight-medium);
  }

  .hero__subhead {
    font-size: 1.25rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    max-width: 46ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-6);
    margin-top: var(--space-8);
  }

  .hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: 0.04em;
    color: var(--color-text-secondary);
    text-transform: uppercase;
  }

  .hero__trust-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .hero__trust-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  /* ============ PROBLEM ============ */
  .problem__inner {
    max-width: 860px;
  }

  .problem__headline {
    margin-top: var(--space-6);
    margin-bottom: var(--space-12);
    font-size: clamp(2rem, 3.5vw + 1rem, 3rem);
  }

  .problem__headline em {
    font-style: italic;
    color: var(--color-accent);
  }

  .problem__body {
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    max-width: var(--container-text);
  }

  .problem__body p + p {
    margin-top: var(--space-6);
  }

  /* ============ OUTCOMES ============ */
  .outcomes__header {
    max-width: 720px;
    margin-bottom: var(--space-16);
  }

  .outcomes__headline {
    margin-top: var(--space-4);
    color: var(--color-text-on-dark);
  }

  .outcomes__list {
    display: flex;
    flex-direction: column;
  }

  .outcome {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-areas:
      "num headline"
      "num body"
      "proof proof";
    gap: var(--space-4) var(--space-8);
    padding: var(--space-12) 0;
    border-top: 1px solid var(--color-border-dark);
  }

  .outcome:last-child {
    border-bottom: 1px solid var(--color-border-dark);
  }

  @media (min-width: 960px) {
    .outcome {
      grid-template-columns: 60px 1fr auto;
      grid-template-areas: "num main proof";
      align-items: start;
      gap: var(--space-16);
    }
  }

  .outcome__num {
    grid-area: num;
    font-family: var(--font-mono);
    font-size: var(--text-small);
    color: var(--color-accent);
    letter-spacing: 0.04em;
  }

  .outcome__main {
    grid-area: main;
    max-width: 60ch;
  }

  @media (max-width: 959px) {
    .outcome__headline { grid-area: headline; }
    .outcome__body { grid-area: body; }
  }

  .outcome__headline {
    color: var(--color-text-on-dark);
    max-width: 22ch;
  }

  .outcome__body {
    margin-top: var(--space-4);
    color: var(--color-text-muted-dark);
    font-size: 1.0625rem;
    line-height: 1.55;
  }

  .outcome__proof {
    grid-area: proof;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    border: 1px solid var(--color-border-dark);
    border-radius: var(--radius-md);
    min-width: 160px;
    align-self: start;
  }

  .outcome__proof-label {
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted-dark);
  }

  .outcome__proof-value {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    color: var(--color-text-on-dark);
    letter-spacing: -0.02em;
  }

  /* ============ WORK ============ */
  .work__header {
    max-width: 720px;
    margin-bottom: var(--space-16);
  }

  .work__header h2 {
    margin-top: var(--space-4);
  }

  .work__honesty {
    margin-top: var(--space-6);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 60ch;
    padding-left: var(--space-4);
    border-left: 2px solid var(--color-accent);
  }

  .work__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 700px) {
    .work__grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 1040px) {
    .work__grid { grid-template-columns: 1fr 1fr 1fr; }
  }

  .work-card {
    display: block;
    transition: transform var(--duration-base) var(--ease-out);
  }

  .work-card:hover {
    transform: translateY(-4px);
  }

  .work-card__media {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-md);
    transition: box-shadow var(--duration-base);
  }

  .work-card:hover .work-card__media {
    box-shadow: var(--shadow-lg);
  }

  .work-card__media--chen {
    background: linear-gradient(135deg, #F6F5F2 0%, #E8E4DD 100%);
  }

  .work-card__media--rivera {
    background: linear-gradient(135deg, #F5EBE0 0%, #E6CCB2 100%);
  }

  .work-card__media--mw {
    background: linear-gradient(135deg, #0B0B0C 0%, #2A2A2E 100%);
  }

  .work-card__browser {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 8px 12px;
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }

  .work-card__media--mw .work-card__browser {
    background: rgba(20, 20, 22, 0.7);
    border-bottom-color: var(--color-border-dark);
    color: var(--color-text-muted-dark);
  }

  .work-card__dots {
    display: flex;
    gap: 4px;
  }

  .work-card__dots span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(0,0,0,0.15);
  }

  .work-card__media--mw .work-card__dots span {
    background: rgba(255,255,255,0.2);
  }

  .work-card__url {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.02em;
    color: var(--color-text-secondary);
  }

  .work-card__preview {
    padding: var(--space-6);
    height: calc(100% - 31px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .work-card__preview-headline {
    font-size: clamp(1.75rem, 2.5vw, 2.25rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
  }

  .work-card__preview-headline--serif {
    font-family: Georgia, 'Times New Roman', serif;
    font-weight: var(--weight-regular);
    font-style: italic;
  }

  .work-card__preview-headline--mono {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    color: var(--color-text-on-dark);
    font-weight: var(--weight-regular);
  }

  .work-card__preview-tag {
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .work-card__media--mw .work-card__preview-tag {
    color: var(--color-text-muted-dark);
  }

  .work-card__meta {
    margin-top: var(--space-4);
  }

  .work-card__title {
    font-size: 1.125rem;
    font-weight: var(--weight-medium);
    letter-spacing: -0.01em;
  }

  .work-card__desc {
    margin-top: var(--space-1);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .work__footer {
    display: flex;
    justify-content: center;
    margin-top: var(--space-12);
  }

  /* ============ PROCESS ============ */
  .process__header {
    max-width: 720px;
    margin-bottom: var(--space-16);
  }

  .process__header h2 {
    margin-top: var(--space-4);
  }

  .process__list {
    list-style: none;
    padding: 0;
    counter-reset: process;
    max-width: 820px;
