<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mountain West Realty | Denver's Premier Brokerage</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black: #0A0A0A;
    --white: #F5F5F5;
    --red: #E8240A;
    --red-dark: #C01E08;
    --gray: #E0E0E0;
    --mid-gray: #888;
    --light-bg: #F5F5F5;
  }

  html { scroll-behavior: smooth; overflow-x: hidden; overflow-y: auto; }

  body {
    background: var(--white);
    color: var(--black);
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: sticky; top: 0; z-index: 100;
    background: var(--black);
    border-bottom: 4px solid var(--red);
    padding: 0 4vw;
    display: flex; justify-content: space-between; align-items: center;
    height: 68px;
  }
  .nav-logo {
    font-family: 'Anton', sans-serif;
    font-size: 1.1rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--white); text-decoration: none;
  }
  .nav-logo span { color: var(--red); }
  .nav-links {
    display: flex; gap: 2.5rem; list-style: none;
  }
  .nav-links a {
    font-size: 0.75rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(245,245,245,0.5); text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--white); }
  .nav-cta {
    background: var(--red); color: var(--white);
    padding: 0.6rem 1.4rem; font-size: 0.75rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none;
    transition: background 0.2s;
  }
  .nav-cta:hover { background: var(--red-dark); }

  /* MARQUEE */
  .marquee-bar {
    background: var(--red); overflow: hidden; padding: 0.55rem 0;
    white-space: nowrap;
  }
  .marquee-inner {
    display: inline-block;
    animation: marquee 28s linear infinite;
  }
  .marquee-inner span {
    font-family: 'Anton', sans-serif;
    font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--white); margin-right: 4rem;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* HERO */
  .hero {
    display: grid; grid-template-columns: 1fr 1fr; min-height: 100vh;
  }
  .hero-left {
    background: var(--black); display: flex; flex-direction: column;
    justify-content: space-between; padding: 5vw 4vw;
  }
  .hero-eyebrow {
    font-size: 0.7rem; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--red); border-left: 3px solid var(--red); padding-left: 1rem;
  }
  .hero-headline {
    font-family: 'Anton', sans-serif;
    font-size: clamp(5rem, 12vw, 14rem); line-height: 0.88;
    color: var(--white); letter-spacing: 0.01em;
  }
  .hero-headline .red { color: var(--red); }
  .hero-bottom {
    display: flex; justify-content: space-between; align-items: flex-end;
    border-top: 1px solid rgba(245,245,245,0.1); padding-top: 2rem;
  }
  .hero-sub {
    font-size: 0.85rem; line-height: 1.65; color: rgba(245,245,245,0.5);
    max-width: 300px;
  }
  .hero-cta {
    display: inline-block; background: var(--red); color: var(--white);
    padding: 1rem 2rem; font-size: 0.75rem; font-weight: 700;
    letter-spacing: 0.15em; text-transform: uppercase; text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .hero-cta:hover { background: var(--red-dark); transform: translateY(-3px); }

  .hero-right {
    background: var(--light-bg); display: grid;
    grid-template-columns: 1fr 1fr; gap: 3px;
  }
  .hero-grid-cell {
    background: var(--gray); position: relative; overflow: hidden;
    min-height: 200px;
  }
  .hero-grid-cell:nth-child(1) { background: linear-gradient(145deg, #c8d0c0, #809078); background-image: url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=700&q=80'); background-size: cover; background-position: center; }
  .hero-grid-cell:nth-child(2) { background: linear-gradient(145deg, #b0b8a8, #687060); background-image: url('https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=700&q=80'); background-size: cover; background-position: center; }
  .hero-grid-cell:nth-child(3) { background: linear-gradient(145deg, #a8b0a0, #607068); background-image: url('https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&w=700&q=80'); background-size: cover; background-position: center; }
  .hero-grid-cell:nth-child(4) { background: var(--black); }
  .cell-label {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: rgba(10,10,10,0.85); padding: 0.8rem 1rem;
  }
  .cell-price {
    font-family: 'Anton', sans-serif; font-size: 1.2rem;
    color: var(--white); letter-spacing: 0.04em;
  }
  .cell-addr {
    font-size: 0.65rem; font-weight: 400; letter-spacing: 0.08em; text-transform: uppercase;
    color: rgba(245,245,245,0.5); margin-top: 0.15rem;
  }
  .cell-sold {
    position: absolute; top: 1rem; right: 1rem;
    background: var(--red); color: var(--white);
    font-family: 'Anton', sans-serif; font-size: 0.7rem; letter-spacing: 0.12em;
    padding: 0.3rem 0.6rem;
  }
  .big-number-cell {
    display: flex; flex-direction: column; justify-content: center;
    align-items: center; text-align: center; padding: 2rem;
  }
  .big-number {
    font-family: 'Anton', sans-serif; font-size: 3.5rem;
    color: var(--red); line-height: 1; letter-spacing: 0.02em;
  }
  .big-number-label {
    font-size: 0.65rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase;
    color: rgba(245,245,245,0.5); margin-top: 0.5rem;
  }

  /* STATS BAND */
  .stats-band {
    background: var(--black); display: grid; grid-template-columns: repeat(4, 1fr);
    border-top: 4px solid var(--red);
  }
  .stat-block {
    padding: 3rem 4vw; border-right: 1px solid rgba(245,245,245,0.08);
  }
  .stat-block:last-child { border-right: none; }
  .stat-num {
    font-family: 'Anton', sans-serif;
    font-size: clamp(2.5rem, 5vw, 5rem); line-height: 1;
    color: var(--white); letter-spacing: 0.02em; display: block;
    margin-bottom: 0.5rem;
  }
  .stat-num .red { color: var(--red); }
  .stat-desc {
    font-size: 0.7rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--mid-gray);
  }

  /* LISTINGS */
  .listings-section { padding: 6vw 4vw; background: var(--white); }
  .section-header-row {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 3rem; padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--black);
  }
  .section-tag {
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--red); margin-bottom: 0.5rem;
  }
  .section-headline {
    font-family: 'Anton', sans-serif;
    font-size: clamp(2rem, 5vw, 4rem); letter-spacing: 0.03em; text-transform: uppercase;
    line-height: 1;
  }
  .all-link {
    font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--black); text-decoration: none; border-bottom: 2px solid var(--red);
    padding-bottom: 2px; transition: color 0.2s;
  }
  .all-link:hover { color: var(--red); }
  .listings-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;
    background: var(--black);
  }
  .listing-card {
    background: var(--white); overflow: hidden;
    transition: transform 0.3s;
  }
  .listing-card:hover { transform: scale(1.01); z-index: 1; }
  .listing-img {
    height: 200px; position: relative; overflow: hidden;
  }
  .listing-img-bg {
    width: 100%; height: 100%;
    transition: transform 0.5s;
  }
  .listing-card:hover .listing-img-bg { transform: scale(1.05); }
  .listing-img-bg { background-size: cover; background-position: center; }
  .listing-card:nth-child(1) .listing-img-bg { background: linear-gradient(145deg, #a8b098, #606850); background-image: url('https://images.unsplash.com/photo-1583608205776-bfd35f0d9f83?auto=format&fit=crop&w=700&q=80'); background-size: cover; background-position: center; }
  .listing-card:nth-child(2) .listing-img-bg { background: linear-gradient(145deg, #b0a890, #706050); background-image: url('https://images.unsplash.com/photo-1568605114967-8130f3a36994?auto=format&fit=crop&w=700&q=80'); background-size: cover; background-position: center; }
  .listing-card:nth-child(3) .listing-img-bg { background: linear-gradient(145deg, #989898, #505050); background-image: url('https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=700&q=80'); background-size: cover; background-position: center; }
  .listing-status {
    position: absolute; top: 1rem; left: 1rem;
    font-family: 'Anton', sans-serif; font-size: 0.65rem; letter-spacing: 0.12em;
    padding: 0.3rem 0.6rem;
  }
  .status-active { background: #1a7a30; color: #fff; }
  .status-pending { background: #d4920a; color: #fff; }
  .status-sold { background: var(--red); color: #fff; }
  .listing-body { padding: 1.5rem; border-top: 3px solid var(--black); }
  .listing-price {
    font-family: 'Anton', sans-serif; font-size: 1.6rem; letter-spacing: 0.02em;
    margin-bottom: 0.3rem;
  }
  .listing-address {
    font-size: 0.8rem; font-weight: 400; color: var(--mid-gray);
    margin-bottom: 1rem; letter-spacing: 0.03em;
  }
  .listing-specs {
    display: flex; gap: 1.2rem;
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    border-top: 1px solid var(--gray); padding-top: 1rem;
  }

  /* TEAM */
  .team-section { background: var(--light-bg); padding: 6vw 4vw; }
  .team-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;
    background: var(--black); margin-top: 3rem;
  }
  .team-card {
    background: var(--white); overflow: hidden;
    transition: background 0.3s;
  }
  .team-card:hover { background: var(--black); }
  .team-photo {
    height: 280px; filter: grayscale(100%);
    transition: filter 0.4s;
    background: linear-gradient(145deg, #999, #555);
    background-size: cover; background-position: center top;
  }
  .team-card:nth-child(1) .team-photo { background-image: url('https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=500&q=80'); background-size: cover; background-position: center top; }
  .team-card:nth-child(2) .team-photo { background: linear-gradient(145deg, #888, #444); background-image: url('https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?auto=format&fit=crop&w=500&q=80'); background-size: cover; background-position: center top; }
  .team-card:nth-child(3) .team-photo { background: linear-gradient(145deg, #aaa, #666); background-image: url('https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?auto=format&fit=crop&w=500&q=80'); background-size: cover; background-position: center top; }
  .team-card:hover .team-photo { filter: grayscale(0%) sepia(20%); }
  .team-body { padding: 1.5rem; border-top: 3px solid var(--black); transition: border-color 0.3s; }
  .team-card:hover .team-body { border-color: var(--red); }
  .team-name {
    font-family: 'Anton', sans-serif; font-size: 1.3rem; letter-spacing: 0.04em;
    text-transform: uppercase; margin-bottom: 0.2rem;
    transition: color 0.3s;
  }
  .team-card:hover .team-name { color: var(--white); }
  .team-role {
    font-size: 0.7rem; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--red);
  }
  .team-stat {
    margin-top: 1rem; font-size: 0.75rem; color: var(--mid-gray);
    transition: color 0.3s;
  }
  .team-card:hover .team-stat { color: rgba(245,245,245,0.5); }

  /* CTA */
  .cta-section {
    background: var(--black); padding: 8vw 4vw;
    display: grid; grid-template-columns: 1fr auto; gap: 4vw; align-items: center;
    border-top: 4px solid var(--red);
  }
  .cta-headline {
    font-family: 'Anton', sans-serif;
    font-size: clamp(2.5rem, 6vw, 6rem); line-height: 0.9; letter-spacing: 0.02em;
    color: var(--white); text-transform: uppercase;
  }
  .cta-headline .red { color: var(--red); }
  .cta-right { display: flex; flex-direction: column; gap: 1.2rem; align-items: flex-end; }
  .cta-sub {
    font-size: 0.9rem; line-height: 1.65; color: rgba(245,245,245,0.5);
    max-width: 300px; text-align: right;
  }
  .btn-red-big {
    display: inline-block; background: var(--red); color: var(--white);
    padding: 1.2rem 2.5rem; font-family: 'Anton', sans-serif;
    font-size: 1rem; letter-spacing: 0.12em; text-transform: uppercase;
    text-decoration: none; transition: background 0.2s, transform 0.2s;
  }
  .btn-red-big:hover { background: var(--red-dark); transform: translateY(-3px); }

  /* FOOTER */
  footer {
    background: var(--black); padding: 2rem 4vw;
    display: flex; justify-content: space-between; align-items: center;
    border-top: 1px solid rgba(245,245,245,0.08);
  }
  .footer-logo {
    font-family: 'Anton', sans-serif; font-size: 1rem;
    color: var(--white); letter-spacing: 0.08em; text-transform: uppercase;
  }
  .footer-logo span { color: var(--red); }
  .footer-copy {
    font-size: 0.65rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: rgba(245,245,245,0.3);
  }
</style>
</head>
