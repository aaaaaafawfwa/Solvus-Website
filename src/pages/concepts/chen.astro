  <div class="listings-stack">
    <div class="listing-row">
      <div class="listing-img">
        <img src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=1200&q=85" alt="3812 Westlake Drive">
