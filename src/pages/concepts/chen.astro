    <div class="hero-btns">
      <a href="#listings" class="btn-solid">View Listings</a>
      <a href="#agent" class="btn-ghost-text">Meet Sarah →</a>
    </div>
  </div>
  <div class="hero-right">
    <img src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=1200&q=85" alt="Austin luxury property">
    <div class="hero-caption">Westlake Hills · Austin TX</div>
  </div>
</section>

<div class="numbers">
