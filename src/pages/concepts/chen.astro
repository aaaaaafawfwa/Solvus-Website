<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sarah Chen · Real Estate · Austin TX</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:    #F8F5F1;
    --white: #FFFFFF;
    --ink:   #0C0B0A;
    --mid:   #7A6E64;
    --faint: #C4BDB6;
    --stone: #9B8B7A;
    --dark:  #141210;
    --serif: 'Cormorant Garamond', serif;
    --sans:  'DM Sans', sans-serif;
    --nav:   68px;
  }

  /* Scroll fix — overflow-x: clip does NOT suppress overflow-y */
  html {
    overflow-x: clip;
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
  }
  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--sans);
    font-weight: 300;
    overflow-x: clip;
  }

  /* ── NAV ─────────────────────────────────────────────── */
  nav {
    position: fixed; top: 0; left: 0; right: 0;
    height: var(--nav); z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid rgba(12,11,10,.09);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 5vw;
  }
  .nav-logo {
    font-family: var(--serif); font-size: 1.05rem; font-weight: 400;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--ink); text-decoration: none;
  }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a {
    font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--mid); text-decoration: none; transition: color .25s;
  }
  .nav-links a:hover { color: var(--ink); }
  .nav-cta {
    font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink); text-decoration: none;
    border-bottom: 1px solid var(--ink); padding-bottom: 1px;
    transition: color .25s, border-color .25s;
  }
  .nav-cta:hover { color: var(--stone); border-color: var(--stone); }

  /* ── HERO ────────────────────────────────────────────── */
  .hero {
    padding-top: var(--nav);
    min-height: 100vh;
    display: grid; grid-template-columns: 1fr 1fr;
  }
  .hero-left {
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 7vw 5vw 7vw 5vw;
  }
  .hero-kicker {
    font-size: 0.67rem; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--stone); margin-bottom: 3rem;
    display: flex; align-items: center; gap: 1rem;
  }
  .hero-kicker::before {
    content: ''; display: block; width: 28px; height: 1px; background: var(--stone);
  }
  .hero-h1 {
    font-family: var(--serif); font-weight: 300;
    font-size: clamp(3.2rem, 6.5vw, 7rem);
    line-height: 1.0; letter-spacing: -0.02em;
    margin-bottom: 3rem;
  }
  .hero-h1 i { font-style: italic; color: var(--stone); }
  .hero-sub {
    font-size: 0.95rem; line-height: 1.8; color: var(--mid);
    max-width: 370px; margin-bottom: 3.5rem;
  }
  .hero-btns { display: flex; align-items: center; gap: 2.5rem; }
  .btn-solid {
    display: inline-block; padding: 0.85rem 2rem;
    background: var(--ink); color: var(--white);
    font-size: 0.7rem; letter-spacing: 0.16em; text-transform: uppercase;
    text-decoration: none; transition: background .3s;
  }
  .btn-solid:hover { background: var(--stone); }
  .btn-ghost-text {
    font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--mid); text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color .25s, border-color .25s;
  }
  .btn-ghost-text:hover { color: var(--ink); border-color: var(--ink); }

  .hero-right {
    position: relative; overflow: clip;
    background: #D6CFC7;
  }
  .hero-right img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    display: block;
  }
  .hero-caption {
    position: absolute; bottom: 2.5rem; left: 2.5rem;
    font-size: 0.62rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(255,255,255,.55);
    text-shadow: 0 1px 6px rgba(0,0,0,.4);
  }

  /* ── NUMBERS ─────────────────────────────────────────── */
  .numbers {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid rgba(12,11,10,.08);
    border-bottom: 1px solid rgba(12,11,10,.08);
  }
  .num-item {
    padding: 2.8rem 5vw;
    border-right: 1px solid rgba(12,11,10,.08);
  }
  .num-item:last-child { border-right: none; }
  .num-val {
    font-family: var(--serif); font-weight: 300;
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    color: var(--ink); line-height: 1; display: block; margin-bottom: .5rem;
  }
  .num-label {
    font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--faint);
  }

  /* ── LISTINGS ────────────────────────────────────────── */
  .listings { padding: 8vw 5vw; background: var(--white); }
  .sec-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 5rem;
  }
  .sec-label {
    font-size: 0.65rem; letter-spacing: 0.26em; text-transform: uppercase;
    color: var(--stone); margin-bottom: .9rem;
  }
  .sec-title {
    font-family: var(--serif); font-weight: 300;
    font-size: clamp(1.8rem, 3.5vw, 3rem); line-height: 1.1;
  }
  .sec-link {
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--mid); text-decoration: none;
    border-bottom: 1px solid var(--faint); padding-bottom: 2px;
    transition: color .25s, border-color .25s; white-space: nowrap;
  }
  .sec-link:hover { color: var(--ink); border-color: var(--ink); }

  .listings-stack { display: flex; flex-direction: column; gap: 1px; }
  .listing-row {
    display: grid; grid-template-columns: 7fr 3fr;
    background: var(--bg); transition: background .4s;
  }
  .listing-row:hover { background: #EFEBE5; }
  .listing-img {
    height: 400px; overflow: clip; position: relative;
  }
  .listing-img img {
    width: 100%; height: 100%; object-fit: cover; object-position: center;
    display: block;
    transition: transform .9s cubic-bezier(.16,1,.3,1);
  }
  .listing-row:hover .listing-img img { transform: scale(1.04); }
  .listing-tag {
    position: absolute; top: 1.5rem; left: 1.5rem;
    font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase;
    padding: .3rem .8rem; background: var(--ink); color: var(--white);
  }
  .listing-info {
    padding: 3rem; display: flex; flex-direction: column; justify-content: center;
    border-left: 1px solid rgba(12,11,10,.07);
  }
  .listing-price {
    font-family: var(--serif); font-size: 1.9rem; font-weight: 400;
    color: var(--ink); margin-bottom: .5rem;
  }
  .listing-addr {
    font-size: .82rem; line-height: 1.55; color: var(--mid); margin-bottom: 2rem;
  }
  .listing-specs {
    display: flex; flex-direction: column; gap: .4rem;
    border-top: 1px solid rgba(12,11,10,.08); padding-top: 1.8rem;
  }
  .spec-row {
    display: flex; justify-content: space-between;
    font-size: 0.67rem; letter-spacing: .1em; text-transform: uppercase;
  }
  .spec-row span:first-child { color: var(--faint); }
  .spec-row span:last-child  { color: var(--ink); font-weight: 400; }

  /* ── AGENT ───────────────────────────────────────────── */
  .agent {
    display: grid; grid-template-columns: 1fr 1fr;
    min-height: 85vh; background: var(--dark);
  }
  .agent-photo { position: relative; overflow: clip; }
  .agent-photo img {
    width: 100%; height: 100%; object-fit: cover;
    object-position: center top; display: block;
    filter: grayscale(10%);
  }
  .agent-copy {
    padding: 7vw 5vw; display: flex; flex-direction: column; justify-content: center;
  }
  .agent-label {
    font-size: 0.65rem; letter-spacing: 0.26em; text-transform: uppercase;
    color: var(--stone); margin-bottom: 3rem;
  }
  .agent-h2 {
    font-family: var(--serif); font-weight: 300;
    font-size: clamp(2rem, 3.5vw, 3.5rem); line-height: 1.1;
    color: var(--white); margin-bottom: 2.5rem;
  }
  .agent-h2 i { font-style: italic; color: var(--stone); }
  .agent-bio {
    font-size: .92rem; line-height: 1.85;
    color: rgba(248,245,241,.45); margin-bottom: 1.2rem; max-width: 480px;
  }
  .agent-creds {
    margin-top: 3rem; padding-top: 2.5rem;
    border-top: 1px solid rgba(255,255,255,.08);
    display: flex; flex-direction: column; gap: .7rem;
  }
  .cred {
    font-size: 0.68rem; letter-spacing: .1em; text-transform: uppercase;
    color: rgba(248,245,241,.35); display: flex; align-items: center; gap: .8rem;
  }
  .cred::before { content: ''; }

  /* ── TESTIMONIAL ─────────────────────────────────────── */
  .testimonial {
    padding: 10vw 5vw; background: var(--white);
    display: grid; grid-template-columns: 200px 1fr; gap: 6vw; align-items: start;
  }
  .t-meta {
    padding-top: .4rem;
  }
  .t-label {
    font-size: 0.62rem; letter-spacing: 0.24em; text-transform: uppercase;
    color: var(--stone); display: block; margin-bottom: 1rem;
  }
  .t-year {
    font-family: var(--serif); font-size: 3rem; font-weight: 300;
    color: var(--faint); line-height: 1;
  }
  .t-quote {
    font-family: var(--serif); font-style: italic; font-weight: 300;
    font-size: clamp(1.5rem, 2.2vw, 2.1rem); line-height: 1.5;
    color: var(--ink); margin-bottom: 2rem;
  }
  .t-author {
    font-size: 0.7rem; letter-spacing: .15em; text-transform: uppercase;
    color: var(--faint); border-top: 1px solid rgba(12,11,10,.1);
    padding-top: 1.5rem;
  }

  /* ── CONTACT ─────────────────────────────────────────── */
  .contact {
    display: grid; grid-template-columns: 1fr 1fr;
    background: var(--bg);
  }
  .contact-left {
    padding: 7vw 5vw; border-right: 1px solid rgba(12,11,10,.08);
    display: flex; flex-direction: column; justify-content: space-between;
  }
  .contact-h2 {
    font-family: var(--serif); font-weight: 300;
    font-size: clamp(2rem, 3.5vw, 3.2rem); line-height: 1.1; margin-bottom: 2rem;
  }
  .contact-h2 i { font-style: italic; color: var(--stone); }
  .contact-body {
    font-size: .9rem; line-height: 1.8; color: var(--mid); margin-bottom: 3rem;
  }
  .contact-detail {
    font-size: .78rem; color: var(--mid); margin-bottom: .5rem;
  }
  .contact-detail a {
    color: var(--ink); text-decoration: none;
    border-bottom: 1px solid transparent; transition: border-color .25s;
  }
  .contact-detail a:hover { border-color: var(--ink); }
  .contact-right { padding: 7vw 5vw; }
  .form-group { margin-bottom: 1.8rem; }
  .form-group input, .form-group textarea {
    width: 100%; background: transparent; border: none;
    border-bottom: 1px solid rgba(12,11,10,.18);
    padding: .75rem 0; color: var(--ink); font-family: var(--sans);
    font-size: .88rem; font-weight: 300; outline: none;
    transition: border-color .3s;
  }
  .form-group input::placeholder, .form-group textarea::placeholder { color: var(--faint); }
  .form-group input:focus, .form-group textarea:focus { border-color: var(--ink); }
  .form-group textarea { height: 96px; resize: none; }
  .form-submit {
    width: 100%; padding: 1rem; background: var(--ink); color: var(--white);
    font-family: var(--sans); font-size: 0.7rem; letter-spacing: .18em;
    text-transform: uppercase; font-weight: 500; border: none; cursor: pointer;
    transition: background .3s;
  }
  .form-submit:hover { background: var(--stone); }

  /* ── FOOTER ──────────────────────────────────────────── */
  footer {
    padding: 2.5rem 5vw; background: var(--bg);
    border-top: 1px solid rgba(12,11,10,.08);
    display: flex; justify-content: space-between; align-items: center;
  }
  .footer-brand {
    font-family: var(--serif); font-size: 1rem;
    letter-spacing: .08em; text-transform: uppercase; color: var(--ink);
  }
  .footer-copy {
    font-size: 0.62rem; letter-spacing: .1em; color: var(--faint);
  }
</style>
</head>
<body>

<nav>
  <a href="#" class="nav-logo">Sarah Chen</a>
  <ul class="nav-links">
    <li><a href="#listings">Listings</a></li>
    <li><a href="#agent">About</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a href="#contact" class="nav-cta">Inquire ↗</a>
</nav>

<section class="hero">
