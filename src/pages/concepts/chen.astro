<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chen Real Estate | Luxury Austin Properties</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black: #050505;
    --off-black: #0E0E0E;
    --card-bg: #111111;
    --gold: #C9A96E;
    --gold-light: #E4C99A;
    --cream: #F0EBE3;
    --muted: #888;
    --border: rgba(201,169,110,0.15);
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--cream);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: sticky; top: 0; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.4rem 5vw;
    background: rgba(5,5,5,0.92);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }
  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem; font-weight: 400; letter-spacing: 0.12em;
    color: var(--cream); text-decoration: none;
  }
  .nav-logo span { color: var(--gold); }
  .nav-links {
    display: flex; gap: 2.5rem; list-style: none;
  }
  .nav-links a {
    font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--muted); text-decoration: none;
    transition: color 0.3s;
  }
  .nav-links a:hover { color: var(--gold); }
  .nav-cta {
    font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--black); background: var(--gold);
    padding: 0.65rem 1.4rem; text-decoration: none;
    transition: background 0.3s;
  }
  .nav-cta:hover { background: var(--gold-light); }

  /* HERO */
  .hero {
    min-height: 100vh; display: flex; flex-direction: column;
    justify-content: center; padding: 8vw 5vw 5vw;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 70% 50%, rgba(201,169,110,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-eyebrow {
    font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 2.5rem;
    display: flex; align-items: center; gap: 1rem;
  }
  .hero-eyebrow::before {
    content: ''; display: block; width: 40px; height: 1px; background: var(--gold);
  }
  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.5rem, 9vw, 9rem);
    font-weight: 300; line-height: 0.9;
    letter-spacing: -0.02em;
    margin-bottom: 3rem; max-width: 900px;
  }
  .hero h1 em {
    font-style: italic; color: var(--gold);
  }
  .hero-sub {
    max-width: 480px; font-size: 1.05rem; line-height: 1.7;
    color: rgba(240,235,227,0.6); margin-bottom: 3.5rem;
    font-weight: 300;
  }
  .hero-actions {
    display: flex; gap: 1.2rem; align-items: center;
  }
  .btn-primary {
    padding: 1rem 2.2rem; background: var(--gold); color: var(--black);
    font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase;
    text-decoration: none; font-weight: 500;
    transition: background 0.3s, transform 0.3s;
  }
  .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); }
  .btn-ghost {
    padding: 1rem 2.2rem; border: 1px solid var(--border); color: var(--cream);
    font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase;
    text-decoration: none; font-weight: 400;
    transition: border-color 0.3s, transform 0.3s;
  }
  .btn-ghost:hover { border-color: var(--gold); transform: translateY(-2px); }

  .hero-scroll-hint {
    position: absolute; bottom: 3rem; left: 5vw;
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--muted); display: flex; align-items: center; gap: 0.8rem;
  }
  .scroll-line {
    display: block; width: 1px; height: 48px; background: var(--gold); opacity: 0.4;
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 0.7; }
  }

  /* STATS BAR */
  .stats-bar {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .stat-item {
    padding: 2.5rem 5vw; border-right: 1px solid var(--border);
  }
  .stat-item:last-child { border-right: none; }
  .stat-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 300;
    color: var(--gold); line-height: 1; display: block; margin-bottom: 0.5rem;
  }
  .stat-label {
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--muted);
  }

  /* FEATURED */
  .section { padding: 7vw 5vw; }
  .section-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 4rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border);
  }
  .section-eyebrow {
    font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 0.8rem;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 300; line-height: 1.1;
  }
  .section-link {
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold); text-decoration: none;
    display: flex; align-items: center; gap: 0.5rem;
    transition: gap 0.3s;
  }
  .section-link:hover { gap: 1rem; }

  .properties-grid {
    display: grid; grid-template-columns: 1.4fr 1fr; gap: 1.5px;
  }
  .property-card {
    background: var(--card-bg); overflow: hidden; cursor: pointer;
    transition: transform 0.5s cubic-bezier(0.16,1,0.3,1);
  }
  .property-card:hover { transform: scale(1.01); }
  .property-image {
    height: 320px; position: relative; overflow: hidden;
  }
  .property-card:first-child .property-image { height: 420px; }
  .property-image-bg {
    width: 100%; height: 100%;
    transition: transform 0.8s cubic-bezier(0.16,1,0.3,1);
  }
  .property-card:hover .property-image-bg { transform: scale(1.04); }
  .property-badge {
    position: absolute; top: 1.2rem; left: 1.2rem;
    font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
    background: var(--gold); color: var(--black);
    padding: 0.35rem 0.75rem; font-weight: 500;
  }
  .property-body { padding: 2rem; }
  .property-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem; font-weight: 400; color: var(--gold);
    margin-bottom: 0.4rem;
  }
  .property-address {
    font-size: 0.85rem; color: var(--cream); margin-bottom: 1.2rem;
    letter-spacing: 0.02em;
  }
  .property-specs {
    display: flex; gap: 1.5rem;
    font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--muted); border-top: 1px solid var(--border); padding-top: 1.2rem;
  }

  /* ABOUT */
  .about-section {
    padding: 7vw 5vw; background: var(--off-black);
    display: grid; grid-template-columns: 1fr 1fr; gap: 6vw; align-items: center;
  }
  .about-image-frame {
    position: relative;
  }
  .about-image {
    width: 100%; aspect-ratio: 3/4;
    background: linear-gradient(160deg, #1a1a1a 0%, #0d0d0d 100%);
    position: relative; overflow: hidden;
  }
  .about-image::after {
    content: 'S C';
    position: absolute; bottom: 2rem; right: 2rem;
    font-family: 'Cormorant Garamond', serif; font-size: 4rem; font-weight: 300;
    color: rgba(201,169,110,0.15); letter-spacing: 0.3em;
  }
  .about-image-accent {
    position: absolute; top: 1.5rem; right: -1.5rem; bottom: -1.5rem; left: 1.5rem;
    border: 1px solid var(--border); z-index: -1;
  }
  .about-eyebrow {
    font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1.5rem;
  }
  .about-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 300; line-height: 1.15;
    margin-bottom: 2rem;
  }
  .about-title em { font-style: italic; color: var(--gold); }
  .about-text {
    font-size: 0.95rem; line-height: 1.8; color: rgba(240,235,227,0.65);
    margin-bottom: 1.5rem;
  }
  .about-credentials {
    display: flex; flex-direction: column; gap: 0.6rem; margin-top: 2.5rem;
  }
  .credential {
    font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--muted); display: flex; align-items: center; gap: 0.8rem;
  }
  .credential::before {
    content: ''; display: block; width: 20px; height: 1px; background: var(--gold);
  }

  /* TESTIMONIAL */
  .testimonial-section {
    padding: 8vw 5vw; text-align: center; position: relative;
  }
  .quote-mark {
    font-family: 'Cormorant Garamond', serif;
    font-size: 8rem; line-height: 1; color: var(--gold); opacity: 0.3;
    position: absolute; top: 4vw; left: 50%; transform: translateX(-50%);
    font-style: italic;
  }
  .testimonial-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.4rem, 2.5vw, 2.2rem); font-weight: 300; font-style: italic;
    line-height: 1.5; max-width: 800px; margin: 0 auto 2.5rem;
    color: var(--cream); position: relative; z-index: 1;
  }
  .testimonial-author {
    font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold);
  }
  .testimonial-divider {
    width: 40px; height: 1px; background: var(--gold); margin: 0 auto 1.5rem;
  }

  /* CONTACT */
  .contact-section {
    padding: 7vw 5vw; background: var(--off-black);
    display: grid; grid-template-columns: 1fr 1fr; gap: 6vw; align-items: start;
  }
  .contact-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 300; line-height: 1.1;
    margin-bottom: 1.5rem;
  }
  .contact-title em { font-style: italic; color: var(--gold); }
  .contact-text {
    font-size: 0.9rem; line-height: 1.8; color: rgba(240,235,227,0.6);
    margin-bottom: 2rem;
  }
  .contact-detail {
    font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 0.6rem;
  }
  .contact-detail a { color: var(--gold); text-decoration: none; }
  .form-group { margin-bottom: 1.2rem; }
  .form-group input, .form-group textarea {
    width: 100%; background: rgba(255,255,255,0.04); border: 1px solid var(--border);
    padding: 1rem 1.2rem; color: var(--cream); font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem; font-weight: 300; outline: none;
    transition: border-color 0.3s;
  }
  .form-group input:focus, .form-group textarea:focus { border-color: var(--gold); }
  .form-group textarea { height: 120px; resize: none; }
  .form-submit {
    width: 100%; padding: 1rem; background: var(--gold); color: var(--black);
    font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
    font-weight: 500; font-family: 'DM Sans', sans-serif;
    border: none; cursor: pointer; transition: background 0.3s;
  }
  .form-submit:hover { background: var(--gold-light); }

  /* FOOTER */
  footer {
    padding: 3rem 5vw; border-top: 1px solid var(--border);
    display: flex; justify-content: space-between; align-items: center;
  }
  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem; color: var(--cream); letter-spacing: 0.1em;
  }
  .footer-logo span { color: var(--gold); }
  .footer-copy {
    font-size: 0.65rem; letter-spacing: 0.1em; color: var(--muted);
  }
</style>
</head>
<body>

