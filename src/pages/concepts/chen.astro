    <div class="form-group"><textarea placeholder="Tell Sarah what you're looking for…"></textarea></div>
    <button class="form-submit">Send Inquiry</button>
  </div>
</section>

<footer>
  <div class="footer-brand">Sarah Chen · Real Estate</div>
  <div class="footer-copy">© 2024 Sarah Chen Real Estate. Austin, Texas. Equal Housing Opportunity.</div>
</footer>

</body>
</html>
