                    <button class="panel-btn" onclick="toggleWf('wf-about', this)">ABOUT</button>
                    <button class="panel-btn" onclick="resetWf()" style="border-color: rgba(2,6,13,0.2);">RESET</button>
                    <div class="interactive-badge">Interactive</div>
                </div>
                <div class="panel-hint" id="hint-wf">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 1v10M6 1l-3 3M6 1l3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                    Click the buttons above to build the page
