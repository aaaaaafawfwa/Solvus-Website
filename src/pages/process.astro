                <div class="panel-body" style="background: var(--c-white);">
                    <div id="wf-header" class="wf-block wf-header">NAV: 80PX / BRAND / CTA</div>
                    <div id="wf-hero" class="wf-block wf-hero">H1 / SUBHEAD / PRIMARY CTA</div>
                    <div id="wf-listings" class="wf-block wf-listings"><div>LISTING</div><div>LISTING</div><div>LISTING</div></div>
                    <div id="wf-about" class="wf-block wf-about">PROFILE / TEXT BLOCK</div>
