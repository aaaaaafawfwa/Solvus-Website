<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Solvus | Methodology & Process</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;200;300;400&family=Space+Mono&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.29/bundled/lenis.min.js" is:inline></script>

<style>
    :root {
        --nav-height: 80px;
        --c-navy: #03060C;
        --c-navy-light: #0A111E;
        --c-white: #F8FAFC;
        --c-cyan: #00E5FF;
        --c-muted: #4A5D7E;
        --font-sans: 'Outfit', sans-serif;
        --font-mono: 'Space Mono', monospace;
    }

    * { box-sizing: border-box; }
    
    html.lenis { height: auto; }
    .lenis.lenis-smooth { scroll-behavior: auto; }
    .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
    .lenis.lenis-stopped { overflow: hidden; }

    body, html {
        margin: 0; padding: 0;
        font-family: var(--font-sans);
        background-color: var(--c-navy);
        color: var(--c-white);
        cursor: none;
        overflow-x: hidden;
    }

    /* Custom Cursor */
    .cursor-dot {
        position: fixed; top: 0; left: 0; width: 6px; height: 6px;
        background: var(--c-cyan); border-radius: 50%;
        transform: translate(-50%, -50%); pointer-events: none; z-index: 9999;
    }
    .cursor-ring {
        position: fixed; top: 0; left: 0; width: 40px; height: 40px;
        border: 1px solid rgba(0, 229, 255, 0.5); border-radius: 50%;
        transform: translate(-50%, -50%); pointer-events: none; z-index: 9998;
        transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1), height 0.3s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.3s;
    }

    #webgl-canvas {
        position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
        z-index: 0; pointer-events: none;
    }

    nav {
        position: fixed; top: 0; width: 100%; height: var(--nav-height);
        display: flex; justify-content: space-between; align-items: center;
        padding: 0 4vw; z-index: 50; mix-blend-mode: difference; color: #fff;
    }
    .brand { font-weight: 200; letter-spacing: 4px; text-transform: uppercase; font-size: 1.2rem; text-decoration: none; color: inherit;}
    .nav-links { display: flex; gap: 3vw; font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; }
    .nav-links a { color: inherit; text-decoration: none; }

    main { position: relative; z-index: 10; }

    section {
        min-height: 100vh; width: 100vw;
        padding: calc(var(--nav-height) + 4vw) 5vw 8vw 5vw;
        position: relative;
    }

    /* Typography */
    h1 { font-size: clamp(3.5rem, 8vw, 9rem); font-weight: 100; letter-spacing: -0.05em; line-height: 0.85; margin: 0 0 2rem 0; }
    h2 { font-size: clamp(2.5rem, 5vw, 6rem); font-weight: 100; letter-spacing: -0.03em; line-height: 0.95; margin: 0 0 2rem 0; }
    h3 { font-weight: 200; font-size: clamp(1.5rem, 3vw, 2.5rem); margin: 0 0 1rem 0; letter-spacing: -0.02em; }
    
    .mono-label {
        font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.15em;
        text-transform: uppercase; margin-bottom: 2rem; display: inline-block;
        padding: 6px 12px; border: 1px solid currentColor; border-radius: 4px;
    }

    p { font-size: clamp(1rem, 1.2vw, 1.3rem); line-height: 1.6; max-width: 650px; margin: 0 0 1.5rem 0; font-weight: 200; opacity: 0.8; }

    /* Buttons */
    .btn {
        display: inline-flex; align-items: center; gap: 1rem; padding: 1.2rem 2.5rem; border: 1px solid currentColor;
        background: transparent; color: inherit; cursor: none; font-family: var(--font-mono); font-size: 0.75rem; 
        text-transform: uppercase; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); text-decoration: none; 
        letter-spacing: 2px; border-radius: 40px; position: relative; overflow: hidden;
    }
    .btn::before { content: ''; position: absolute; top: 100%; left: 0; width: 100%; height: 100%; background: currentColor; transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); z-index: -1; }
    .btn:hover::before { transform: translateY(-100%); }
    .btn:hover { color: var(--c-navy) !important; }
    .btn-solid { background: currentColor; color: var(--c-navy); }
    .btn-solid::before { background: var(--c-navy); }
    .btn-solid:hover { color: var(--c-white) !important; }

    .dark-sec { color: var(--c-white); background-color: transparent; }
    .light-sec { color: var(--c-navy); background-color: var(--c-white); }
    .light-sec .btn:hover { color: var(--c-white) !important; }
    .light-sec .btn-solid { color: var(--c-white); }
    .light-sec .btn-solid:hover { color: var(--c-navy) !important; }

    .split-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8vw; align-items: center; }

    /* Component: Interactive Panels */
    .interactive-panel {
        width: 100%; height: 600px; border: 1px solid rgba(255,255,255,0.1);
        background: rgba(2, 6, 13, 0.4); backdrop-filter: blur(10px);
        border-radius: 8px; display: flex; flex-direction: column; overflow: hidden;
        box-shadow: 0 30px 60px rgba(0,0,0,0.1);
    }
    .light-sec .interactive-panel {
        background: rgba(255, 255, 255, 0.8); border-color: rgba(2,6,13,0.1);
    }

    .panel-header {
        display: flex; gap: 1rem; padding: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.02);
    }
    .light-sec .panel-header { border-color: rgba(2,6,13,0.1); background: rgba(2,6,13,0.02); }
    
    .panel-btn {
        background: transparent; border: 1px solid currentColor; color: inherit;
        font-family: var(--font-mono); font-size: 0.7rem; padding: 8px 16px; cursor: none;
        border-radius: 40px; transition: all 0.3s; letter-spacing: 1px;
    }
    .panel-btn:hover, .panel-btn.active { background: var(--c-cyan); color: var(--c-navy); border-color: var(--c-cyan); }

    .panel-body { flex: 1; padding: 2rem; position: relative; overflow: hidden; display: flex; flex-direction: column; gap: 1rem;}

    /* specific: Wireframe Builder */
    .wf-block {
        width: 100%; border: 1px dashed var(--c-cyan); border-radius: 4px;
        display: flex; align-items: center; justify-content: center;
        font-family: var(--font-mono); font-size: 0.75rem; color: var(--c-cyan);
        opacity: 0; transform: scale(0.98); transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        height: 0; padding: 0; margin: 0; overflow: hidden;
    }
    .wf-block.active { opacity: 1; transform: scale(1); margin-bottom: 1rem; }
    .wf-header { height: 60px; }
    .wf-hero { height: 200px; }
    .wf-listings { height: 150px; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; padding: 1rem; border: none; }
    .wf-listings div { border: 1px dashed var(--c-cyan); height: 100%; border-radius: 4px; }
    .wf-about { height: 100px; }

    /* specific: Token System */
    .token-view { display: none; height: 100%; animation: fadeIn 0.4s ease; flex-direction: column; gap: 2rem; justify-content: center;}
    .token-view.active { display: flex; }
    .type-row { display: flex; align-items: baseline; gap: 2rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 1rem;}
    .space-bar { height: 20px; background: var(--c-cyan); border-radius: 2px; display: flex; align-items: center; padding-left: 10px; font-family: var(--font-mono); font-size: 0.6rem; color: var(--c-navy);}
    .color-grid { display: flex; gap: 1rem; }
    .color-swatch { width: 80px; height: 80px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 0.6rem;}

    /* specific: Code vs Render */
    .split-view-container { display: flex; height: 100%; width: 100%; }
    .code-side { flex: 1; background: #0A111E; padding: 2rem; font-family: var(--font-mono); font-size: 0.8rem; color: #8AB4F8; overflow: hidden; border-right: 1px solid rgba(2,6,13,0.1);}
    .render-side { flex: 1; padding: 2rem; display: flex; align-items: center; justify-content: center; background: #F8FAFC; color: #02060D;}
    .slider-container { padding: 1.5rem; background: rgba(2,6,13,0.02); border-bottom: 1px solid rgba(2,6,13,0.1); display: flex; align-items: center; gap: 1rem;}
    input[type=range] { flex: 1; cursor: none; accent-color: var(--c-cyan); }

    /* specific: Handover Manifest */
    .manifest-list { list-style: none; padding: 0; margin: 0; font-family: var(--font-mono); font-size: 0.85rem;}
    .manifest-list li { display: flex; gap: 1rem; align-items: center; padding: 1.25rem 0; border-bottom: 1px solid rgba(255,255,255,0.1); opacity: 0.3; transition: opacity 0.3s; }
    .manifest-list li.checked { opacity: 1; }
    .checkbox { width: 20px; height: 20px; border: 1px solid currentColor; display: flex; align-items: center; justify-content: center; border-radius: 2px;}
    .manifest-list li.checked .checkbox::after { content: '✓'; color: var(--c-cyan); }

    /* Engineering Grid */
    .eng-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 4rem; }
    .eng-card { border: 1px solid rgba(2,6,13,0.1); padding: 2rem; border-radius: 4px; transition: transform 0.3s, border-color 0.3s;}
    .eng-card:hover { transform: translateY(-5px); border-color: var(--c-cyan); }
    .eng-card .mono-label { border: none; padding: 0; color: var(--c-navy); font-weight: bold; }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* Legend */
    .legend-block { font-family: var(--font-mono); font-size: 0.85rem; border: 1px solid var(--c-cyan); padding: 2rem; border-radius: 4px; display: inline-flex; flex-direction: column; gap: 1rem;}
    .legend-item { display: flex; gap: 2rem; cursor: none; transition: color 0.3s; }
    .legend-item:hover { color: var(--c-cyan); }

    .stagger-text { overflow: hidden; display: block; }
    .stagger-text span { display: block; }
    .outline-text { color: transparent; -webkit-text-stroke: 1px var(--c-muted); }
    .bg-giant-text { position: absolute; top: 10%; left: -5%; font-size: 25vw; font-weight: 100; line-height: 0.8; color: transparent; -webkit-text-stroke: 1px rgba(255,255,255,0.02); pointer-events: none; z-index: -1; white-space: nowrap; }
    .light-sec .bg-giant-text { -webkit-text-stroke: 1px rgba(2,6,13,0.03); }
    .progress-bar { position: fixed; top: 0; left: 0; height: 2px; background: var(--c-cyan); width: 0%; z-index: 100; transform-origin: left; }
</style>
</head>
<body>

<div class="cursor-dot" id="cursorDot"></div>
<div class="cursor-ring" id="cursorRing"></div>
<div class="progress-bar" id="progressBar"></div>

<nav>
    <a href="/" class="brand hover-target">Solvus</a>
    <div class="nav-links">
        <span style="color: var(--c-cyan);">Process</span>
        <a href="/services" class="hover-target">Services</a>
        <a href="/about" class="hover-target">About</a>
    </div>
</nav>

<canvas id="webgl-canvas"></canvas>

<main>
    <section id="s1" class="dark-sec">
        <div class="split-grid" style="height: 80vh;">
            <div>
                <div class="mono-label fade-up" style="color: var(--c-cyan); border-color: var(--c-cyan);">SHEET 03 / METHODOLOGY</div>
                <h1 class="stagger-wrap">
                    <span class="stagger-text"><span>How every</span></span>
                    <span class="stagger-text"><span class="outline-text">Solvus site</span></span>
                    <span class="stagger-text"><span>gets built.</span></span>
                </h1>
                <p class="fade-up">No case studies yet — Solvus is pre-launch. Instead, every decision and technique we use is documented below. If you want to see what we deliver, read this page. It's the honest version of a portfolio.</p>
            </div>
            
            <div class="fade-up float-y" data-speed="1.1" style="display: flex; justify-content: flex-end;">
                <div class="legend-block">
                    <div style="color: var(--c-muted); margin-bottom: 1rem;">— PHASES OF WORK —</div>
                    <div class="legend-item hover-target" onclick="lenis.scrollTo('#s2')"><span>01</span><span>STRUCTURE</span></div>
                    <div class="legend-item hover-target" onclick="lenis.scrollTo('#s3')"><span>02</span><span>SYSTEM</span></div>
                    <div class="legend-item hover-target" onclick="lenis.scrollTo('#s4')"><span>03</span><span>BUILD</span></div>
                    <div class="legend-item hover-target" onclick="lenis.scrollTo('#s5')"><span>04</span><span>LAUNCH</span></div>
                </div>
            </div>
        </div>
    </section>

    <section id="s2" class="light-sec">
        <div class="bg-giant-text para-text">STRUCTURE</div>
        <div class="split-grid">
            <div style="padding-right: 4vw;">
                <div class="mono-label">PHASE 01 / STRUCTURE</div>
                <h2>We start with the argument, not the visuals.</h2>
                <p>Every site opens with a question: "what does this realtor need a visitor to do in the first 15 seconds?"</p>
                <p>Before anything else, we map visitor intent → information hierarchy → page structure. This is wireframing, but done as a written argument first.</p>
            </div>
            
            <div class="interactive-panel float-y" data-speed="1.05">
                <div class="panel-header">
                    <button class="panel-btn hover-target" onclick="toggleWf('wf-header', this)">HEADER</button>
                    <button class="panel-btn hover-target" onclick="toggleWf('wf-hero', this)">HERO</button>
                    <button class="panel-btn hover-target" onclick="toggleWf('wf-listings', this)">LISTINGS</button>
                    <button class="panel-btn hover-target" onclick="toggleWf('wf-about', this)">ABOUT</button>
                    <button class="panel-btn hover-target" onclick="resetWf()" style="margin-left: auto; border-color: rgba(2,6,13,0.2);">RESET</button>
                </div>
                <div class="panel-body" style="background: var(--c-white);">
                    <div id="wf-header" class="wf-block wf-header">NAV: 80PX / BRAND / CTA</div>
                    <div id="wf-hero" class="wf-block wf-hero">H1 / SUBHEAD / PRIMARY CTA</div>
                    <div id="wf-listings" class="wf-block wf-listings"><div>LISTING</div><div>LISTING</div><div>LISTING</div></div>
                    <div id="wf-about" class="wf-block wf-about">PROFILE / TEXT BLOCK</div>
                </div>
            </div>
        </div>
    </section>

    <section id="s3" class="dark-sec">
        <div class="bg-giant-text para-text">TOKENS</div>
        <div class="split-grid">
            <div style="padding-right: 4vw;">
                <div class="mono-label">PHASE 02 / SYSTEM</div>
                <h2>Design tokens before components. Components before pages.</h2>
                <p>Every Solvus build starts with a type scale, a spacing scale, and a colour palette. Locked before any visual design. Then components. Then pages. Never the other way around.</p>
            </div>
            
            <div class="interactive-panel float-y" data-speed="0.95">
                <div class="panel-header">
                    <button class="panel-btn active hover-target" onclick="switchTab('tab-type', this)">TYPE</button>
                    <button class="panel-btn hover-target" onclick="switchTab('tab-space', this)">SPACE</button>
                    <button class="panel-btn hover-target" onclick="switchTab('tab-color', this)">COLOUR</button>
                </div>
                <div class="panel-body">
                    <div id="tab-type" class="token-view active">
                        <div class="type-row"><span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--c-muted); width: 80px;">H1 - 8rem</span><span style="font-size: 4rem; font-weight: 100; line-height: 1;">Display</span></div>
                        <div class="type-row"><span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--c-muted); width: 80px;">H2 - 4rem</span><span style="font-size: 2.5rem; font-weight: 100; line-height: 1;">Heading</span></div>
                        <div class="type-row"><span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--c-muted); width: 80px;">Body - 1rem</span><span style="font-size: 1rem; font-weight: 300;">Standard paragraph text used for long-form reading.</span></div>
                    </div>
                    <div id="tab-space" class="token-view">
                        <div class="space-bar" style="width: 100%;">--space-xl (128px)</div>
                        <div class="space-bar" style="width: 50%;">--space-lg (64px)</div>
                        <div class="space-bar" style="width: 25%;">--space-md (32px)</div>
                        <div class="space-bar" style="width: 12.5%;">--space-sm (16px)</div>
                    </div>
                    <div id="tab-color" class="token-view">
                        <div class="color-grid">
                            <div class="color-swatch hover-target" style="background: #02060D; color: #FFF; border-color: #333;">#02060D<br>Navy Base</div>
                            <div class="color-swatch hover-target" style="background: #00E5FF; color: #000;">#00E5FF<br>Cyan Accent</div>
                            <div class="color-swatch hover-target" style="background: #F8FAFC; color: #000;">#F8FAFC<br>Paper White</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="s4" class="light-sec">
        <div class="split-grid">
            <div style="padding-right: 4vw;">
                <div class="mono-label">PHASE 03 / BUILD</div>
                <h2>Hand-coded.<br>Every time.</h2>
                <p>We do not use page builders. They are bloated, slow, unmaintainable, and locked to specific platforms.</p>
                <p>Hand-coding gives you sub-1s load times, intentional placement of every DOM element, and zero hidden tracking scripts. This is progressive enhancement.</p>
            </div>
            
            <div class="interactive-panel float-y" data-speed="1.1" style="background: var(--c-white);">
                <div class="slider-container">
                    <span style="font-family: var(--font-mono); font-size: 0.7rem;">MARKUP</span>
                    <input type="range" min="0" max="2" value="0" class="hover-target" id="codeSlider" oninput="updateSplitView()">
                    <span style="font-family: var(--font-mono); font-size: 0.7rem;">INTERACTIVE</span>
                </div>
                <div class="split-view-container">
                    <div class="code-side" id="codeView">
&lt;button class="btn"&gt;<br>
&nbsp;&nbsp;Book Call<br>
&lt;/button&gt;
                    </div>
                    <div class="render-side">
                        <button id="renderBtn" style="font-family: serif; background: #eee; border: 1px solid #ccc; padding: 5px;">Book Call</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="s5" class="dark-sec">
        <div class="split-grid" style="align-items: start;">
            <div style="padding-right: 4vw;">
                <div class="mono-label">PHASE 04 / LAUNCH</div>
                <h2>Launch is a handover, not a delivery.</h2>
                <p>On launch day, you get source code, hosting credentials, domain ownership, documentation, and a 30-minute training call. No ongoing dependency. You can fire Solvus forever and your site keeps running.</p>
            </div>
            
            <div class="interactive-panel float-y" data-speed="0.95" style="height: auto; min-height: 500px;">
                <div class="panel-header">
                    <div class="mono-label" style="border:none; padding:0; margin:0; color: var(--c-cyan);">HANDOVER MANIFEST / SOLVUS → CLIENT</div>
                </div>
                <div class="panel-body" style="padding-top: 0;">
                    <ul class="manifest-list" id="manifestList">
                        <li><div class="checkbox"></div> Source code (Git repository, full history)</li>
                        <li><div class="checkbox"></div> Hosting account credentials</li>
                        <li><div class="checkbox"></div> Domain registrar access</li>
                        <li><div class="checkbox"></div> CMS/content admin access</li>
                        <li><div class="checkbox"></div> Google Business Profile ownership</li>
                        <li><div class="checkbox"></div> Analytics ownership transfer</li>
                        <li><div class="checkbox"></div> Documentation (maintenance guidelines)</li>
                        <li><div class="checkbox"></div> 30-min training session recording</li>
                        <li><div class="checkbox"></div> 30-day support window activated</li>
                    </ul>
                    <div id="manifestComplete" style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--c-cyan); text-align: right; margin-top: 2rem; opacity: 0;">— HANDOVER COMPLETE —</div>
                </div>
            </div>
        </div>
    </section>

    <section id="s6" class="light-sec" style="padding-top: 6vw;">
        <div style="text-align: center; max-width: 800px; margin: 0 auto;">
            <div class="mono-label">SPECIFICATION / ENGINEERING</div>
            <h2>Under the hood.</h2>
            <p style="margin: 0 auto;">Details nobody else bothers to mention. These apply to every Solvus build.</p>
        </div>

        <div class="eng-grid">
            <div class="eng-card hover-target">
                <div class="mono-label">LIGHTHOUSE TARGET</div>
                <p style="margin:0; font-size: 1rem;">Minimum 95/100 on mobile. Measured on every push.</p>
            </div>
            <div class="eng-card hover-target">
                <div class="mono-label">LCP BUDGET</div>
                <p style="margin:0; font-size: 1rem;">Under 1.5s on 4G. Under 2.5s on slow 3G.</p>
            </div>
            <div class="eng-card hover-target">
                <div class="mono-label">CLS BUDGET</div>
                <p style="margin:0; font-size: 1rem;">Under 0.05. Below Google's "good" threshold.</p>
            </div>
            <div class="eng-card hover-target">
                <div class="mono-label">WCAG LEVEL</div>
                <p style="margin:0; font-size: 1rem;">AA minimum, AAA on text contrast for legibility.</p>
            </div>
            <div class="eng-card hover-target">
                <div class="mono-label">SEMANTIC HTML</div>
                <p style="margin:0; font-size: 1rem;">Used correctly. Nav, main, article, real headings in order.</p>
            </div>
            <div class="eng-card hover-target">
                <div class="mono-label">SCHEMA MARKUP</div>
                <p style="margin:0; font-size: 1rem;">LocalBusiness + RealEstateAgent injected as JSON-LD.</p>
            </div>
            <div class="eng-card hover-target">
                <div class="mono-label">IMAGE STRATEGY</div>
                <p style="margin:0; font-size: 1rem;">Modern formats (WebP/AVIF), responsive srcset, lazy-loaded.</p>
            </div>
            <div class="eng-card hover-target">
                <div class="mono-label">PROGRESSIVE ENHANCEMENT</div>
                <p style="margin:0; font-size: 1rem;">Site works without JS for core content.</p>
            </div>
        </div>
    </section>

    <section id="s7" class="dark-sec" style="background-color: var(--c-navy); text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 80vh;">
        <div style="max-width: 900px; z-index: 2;">
            <div class="mono-label" style="color: var(--c-cyan); border-color: var(--c-cyan);">END SHEET 03 / BOOK CALL</div>
            <h2 class="stagger-wrap" style="font-size: clamp(3rem, 7vw, 8rem); margin-bottom: 2rem;">
                <span class="stagger-text"><span>Want this level of</span></span>
                <span class="stagger-text"><span class="outline-text">work for your site?</span></span>
            </h2>
            <div class="btn-group fade-up" style="justify-content: center; margin-bottom: 2rem;">
                <a href="#book" class="btn btn-solid hover-target">Book a 20-minute call ↗</a>
            </div>
            <div class="mono-label fade-up" style="border:none; color: var(--c-muted);">OR EMAIL HELLO@SOLVUS.COM</div>
        </div>
    </section>
</main>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" is:inline></script>

<script is:inline>
    gsap.registerPlugin(ScrollTrigger);

    // Lenis Smooth Scroll
    const lenis = new Lenis({
        duration: 1.2, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), direction: 'vertical',
        gestureDirection: 'vertical', smooth: true, mouseMultiplier: 1, smoothTouch: false,
        touchMultiplier: 2, infinite: false,
    });
    function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);

    // Custom Cursor
    const cursorDot = document.getElementById('cursorDot');
    const cursorRing = document.getElementById('cursorRing');
    let mouseX = window.innerWidth / 2, mouseY = window.innerHeight / 2;
    let ringX = mouseX, ringY = mouseY;

    window.addEventListener('mousemove', (e) => {
        mouseX = e.clientX; mouseY = e.clientY;
        gsap.to(cursorDot, { x: mouseX, y: mouseY, duration: 0 });
    });
    gsap.ticker.add(() => {
        ringX += (mouseX - ringX) * 0.15; ringY += (mouseY - ringY) * 0.15;
        gsap.set(cursorRing, { x: ringX, y: ringY });
    });

    document.querySelectorAll('.hover-target').forEach(link => {
        link.addEventListener('mouseenter', () => {
            gsap.to(cursorRing, { width: 60, height: 60, backgroundColor: 'rgba(0, 229, 255, 0.1)', duration: 0.3 });
            gsap.to(cursorDot, { scale: 0, duration: 0.2 });
        });
        link.addEventListener('mouseleave', () => {
            gsap.to(cursorRing, { width: 40, height: 40, backgroundColor: 'transparent', duration: 0.3 });
            gsap.to(cursorDot, { scale: 1, duration: 0.2 });
        });
    });

    // Wireframe Builder Logic
    function toggleWf(id, btn) {
        btn.classList.toggle('active');
        const block = document.getElementById(id);
        if (block.classList.contains('active')) {
            block.classList.remove('active');
            gsap.to(block, { height: 0, padding: 0, opacity: 0, duration: 0.4, ease: "power2.inOut" });
        } else {
            block.classList.add('active');
            let h = 0;
            if(id === 'wf-header') h = 60;
            if(id === 'wf-hero') h = 200;
            if(id === 'wf-listings') h = 150;
            if(id === 'wf-about') h = 100;
            gsap.to(block, { height: h, opacity: 1, duration: 0.4, ease: "power2.inOut" });
        }
    }
    function resetWf() {
        document.querySelectorAll('.wf-block').forEach(block => {
            block.classList.remove('active');
            gsap.to(block, { height: 0, padding: 0, opacity: 0, duration: 0.4 });
        });
        document.querySelectorAll('.panel-header button').forEach(btn => btn.classList.remove('active'));
    }

    // Token Tabs Logic
    function switchTab(id, btn) {
        document.querySelectorAll('#s3 .panel-header button').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('.token-view').forEach(v => v.classList.remove('active'));
        document.getElementById(id).classList.add('active');
    }

    // Code vs Render Slider Logic
    function updateSplitView() {
        const val = document.getElementById('codeSlider').value;
        const codeView = document.getElementById('codeView');
        const renderBtn = document.getElementById('renderBtn');
        
        if (val == 0) {
            codeView.innerHTML = '&lt;button class="btn"&gt;<br>&nbsp;&nbsp;Book Call<br>&lt;/button&gt;';
            renderBtn.style = "font-family: serif; background: #eee; border: 1px solid #ccc; padding: 5px; color: black; border-radius:0; cursor:default; transform:none; transition:none;";
        } else if (val == 1) {
            codeView.innerHTML = '.btn {<br>&nbsp;&nbsp;padding: 1rem 2rem;<br>&nbsp;&nbsp;border: 1px solid #000;<br>&nbsp;&nbsp;border-radius: 40px;<br>&nbsp;&nbsp;font-family: monospace;<br>}';
            renderBtn.style = "font-family: 'Space Mono', monospace; background: transparent; border: 1px solid #02060D; padding: 1rem 2rem; color: #02060D; border-radius: 40px; cursor:default; transform:none; transition:none;";
        } else {
            codeView.innerHTML = 'btn.addEventListener("hover", () => {<br>&nbsp;&nbsp;gsap.to(btn, {<br>&nbsp;&nbsp;&nbsp;&nbsp;backgroundColor: "#00E5FF",<br>&nbsp;&nbsp;&nbsp;&nbsp;scale: 1.05<br>&nbsp;&nbsp;});<br>});';
            renderBtn.style = "font-family: 'Space Mono', monospace; background: transparent; border: 1px solid #02060D; padding: 1rem 2rem; color: #02060D; border-radius: 40px; cursor: none; transition: all 0.3s; box-shadow: 0 10px 20px rgba(0,0,0,0.1);";
            // simulated hover state style for position 2
            renderBtn.onmouseover = () => { renderBtn.style.backgroundColor = "#00E5FF"; renderBtn.style.transform = "scale(1.05)"; };
            renderBtn.onmouseout = () => { renderBtn.style.backgroundColor = "transparent"; renderBtn.style.transform = "scale(1)"; };
        }
    }

    // Manifest Checklist Animation
    ScrollTrigger.create({
        trigger: "#manifestList",
        start: "top 70%",
        once: true,
        onEnter: () => {
            const items = document.querySelectorAll('#manifestList li');
            gsap.to(items, {
                className: "+=checked",
                stagger: 0.15,
                duration: 0.1,
                onComplete: () => {
                    gsap.to("#manifestComplete", { opacity: 1, duration: 0.5, y: -10 });
                }
            });
        }
    });

    // Universal Scroll Animations
    gsap.to("#progressBar", { scaleX: 1, ease: "none", scrollTrigger: { trigger: "body", start: "top top", end: "bottom bottom", scrub: 0.3 } });

    document.querySelectorAll('.stagger-wrap').forEach(wrap => {
        gsap.fromTo(wrap.querySelectorAll('.stagger-text span'), 
            { y: "110%" }, { y: "0%", duration: 1.2, stagger: 0.1, ease: "power4.out", scrollTrigger: { trigger: wrap, start: "top 85%" } }
        );
    });
    document.querySelectorAll('.fade-up').forEach(elem => {
        gsap.fromTo(elem, { y: 30, opacity: 0 }, { y: 0, opacity: 1, duration: 1, ease: "power3.out", scrollTrigger: { trigger: elem, start: "top 90%" } });
    });
    document.querySelectorAll('.para-text').forEach(text => {
        gsap.to(text, { xPercent: -20, ease: "none", scrollTrigger: { trigger: text.parentElement, start: "top bottom", end: "bottom top", scrub: true } });
    });
    document.querySelectorAll('.float-y').forEach(elem => {
        const speed = elem.getAttribute('data-speed') || 1;
        gsap.to(elem, { y: -100 * speed, ease: "none", scrollTrigger: { trigger: elem.parentElement, start: "top bottom", end: "bottom top", scrub: true } });
    });

    // --- THREE.JS BACKGROUND ---
    const canvas = document.getElementById('webgl-canvas');
    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x03060C, 0.002);
    const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = 60;
    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const particleGeo = new THREE.BufferGeometry();
    const pCount = 3000;
    const pArray = new Float32Array(pCount * 3);
    for(let i=0; i<pCount*3; i++) pArray[i] = (Math.random() - 0.5) * 200;
    particleGeo.setAttribute('position', new THREE.BufferAttribute(pArray, 3));
    
    const colorCyan = new THREE.Color(0x00E5FF);
    const colorNavy = new THREE.Color(0x03060C);
    
    const particleMat = new THREE.PointsMaterial({ size: 0.15, color: colorCyan, transparent: true, opacity: 0.3 });
    const particles = new THREE.Points(particleGeo, particleMat);
    scene.add(particles);

    const geoGroup = new THREE.Group();
    scene.add(geoGroup);
    const matWire = new THREE.LineBasicMaterial({ color: colorCyan, transparent: true, opacity: 0.1 });
    
    for(let i=0; i<5; i++) {
        const geo = i % 2 === 0 ? new THREE.IcosahedronGeometry(20, 1) : new THREE.OctahedronGeometry(25, 2);
        const mesh = new THREE.LineSegments(new THREE.EdgesGeometry(geo), matWire);
        mesh.position.set((Math.random() - 0.5) * 40, (Math.random() - 0.5) * 40, -i * 50);
        mesh.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, 0);
        geoGroup.add(mesh);
    }

    let targetRotationX = 0, targetRotationY = 0;
    window.addEventListener('mousemove', (e) => {
        targetRotationY = ((e.clientX / window.innerWidth) - 0.5) * 0.5;
        targetRotationX = ((e.clientY / window.innerHeight) - 0.5) * 0.5;
    });

    ScrollTrigger.create({
        trigger: "body", start: "top top", end: "bottom bottom", scrub: 1,
        onUpdate: (self) => {
            camera.position.z = 60 - (self.progress * 250);
            camera.rotation.z = self.progress * 0.5;
            
            // 7 Sections total. Even sections (2, 4, 6) are light.
            const currentSection = Math.floor(self.progress * 7);
            if (currentSection === 1 || currentSection === 3 || currentSection === 5) {
                // Light sections (S2, S4, S6)
                particleMat.color.lerp(colorNavy, 0.1);
                matWire.color.lerp(colorNavy, 0.1);
                scene.fog.color.lerp(new THREE.Color(0xF8FAFC), 0.1);
            } else {
                // Dark sections (S1, S3, S5, S7)
                particleMat.color.lerp(colorCyan, 0.1);
                matWire.color.lerp(colorCyan, 0.1);
                scene.fog.color.lerp(colorNavy, 0.1);
            }
        }
    });

    const clock = new THREE.Clock();
    function animate() {
        requestAnimationFrame(animate);
        const t = clock.getElapsedTime();
        geoGroup.rotation.x += 0.05 * (targetRotationX + (Math.sin(t*0.5)*0.1) - geoGroup.rotation.x);
        geoGroup.rotation.y += 0.05 * (targetRotationY + (t*0.1) - geoGroup.rotation.y);
        particles.position.y = Math.sin(t * 0.2) * 5;
        particles.rotation.y = t * 0.02;
        geoGroup.children.forEach((child, index) => {
            child.rotation.x += 0.002 * (index % 2 === 0 ? 1 : -1);
            child.rotation.y += 0.003;
        });
        renderer.render(scene, camera);
    }
    animate();

    window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
    });
</script>
</body>
</html>
