<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Solvus | Methodology & Process</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;200;300;400&family=Space+Mono&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.29/bundled/lenis.min.js" is:inline></script>

<style>
    :root {
        --nav-height: 80px;
        --c-navy: #03060C;
        --c-navy-light: #0A111E;
        --c-white: #F8FAFC;
        --c-cyan: #00E5FF;
        --c-muted: #4A5D7E;
        --font-sans: 'Outfit', sans-serif;
        --font-mono: 'Space Mono', monospace;
    }

    * { box-sizing: border-box; }

    html.lenis { height: auto; }
    .lenis.lenis-smooth { scroll-behavior: auto; }
    .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
    .lenis.lenis-stopped { overflow: hidden; }

    body, html {
        margin: 0; padding: 0;
        font-family: var(--font-sans);
        background-color: var(--c-navy);
        color: var(--c-white);
        overflow-x: hidden;
    }

    @media (hover: hover) { * { cursor: none !important; } }

    .solvus-cursor {
        position: fixed; width: 8px; height: 8px;
        background: var(--c-cyan); border-radius: 50%;
        pointer-events: none; z-index: 99999;
        opacity: 0; margin-left: -4px; margin-top: -4px;
        transition: opacity 0.15s; will-change: left, top;
    }

    #webgl-canvas {
        position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
        z-index: 0; pointer-events: none;
    }

    nav {
        position: fixed; top: 0; width: 100%; height: var(--nav-height);
        display: flex; justify-content: space-between; align-items: center;
        padding: 0 4vw; z-index: 50;
        background: rgba(3, 6, 12, 0.85);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        color: var(--c-white);
    }
    .brand { font-weight: 200; letter-spacing: 4px; text-transform: uppercase; font-size: 1.2rem; text-decoration: none; color: inherit; }
    .nav-links { display: flex; gap: 3vw; font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; }
    .nav-links a { color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-links a:hover { color: var(--c-white); }
    .nav-active { color: var(--c-cyan) !important; }

    main { position: relative; z-index: 10; }

    section {
        min-height: 100vh; width: 100%;
        padding: calc(var(--nav-height) + 4vw) 5vw 8vw 5vw;
        position: relative;
    }

    h1 { font-size: clamp(3.5rem, 8vw, 9rem); font-weight: 100; letter-spacing: -0.05em; line-height: 0.85; margin: 0 0 2rem 0; }
    h2 { font-size: clamp(2.5rem, 5vw, 6rem); font-weight: 100; letter-spacing: -0.03em; line-height: 0.95; margin: 0 0 2rem 0; }
    h3 { font-weight: 200; font-size: clamp(1.5rem, 3vw, 2.5rem); margin: 0 0 1rem 0; letter-spacing: -0.02em; }

    .mono-label {
        font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.15em;
        text-transform: uppercase; margin-bottom: 2rem; display: inline-block;
        padding: 6px 12px; border: 1px solid currentColor; border-radius: 4px;
    }

    p { font-size: clamp(1rem, 1.2vw, 1.3rem); line-height: 1.6; max-width: 650px; margin: 0 0 1.5rem 0; font-weight: 200; opacity: 0.8; }

    .btn {
        display: inline-flex; align-items: center; gap: 1rem;
        padding: 1.2rem 2.5rem; border: 1px solid var(--c-white);
        background: transparent; color: var(--c-white);
        font-family: var(--font-mono); font-size: 0.75rem;
        text-transform: uppercase; text-decoration: none; letter-spacing: 2px;
        border-radius: 40px;
        transition: background 0.35s cubic-bezier(0.16,1,0.3,1), color 0.35s, border-color 0.35s;
    }
    .btn:hover { background: var(--c-cyan); color: var(--c-navy) !important; border-color: var(--c-cyan); }
    .btn-solid { background: var(--c-white); color: var(--c-navy); border-color: var(--c-white); }
    .btn-solid:hover { background: var(--c-cyan); color: var(--c-navy) !important; border-color: var(--c-cyan); }

    .dark-sec { color: var(--c-white); background-color: transparent; }
    .light-sec { color: var(--c-navy); background-color: var(--c-white); }

    .split-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8vw; align-items: center; }

    /* ── Interactive Panel Shell ──────────────────────────────── */
    .interactive-panel {
        width: 100%; height: 600px; border: 1px solid rgba(255,255,255,0.1);
        background: rgba(2, 6, 13, 0.4); backdrop-filter: blur(10px);
        border-radius: 8px; display: flex; flex-direction: column; overflow: hidden;
        box-shadow: 0 30px 60px rgba(0,0,0,0.15);
        transition: border-color 0.4s ease, box-shadow 0.4s ease;
    }
    .light-sec .interactive-panel {
        background: rgba(255,255,255,0.8); border-color: rgba(2,6,13,0.1);
        box-shadow: 0 30px 60px rgba(0,0,0,0.06);
    }

    @keyframes panelCall {
        0%   { transform: scale(1);      box-shadow: 0 30px 60px rgba(0,0,0,0.15), 0 0  0px rgba(0,229,255,0);     border-color: rgba(255,255,255,0.1); }
        30%  { transform: scale(1.016);  box-shadow: 0 38px 75px rgba(0,0,0,0.18), 0 0 45px rgba(0,229,255,0.2),  0 0 90px rgba(0,229,255,0.07); border-color: rgba(0,229,255,0.45); }
        55%  { transform: scale(1.016);  box-shadow: 0 38px 75px rgba(0,0,0,0.18), 0 0 45px rgba(0,229,255,0.2),  0 0 90px rgba(0,229,255,0.07); border-color: rgba(0,229,255,0.45); }
        100% { transform: scale(1);      box-shadow: 0 30px 60px rgba(0,0,0,0.15), 0 0  0px rgba(0,229,255,0);     border-color: rgba(255,255,255,0.1); }
    }
    @keyframes panelCallLight {
        0%   { transform: scale(1);      box-shadow: 0 30px 60px rgba(0,0,0,0.06), 0 0  0px rgba(0,229,255,0);     border-color: rgba(2,6,13,0.1); }
        30%  { transform: scale(1.016);  box-shadow: 0 38px 75px rgba(0,0,0,0.09), 0 0 45px rgba(0,229,255,0.18), 0 0 90px rgba(0,229,255,0.06); border-color: rgba(0,200,230,0.4); }
        55%  { transform: scale(1.016);  box-shadow: 0 38px 75px rgba(0,0,0,0.09), 0 0 45px rgba(0,229,255,0.18), 0 0 90px rgba(0,229,255,0.06); border-color: rgba(0,200,230,0.4); }
        100% { transform: scale(1);      box-shadow: 0 30px 60px rgba(0,0,0,0.06), 0 0  0px rgba(0,229,255,0);     border-color: rgba(2,6,13,0.1); }
    }

    .panel-calling              { animation: panelCall      2.6s cubic-bezier(0.45, 0, 0.55, 1) 3 both; }
    .light-sec .panel-calling   { animation: panelCallLight 2.6s cubic-bezier(0.45, 0, 0.55, 1) 3 both; }

    /* smooth return to rest when interaction stops the pulse */
    .panel-settling {
        animation: none !important;
        transition: transform 0.7s cubic-bezier(0.16,1,0.3,1),
                    box-shadow 0.7s cubic-bezier(0.16,1,0.3,1),
                    border-color 0.7s cubic-bezier(0.16,1,0.3,1) !important;
        transform: scale(1) !important;
        box-shadow: 0 30px 60px rgba(0,0,0,0.15) !important;
        border-color: rgba(255,255,255,0.1) !important;
    }
    .light-sec .panel-settling {
        box-shadow: 0 30px 60px rgba(0,0,0,0.06) !important;
        border-color: rgba(2,6,13,0.1) !important;
    }

    /* Interactive badge */
    .interactive-badge {
        display: flex; align-items: center; gap: 6px;
        font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.15em;
        text-transform: uppercase; padding: 5px 10px; border-radius: 40px;
        background: rgba(0,229,255,0.1); color: var(--c-cyan);
        border: 1px solid rgba(0,229,255,0.2); margin-left: auto; white-space: nowrap;
        animation: badgePulse 2.5s ease-in-out infinite;
    }
    .interactive-badge::before {
        content: ''; display: block; width: 5px; height: 5px; border-radius: 50%;
        background: var(--c-cyan); flex-shrink: 0;
        animation: dotBlink 2.5s ease-in-out infinite;
    }
    @keyframes badgePulse { 0%,100%{opacity:.55} 50%{opacity:1} }
    @keyframes dotBlink   { 0%,100%{opacity:1}  50%{opacity:.2} }

    .light-sec .interactive-badge {
        background: rgba(0,229,255,0.08); border-color: rgba(0,180,200,0.25);
    }

    /* Hint strip */
    .panel-hint {
        display: flex; align-items: center; gap: 0.6rem;
        font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.12em;
        text-transform: uppercase; padding: 0.6rem 1.5rem;
        background: rgba(0,229,255,0.04); border-bottom: 1px solid rgba(0,229,255,0.08);
        color: rgba(0,229,255,0.55);
        transition: opacity 0.5s ease, max-height 0.5s ease, padding 0.5s ease;
        overflow: hidden; max-height: 60px;
    }
    .panel-hint svg { flex-shrink: 0; opacity: 0.7; }
    .panel-hint.hidden { opacity: 0; max-height: 0; padding-top: 0; padding-bottom: 0; pointer-events: none; }
    .light-sec .panel-hint {
        background: rgba(0,0,0,0.02); border-color: rgba(0,0,0,0.06);
        color: rgba(0,100,120,0.5);
    }

    .panel-header {
        display: flex; gap: 1rem; padding: 1.2rem 1.5rem; align-items: center;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.02);
    }
    .light-sec .panel-header { border-color: rgba(2,6,13,0.1); background: rgba(2,6,13,0.02); }

    .panel-btn {
        background: transparent; border: 1px solid currentColor; color: inherit;
        font-family: var(--font-mono); font-size: 0.7rem; padding: 8px 16px;
        border-radius: 40px; transition: background 0.25s, color 0.25s, border-color 0.25s;
        letter-spacing: 1px;
    }
    .panel-btn:hover, .panel-btn.active {
        background: var(--c-cyan); color: var(--c-navy); border-color: var(--c-cyan);
    }

    .panel-body { flex: 1; padding: 2rem; position: relative; overflow: hidden; display: flex; flex-direction: column; gap: 1rem; }

    /* ── Wireframe Builder ──────────────────────────────────── */
    .wf-block {
        width: 100%; border: 1px dashed var(--c-cyan); border-radius: 4px;
        display: flex; align-items: center; justify-content: center;
        font-family: var(--font-mono); font-size: 0.75rem; color: var(--c-cyan);
        opacity: 0; transform: scale(0.98);
        transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        height: 0; padding: 0; margin: 0; overflow: hidden;
    }
    .wf-block.active { opacity: 1; transform: scale(1); margin-bottom: 1rem; }
    .wf-header { height: 60px; }
    .wf-hero   { height: 200px; }
    .wf-listings { height: 150px; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; padding: 1rem; border: none; }
    .wf-listings div { border: 1px dashed var(--c-cyan); height: 100%; border-radius: 4px; }
    .wf-about  { height: 100px; }

    /* ── Token System ───────────────────────────────────────── */
    .token-view { display: none; height: 100%; animation: fadeIn 0.4s ease; flex-direction: column; gap: 2rem; justify-content: center; }
    .token-view.active { display: flex; }
    .type-row { display: flex; align-items: baseline; gap: 2rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 1rem; }
    .space-bar { height: 20px; background: var(--c-cyan); border-radius: 2px; display: flex; align-items: center; padding-left: 10px; font-family: var(--font-mono); font-size: 0.6rem; color: var(--c-navy); }
    .color-grid { display: flex; gap: 1rem; }
    .color-swatch { width: 80px; height: 80px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 0.6rem; text-align: center; }

    /* ── Code vs Render ─────────────────────────────────────── */
    .split-view-container { display: flex; height: 100%; width: 100%; }
    .code-side { flex: 1; background: #0A111E; padding: 2rem; font-family: var(--font-mono); font-size: 0.8rem; color: #8AB4F8; overflow: hidden; border-right: 1px solid rgba(2,6,13,0.1); }
    .render-side { flex: 1; padding: 2rem; display: flex; align-items: center; justify-content: center; background: #F8FAFC; color: #02060D; }
    .slider-container { padding: 1.2rem 1.5rem; background: rgba(2,6,13,0.02); border-bottom: 1px solid rgba(2,6,13,0.1); display: flex; align-items: center; gap: 1rem; }
    .slider-container span { font-family: var(--font-mono); font-size: 0.7rem; color: rgba(2,6,13,0.5); white-space: nowrap; }
    input[type=range] { flex: 1; accent-color: var(--c-cyan); height: 4px; }

    /* ── Manifest ───────────────────────────────────────────── */
    .manifest-list { list-style: none; padding: 0; margin: 0; font-family: var(--font-mono); font-size: 0.85rem; }
    .manifest-list li {
        display: flex; gap: 1rem; align-items: center;
        padding: 1.25rem 0; border-bottom: 1px solid rgba(255,255,255,0.08);
        opacity: 0; transform: translateX(-12px);
        transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16,1,0.3,1),
                    color 0.3s ease, border-color 0.3s ease;
    }
    .manifest-list li.checked {
        opacity: 1; transform: translateX(0);
        color: var(--c-white); border-color: rgba(0,229,255,0.15);
    }
    .checkbox {
        width: 20px; height: 20px; border: 1px solid rgba(255,255,255,0.3);
        display: flex; align-items: center; justify-content: center;
        border-radius: 2px; flex-shrink: 0;
        transition: border-color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
    }
    .manifest-list li.checked .checkbox {
        border-color: var(--c-cyan); background: rgba(0,229,255,0.12);
        box-shadow: 0 0 8px rgba(0,229,255,0.3);
    }
    .manifest-list li.checked .checkbox::after { content: '✓'; color: var(--c-cyan); font-size: 0.75rem; }

    /* ── Engineering Grid ───────────────────────────────────── */
    .eng-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 4rem; }
    .eng-card { border: 1px solid rgba(2,6,13,0.1); padding: 2rem; border-radius: 4px; transition: transform 0.3s, border-color 0.3s; }
    .eng-card:hover { transform: translateY(-5px); border-color: var(--c-cyan); }
    .eng-card .mono-label { border: none; padding: 0; color: var(--c-navy); font-weight: bold; }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* ── Legend / Nav block ─────────────────────────────────── */
    .legend-block { font-family: var(--font-mono); font-size: 0.85rem; border: 1px solid var(--c-cyan); padding: 2rem; border-radius: 4px; display: inline-flex; flex-direction: column; gap: 1rem; }
    .legend-item { display: flex; gap: 2rem; transition: color 0.3s; }
    .legend-item:hover { color: var(--c-cyan); }

    .stagger-text { overflow: hidden; display: block; }
    .stagger-text span { display: block; }
    .outline-text { color: var(--c-cyan); }

    .bg-giant-text { position: absolute; top: 10%; left: -5%; font-size: 25vw; font-weight: 100; line-height: 0.8; color: transparent; -webkit-text-stroke: 1px rgba(255,255,255,0.02); pointer-events: none; z-index: -1; white-space: nowrap; }
    .light-sec .bg-giant-text { -webkit-text-stroke: 1px rgba(2,6,13,0.03); }

    .progress-bar { position: fixed; top: 0; left: 0; height: 2px; background: var(--c-cyan); width: 0%; z-index: 100; transform-origin: left; }

    @media (max-width: 768px) {
        * { cursor: auto !important; }
        :root { --nav-height: 64px; }
        nav { padding: 0 5vw; }
        .brand { font-size: 1rem; letter-spacing: 2px; }
        .nav-links { display: none; }
        section { padding: calc(var(--nav-height) + 6vw) 6vw 10vw 6vw; min-height: auto; }
        #s1 .split-grid { height: auto !important; min-height: 80svh; }
        .split-grid { grid-template-columns: 1fr; gap: 2rem; height: auto !important; }
        h1 { font-size: clamp(3rem, 13vw, 5rem); }
        h2 { font-size: clamp(2rem, 9vw, 3.5rem); }
        h3 { font-size: clamp(1.2rem, 5vw, 1.8rem); }
        p { font-size: 1rem; max-width: 100%; }

        /* Interactive panel mobile fixes */
        .interactive-panel { height: auto; min-height: 0; }
        .panel-header { flex-wrap: wrap; gap: 0.5rem; padding: 0.75rem 1rem; }
        .panel-btn { padding: 5px 10px; font-size: 0.62rem; }
        .interactive-badge { margin-left: 0; font-size: 0.5rem; padding: 4px 8px; }
        .panel-body { padding: 1rem; overflow: visible; }
        .token-view { height: auto; }
        .type-row { flex-wrap: wrap; align-items: center; gap: 0.5rem 1rem; }
        #tab-type .type-row:first-child > span:last-child { font-size: 2rem !important; }
        #tab-type .type-row:nth-child(2) > span:last-child { font-size: 1.5rem !important; }
        .split-view-container { flex-direction: column; height: auto; }
        .code-side { height: auto; min-height: 100px; border-right: none; border-bottom: 1px solid rgba(2,6,13,0.1); }
        .render-side { padding: 1.5rem; min-height: 80px; }
        .color-grid { flex-wrap: wrap; }
        .color-swatch { width: 55px; height: 55px; font-size: 0.5rem; }
    }

    .nav-hamburger {
        display: none; flex-direction: column; gap: 5px;
        width: 36px; height: 36px; align-items: center; justify-content: center;
        background: none; border: none; cursor: pointer; color: inherit; padding: 0;
    }
    .nav-hamburger span {
        width: 20px; height: 1.5px; background: currentColor; display: block;
        transition: transform 0.3s cubic-bezier(0.16,1,0.3,1);
    }
    .nav-hamburger[aria-expanded="true"] span:nth-child(1) { transform: translateY(3.25px) rotate(45deg); }
    .nav-hamburger[aria-expanded="true"] span:nth-child(2) { transform: translateY(-3.25px) rotate(-45deg); }

    .mobile-nav {
        position: fixed; inset: 0; background: var(--c-navy); z-index: 49;
        transform: translateX(100%); transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
        display: flex; flex-direction: column;
        padding: calc(var(--nav-height) + 2rem) 6vw 5rem; overflow-y: auto;
    }
    .mobile-nav[data-open="true"] { transform: translateX(0); }
    .mobile-nav__list { list-style: none; flex: 1; margin: 0; padding: 0; }
    .mobile-nav__link {
        display: flex; align-items: center; justify-content: space-between;
        font-family: var(--font-mono); font-size: 0.85rem;
        letter-spacing: 0.2em; text-transform: uppercase;
        color: rgba(248,250,252,0.75); text-decoration: none;
        padding: 1.4rem 0; border-bottom: 1px solid rgba(255,255,255,0.06); transition: color 0.2s;
    }
    .mobile-nav__link::after { content: '→'; font-size: 0.8rem; opacity: 0.3; transition: opacity 0.2s; }
    .mobile-nav__link:hover { color: var(--c-cyan); }
    .mobile-nav__link:hover::after { opacity: 1; }
    .mobile-nav__cta {
        display: block; text-align: center; padding: 1.1rem;
        background: var(--c-cyan); color: var(--c-navy); font-family: var(--font-mono);
        font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase;
        text-decoration: none; border-radius: 40px; font-weight: 500; margin-top: 2rem;
    }
    @media (max-width: 768px) {
        .nav-hamburger { display: flex; }
    }
</style>
</head>
<body>

<div class="solvus-cursor" id="solvusCursor"></div>
<div class="progress-bar" id="progressBar"></div>

<nav>
    <a href="/" class="brand">Solvus</a>
    <div class="nav-links">
        <span class="nav-active">Process</span>
        <a href="/services">Services</a>
        <a href="/about">About</a>
    </div>
    <button class="nav-hamburger" id="navHamburger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span>
    </button>
</nav>

<div class="mobile-nav" id="mobileNav" aria-hidden="true">
    <ul class="mobile-nav__list">
        <li><a href="/" class="mobile-nav__link">Home</a></li>
        <li><a href="/process" class="mobile-nav__link">Process</a></li>
        <li><a href="/services" class="mobile-nav__link">Services</a></li>
        <li><a href="/about" class="mobile-nav__link">About</a></li>
    </ul>
    <a href="mailto:solvus@aisolvus.com" class="mobile-nav__cta">Book a call ↗</a>
</div>

<canvas id="webgl-canvas"></canvas>

<main>
    <!-- S1: HERO -->
    <section id="s1" class="dark-sec">
        <div class="split-grid" style="height: 80vh;">
            <div>
                <div class="mono-label fade-up" style="color: var(--c-cyan); border-color: var(--c-cyan);">SHEET 02 / METHODOLOGY</div>
                <h1 class="stagger-wrap">
                    <span class="stagger-text"><span>How every</span></span>
                    <span class="stagger-text"><span class="outline-text">Solvus site</span></span>
                    <span class="stagger-text"><span>gets built.</span></span>
                </h1>
                <p class="fade-up">No case studies yet. Solvus is pre-launch. Instead, every decision and technique we use is documented below. If you want to see what we deliver, read this page. It is the honest version of a portfolio.</p>
            </div>

            <div class="fade-up float-y" data-speed="1.1" style="display: flex; justify-content: flex-end;">
                <div class="legend-block">
                    <div style="color: var(--c-muted); margin-bottom: 1rem; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.15em;">PHASES OF WORK</div>
                    <div class="legend-item" onclick="lenis.scrollTo('#s2')" style="cursor:pointer;"><span>01</span><span>STRUCTURE</span></div>
                    <div class="legend-item" onclick="lenis.scrollTo('#s3')" style="cursor:pointer;"><span>02</span><span>SYSTEM</span></div>
                    <div class="legend-item" onclick="lenis.scrollTo('#s4')" style="cursor:pointer;"><span>03</span><span>BUILD</span></div>
                    <div class="legend-item" onclick="lenis.scrollTo('#s5')" style="cursor:pointer;"><span>04</span><span>LAUNCH</span></div>
                </div>
            </div>
