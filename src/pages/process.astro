        <div style="max-width: 900px; z-index: 2;">
            <div class="mono-label" style="color: var(--c-cyan); border-color: var(--c-cyan);">END SHEET 02 / BOOK CALL</div>
            <h2 class="stagger-wrap" style="font-size: clamp(3rem, 7vw, 8rem); margin-bottom: 2rem;">
                <span class="stagger-text"><span>Want this level of</span></span>
                <span class="stagger-text"><span class="outline-text">work for your site?</span></span>
            </h2>
            <div class="btn-group fade-up" style="justify-content: center; margin-bottom: 2rem; display: flex;">
                <a href="mailto:solvus@aisolvus.com" class="btn btn-solid">Book a 20-minute call ↗</a>
            </div>
            <div class="mono-label fade-up" style="border:none; color: var(--c-muted);">OR EMAIL SOLVUS@AISOLVUS.COM</div>
        </div>
    </section>
</main>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" is:inline></script>

<script is:inline>
    gsap.registerPlugin(ScrollTrigger);

    // Cursor
    if (window.matchMedia('(hover: hover)').matches) {
        const dot = document.getElementById('solvusCursor');
        if (dot) {
            let usingTouch = false;
            window.addEventListener('touchstart', () => { usingTouch = true; dot.style.opacity = '0'; }, { passive: true });
            window.addEventListener('mousemove', (e) => {
                if (usingTouch) { usingTouch = false; return; }
                dot.style.left    = e.clientX + 'px';
                dot.style.top     = e.clientY + 'px';
                dot.style.opacity = '1';
            }, { passive: true });
        }
    }

    // Lenis
    const lenis = new Lenis({
        duration: 1.2, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        direction: 'vertical', smooth: true, mouseMultiplier: 1,
        smoothTouch: false, touchMultiplier: 2, infinite: false,
    });
    function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);

    // Hint dismissal
    function dismissHint(id) {
        const h = document.getElementById(id);
        if (h) h.classList.add('hidden');
    }

    // ── Wireframe Builder ──────────────────────────────────────────
    function toggleWf(id, btn) {
        dismissHint('hint-wf');
        btn.classList.toggle('active');
        const block = document.getElementById(id);
        if (block.classList.contains('active')) {
            block.classList.remove('active');
            gsap.to(block, { height: 0, padding: 0, opacity: 0, duration: 0.4, ease: "power2.inOut" });
        } else {
            block.classList.add('active');
            let h = 0;
            if (id === 'wf-header')   h = 60;
            if (id === 'wf-hero')     h = 200;
            if (id === 'wf-listings') h = 150;
            if (id === 'wf-about')    h = 100;
            gsap.to(block, { height: h, opacity: 1, duration: 0.4, ease: "power2.inOut" });
        }
    }
    function resetWf() {
        dismissHint('hint-wf');
        document.querySelectorAll('.wf-block').forEach(block => {
            block.classList.remove('active');
            gsap.to(block, { height: 0, padding: 0, opacity: 0, duration: 0.4 });
        });
        document.querySelectorAll('#s2 .panel-btn').forEach(b => b.classList.remove('active'));
    }

    // ── Token Tabs ─────────────────────────────────────────────────
    function switchTab(id, btn) {
        dismissHint('hint-tabs');
        document.querySelectorAll('#s3 .panel-header button').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('.token-view').forEach(v => v.classList.remove('active'));
        document.getElementById(id).classList.add('active');
    }

    // ── Code/Render Slider ─────────────────────────────────────────
    function onSliderInput() {
        dismissHint('hint-slider');
        updateSplitView();
    }

    function updateSplitView() {
        const val = document.getElementById('codeSlider').value;
        const codeView  = document.getElementById('codeView');
        const renderBtn = document.getElementById('renderBtn');

        if (val == 0) {
            codeView.innerHTML = '&lt;button class="btn"&gt;<br>&nbsp;&nbsp;Book Call<br>&lt;/button&gt;';
            renderBtn.style.cssText = "font-family: serif; background: #eee; border: 1px solid #ccc; padding: 5px; color: black; border-radius:0; transition:none;";
            renderBtn.onmouseover = null; renderBtn.onmouseout = null;
        } else if (val == 1) {
            codeView.innerHTML = '.btn {<br>&nbsp;&nbsp;padding: 1rem 2rem;<br>&nbsp;&nbsp;border: 1px solid #000;<br>&nbsp;&nbsp;border-radius: 40px;<br>&nbsp;&nbsp;font-family: monospace;<br>}';
            renderBtn.style.cssText = "font-family: 'Space Mono', monospace; background: transparent; border: 1px solid #02060D; padding: 1rem 2rem; color: #02060D; border-radius: 40px; transition:none;";
            renderBtn.onmouseover = null; renderBtn.onmouseout = null;
        } else {
            codeView.innerHTML = 'btn.addEventListener("mouseover", () => {<br>&nbsp;&nbsp;btn.style.background = "#00E5FF";<br>&nbsp;&nbsp;btn.style.transform = "scale(1.05)";<br>});';
            renderBtn.style.cssText = "font-family: 'Space Mono', monospace; background: transparent; border: 1px solid #02060D; padding: 1rem 2rem; color: #02060D; border-radius: 40px; transition: all 0.3s; box-shadow: 0 10px 20px rgba(0,0,0,0.1);";
            renderBtn.onmouseover = () => { renderBtn.style.backgroundColor = "#00E5FF"; renderBtn.style.transform = "scale(1.05)"; };
            renderBtn.onmouseout  = () => { renderBtn.style.backgroundColor = "transparent"; renderBtn.style.transform = "scale(1)"; };
        }
    }

    // Animate slider on load to hint it can be dragged
    window.addEventListener('load', () => {
        const slider = document.getElementById('codeSlider');
        if (!slider) return;
        let dir = 1, val = 0;
        const hint = setInterval(() => {
            val += dir * 0.04;
            if (val >= 0.6) dir = -1;
            if (val <= 0)   { clearInterval(hint); val = 0; }
            slider.value = val;
            updateSplitView();
        }, 30);
    });

    // ── Panel call-out animation ───────────────────────────────────
    document.querySelectorAll('.interactive-panel').forEach(panel => {
        const obs = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    setTimeout(() => panel.classList.add('panel-calling'), 350);
                    obs.disconnect();
                }
            });
        }, { threshold: 0.4 });
        obs.observe(panel);

        const stop = () => {
            if (!panel.classList.contains('panel-calling')) return;
            panel.classList.remove('panel-calling');
            panel.classList.add('panel-settling');
            setTimeout(() => panel.classList.remove('panel-settling'), 750);
        };
        panel.addEventListener('click',      stop, { once: true });
        panel.addEventListener('input',      stop, { once: true });
        panel.addEventListener('mouseenter', stop, { once: true });
    });

    // ── Manifest Checklist ─────────────────────────────────────────
    ScrollTrigger.create({
        trigger: "#manifestList",
        start: "top 78%",
        once: true,
        onEnter: () => {
            dismissHint('hint-manifest');
            const items = document.querySelectorAll('#manifestList li');
            items.forEach((item, i) => {
                setTimeout(() => {
                    item.classList.add('checked');
                }, i * 160);
            });
            setTimeout(() => {
                const done = document.getElementById('manifestComplete');
                if (done) { done.style.opacity = '1'; done.style.transform = 'translateY(-8px)'; }
            }, items.length * 160 + 200);
        }
    });

    // ── Scroll Animations ──────────────────────────────────────────
    gsap.to("#progressBar", { scaleX: 1, ease: "none", scrollTrigger: { trigger: "body", start: "top top", end: "bottom bottom", scrub: 0.3 } });

    document.querySelectorAll('.stagger-wrap').forEach(wrap => {
        gsap.fromTo(wrap.querySelectorAll('.stagger-text span'),
            { y: "110%" }, { y: "0%", duration: 1.2, stagger: 0.1, ease: "power4.out", scrollTrigger: { trigger: wrap, start: "top 85%" } }
        );
    });
    document.querySelectorAll('.fade-up').forEach(elem => {
        gsap.fromTo(elem, { y: 30, opacity: 0 }, { y: 0, opacity: 1, duration: 1, ease: "power3.out", scrollTrigger: { trigger: elem, start: "top 90%" } });
    });
    document.querySelectorAll('.para-text').forEach(text => {
        gsap.to(text, { xPercent: -20, ease: "none", scrollTrigger: { trigger: text.parentElement, start: "top bottom", end: "bottom top", scrub: true } });
    });
    document.querySelectorAll('.float-y').forEach(elem => {
        const speed = elem.getAttribute('data-speed') || 1;
        gsap.to(elem, { y: -100 * speed, ease: "none", scrollTrigger: { trigger: elem.parentElement, start: "top bottom", end: "bottom top", scrub: true } });
    });

    // ── Three.js Background ────────────────────────────────────────
    const canvas = document.getElementById('webgl-canvas');
    const scene  = new THREE.Scene();
    scene.fog    = new THREE.FogExp2(0x03060C, 0.002);
    const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = 60;
    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const particleGeo = new THREE.BufferGeometry();
    const pCount = 3000;
    const pArray = new Float32Array(pCount * 3);
    for (let i = 0; i < pCount * 3; i++) pArray[i] = (Math.random() - 0.5) * 200;
    particleGeo.setAttribute('position', new THREE.BufferAttribute(pArray, 3));

    const colorCyan = new THREE.Color(0x00E5FF);
    const colorNavy = new THREE.Color(0x03060C);
    const particleMat = new THREE.PointsMaterial({ size: 0.15, color: colorCyan, transparent: true, opacity: 0.3 });
    const particles   = new THREE.Points(particleGeo, particleMat);
    scene.add(particles);

    const geoGroup = new THREE.Group();
    scene.add(geoGroup);
    const matWire = new THREE.LineBasicMaterial({ color: colorCyan, transparent: true, opacity: 0.1 });
    for (let i = 0; i < 5; i++) {
        const geo  = i % 2 === 0 ? new THREE.IcosahedronGeometry(20, 1) : new THREE.OctahedronGeometry(25, 2);
        const mesh = new THREE.LineSegments(new THREE.EdgesGeometry(geo), matWire);
        mesh.position.set((Math.random() - 0.5) * 40, (Math.random() - 0.5) * 40, -i * 50);
        mesh.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, 0);
        geoGroup.add(mesh);
    }

    let targetRotX = 0, targetRotY = 0;
    window.addEventListener('mousemove', (e) => {
        targetRotY = ((e.clientX / window.innerWidth)  - 0.5) * 0.5;
        targetRotX = ((e.clientY / window.innerHeight) - 0.5) * 0.5;
    });

    ScrollTrigger.create({
        trigger: "body", start: "top top", end: "bottom bottom", scrub: 1,
        onUpdate: (self) => {
            camera.position.z = 60 - (self.progress * 250);
            camera.rotation.z = self.progress * 0.5;
            const sec = Math.floor(self.progress * 7);
            if (sec === 1 || sec === 3 || sec === 5) {
                particleMat.color.lerp(colorNavy, 0.1);
                matWire.color.lerp(colorNavy, 0.1);
                scene.fog.color.lerp(new THREE.Color(0xF8FAFC), 0.1);
            } else {
                particleMat.color.lerp(colorCyan, 0.1);
                matWire.color.lerp(colorCyan, 0.1);
                scene.fog.color.lerp(colorNavy, 0.1);
            }
        }
    });

    const clock = new THREE.Clock();
    function animate() {
        requestAnimationFrame(animate);
        const t = clock.getElapsedTime();
        geoGroup.rotation.x += 0.05 * (targetRotX + Math.sin(t * 0.5) * 0.1 - geoGroup.rotation.x);
        geoGroup.rotation.y += 0.05 * (targetRotY + t * 0.1 - geoGroup.rotation.y);
        particles.position.y  = Math.sin(t * 0.2) * 5;
        particles.rotation.y  = t * 0.02;
        geoGroup.children.forEach((child, i) => {
            child.rotation.x += 0.002 * (i % 2 === 0 ? 1 : -1);
            child.rotation.y += 0.003;
        });
        renderer.render(scene, camera);
    }
    animate();

    window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
    });

    // Hamburger menu
    const hamburger = document.getElementById('navHamburger');
    const mobileNav = document.getElementById('mobileNav');
    if (hamburger && mobileNav) {
        hamburger.addEventListener('click', () => {
            const next = hamburger.getAttribute('aria-expanded') !== 'true';
            hamburger.setAttribute('aria-expanded', String(next));
            mobileNav.setAttribute('data-open', String(next));
            mobileNav.setAttribute('aria-hidden', String(!next));
            document.body.style.overflow = next ? 'hidden' : '';
        });
        mobileNav.querySelectorAll('.mobile-nav__link').forEach(link => {
            link.addEventListener('click', () => {
                hamburger.setAttribute('aria-expanded', 'false');
                mobileNav.setAttribute('data-open', 'false');
                mobileNav.setAttribute('aria-hidden', 'true');
                document.body.style.overflow = '';
            });
        });
    }
</script>
</body>
</html>
