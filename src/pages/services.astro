<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Solvus | Services & Specifications</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;200;300;400&family=Space+Mono&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.29/bundled/lenis.min.js" is:inline></script>
<style>
    :root {
        --nav-height: 80px;
        --c-navy: #03060C;
        --c-navy-light: #0A111E;
        --c-white: #F8FAFC;
        --c-cyan: #00E5FF;
        --c-muted: #4A5D7E;
        --font-sans: 'Outfit', sans-serif;
        --font-mono: 'Space Mono', monospace;
    }

    * { box-sizing: border-box; }
    
    html.lenis { height: auto; }
    .lenis.lenis-smooth { scroll-behavior: auto; }
    .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
    .lenis.lenis-stopped { overflow: hidden; }

    body, html {
        margin: 0; padding: 0;
        font-family: var(--font-sans);
        background-color: var(--c-navy);
        color: var(--c-white);
        cursor: none;
        overflow-x: hidden;
    }

    /* Custom Cursor */
    .cursor-dot {
        position: fixed; top: 0; left: 0; width: 6px; height: 6px;
        background: var(--c-cyan); border-radius: 50%;
        transform: translate(-50%, -50%); pointer-events: none; z-index: 9999;
    }
    .cursor-ring {
        position: fixed; top: 0; left: 0; width: 40px; height: 40px;
        border: 1px solid rgba(0, 229, 255, 0.5); border-radius: 50%;
        transform: translate(-50%, -50%); pointer-events: none; z-index: 9998;
        transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1), height 0.3s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.3s;
    }

    #webgl-canvas {
        position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
        z-index: 0; pointer-events: none;
    }

    nav {
        position: fixed; top: 0; width: 100%; height: var(--nav-height);
        display: flex; justify-content: space-between; align-items: center;
        padding: 0 4vw; z-index: 50; mix-blend-mode: difference; color: #fff;
    }
    .brand { font-weight: 200; letter-spacing: 4px; text-transform: uppercase; font-size: 1.2rem; text-decoration: none; color: inherit;}
    .nav-links { display: flex; gap: 3vw; font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; }

    main { position: relative; z-index: 10; }

    section {
        min-height: 100vh; width: 100vw;
        padding: calc(var(--nav-height) + 4vw) 5vw 8vw 5vw;
        position: relative;
    }

    /* Typography */
    h1 { font-size: clamp(3.5rem, 8vw, 9rem); font-weight: 100; letter-spacing: -0.05em; line-height: 0.85; margin: 0 0 2rem 0; }
    h2 { font-size: clamp(2.5rem, 5vw, 6rem); font-weight: 100; letter-spacing: -0.03em; line-height: 0.95; margin: 0 0 2rem 0; }
    h3 { font-weight: 200; font-size: clamp(1.5rem, 3vw, 2.5rem); margin: 0 0 1rem 0; letter-spacing: -0.02em; }
    
    .mono-label {
        font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.15em;
        text-transform: uppercase; margin-bottom: 2rem; display: inline-block;
        padding: 6px 12px; border: 1px solid currentColor; border-radius: 4px;
    }

    p { font-size: clamp(1rem, 1.2vw, 1.3rem); line-height: 1.6; max-width: 650px; margin: 0 0 1.5rem 0; font-weight: 200; opacity: 0.8; }

    /* Buttons */
    .btn {
        display: inline-flex; align-items: center; gap: 1rem; padding: 1.2rem 2.5rem; border: 1px solid currentColor;
        background: transparent; color: inherit; cursor: none; font-family: var(--font-mono); font-size: 0.75rem; 
        text-transform: uppercase; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); text-decoration: none; 
        letter-spacing: 2px; border-radius: 40px; position: relative; overflow: hidden;
    }
    .btn::before {
        content: ''; position: absolute; top: 100%; left: 0; width: 100%; height: 100%;
        background: currentColor; transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); z-index: -1;
    }
    .btn:hover::before { transform: translateY(-100%); }
    .btn:hover { color: var(--c-navy) !important; }
    .btn-solid { background: currentColor; color: var(--c-navy); }
    .btn-solid::before { background: var(--c-navy); }
    .btn-solid:hover { color: var(--c-white) !important; }

    /* Section Themes */
    .dark-sec { color: var(--c-white); background-color: transparent; }
    .light-sec { color: var(--c-navy); background-color: var(--c-white); }
    .light-sec .btn:hover { color: var(--c-white) !important; }
    .light-sec .btn-solid { color: var(--c-white); }
    .light-sec .btn-solid:hover { color: var(--c-navy) !important; }

    .split-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8vw; align-items: center; }

    /* Radial Diagram (S1) */
    .radial-container { position: relative; width: 100%; aspect-ratio: 1; display: flex; justify-content: center; align-items: center; }
    .radial-center {
        width: 140px; height: 140px; background: rgba(0, 229, 255, 0.05); border: 1px solid var(--c-cyan);
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        text-align: center; z-index: 2; backdrop-filter: blur(5px);
        font-weight: 300; font-size: 1.2rem; text-transform: uppercase; letter-spacing: 2px;
    }
    .radial-node {
        position: absolute; padding: 12px 20px; background: var(--c-navy-light);
        border: 1px solid rgba(255,255,255,0.1); border-radius: 40px; font-family: var(--font-mono);
        font-size: 0.75rem; letter-spacing: 1px; color: var(--c-white); transition: border-color 0.3s, transform 0.3s;
        z-index: 2;
    }
    .radial-node:hover { border-color: var(--c-cyan); transform: scale(1.05); }
    .radial-lines { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 1; }
    .radial-lines line { stroke: rgba(0, 229, 255, 0.3); stroke-width: 1; stroke-dasharray: 4; }

    /* Spec List (S2) */
    .spec-card {
        background: rgba(0, 229, 255, 0.02); border: 1px solid rgba(2, 6, 13, 0.1);
        padding: 4rem; border-radius: 8px; width: 100%; max-width: 1000px; margin: 0 auto;
    }
    .spec-card-header { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 0.75rem; color: var(--c-muted); margin-bottom: 3rem; border-bottom: 1px solid rgba(2,6,13,0.1); padding-bottom: 1rem;}
    .spec-list { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; width: 100%; }
    .spec-item { display: flex; justify-content: space-between; align-items: baseline; border-bottom: 1px dashed rgba(2,6,13,0.1); padding-bottom: 1rem; transition: padding-left 0.3s ease; }
    .spec-item:hover { padding-left: 10px; border-bottom-color: var(--c-cyan); }
    dt { font-size: 1.25rem; font-weight: 300; margin: 0; }
    dd { font-family: var(--font-mono); font-size: 0.75rem; color: var(--c-cyan); margin: 0; border: 1px solid var(--c-cyan); padding: 4px 8px; border-radius: 20px;}

    /* SERP Visualizer (S3) */
    .serp-container { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 3rem; position: relative; }
    .serp-result { margin-bottom: 2rem; position: relative; }
    .serp-url { font-family: var(--font-mono); font-size: 0.8rem; color: var(--c-muted); margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem; }
    .serp-title { font-size: 1.5rem; font-weight: 300; color: #8AB4F8; margin: 0 0 0.5rem 0; text-decoration: underline; text-decoration-color: transparent; transition: text-decoration-color 0.3s; }
    .serp-title:hover { text-decoration-color: #8AB4F8; }
    .serp-desc { font-size: 0.95rem; color: #BDC1C6; line-height: 1.5; font-weight: 200; }
    
    .annotation-pin {
        position: absolute; width: 12px; height: 12px; background: var(--c-navy); border: 2px solid var(--c-cyan);
        border-radius: 50%; cursor: none; z-index: 5;
    }
    .annotation-pin::after {
        content: ''; position: absolute; top: -4px; left: -4px; right: -4px; bottom: -4px;
        border: 1px solid var(--c-cyan); border-radius: 50%; opacity: 0; transition: opacity 0.3s, transform 0.3s;
    }
    .annotation-pin:hover::after { opacity: 1; transform: scale(1.5); }
    .annotation-tooltip {
        position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%) translateY(-10px);
        background: var(--c-navy-light); border: 1px solid var(--c-cyan); padding: 1rem;
        font-family: var(--font-mono); font-size: 0.75rem; color: var(--c-white); white-space: nowrap;
        opacity: 0; pointer-events: none; transition: opacity 0.3s, transform 0.3s; border-radius: 4px;
    }
    .annotation-pin:hover .annotation-tooltip { opacity: 1; transform: translateX(-50%) translateY(-20px); }

    /* Exclusions & Pricing (S4) */
    .exclusions-list { list-style: none; padding: 0; }
    .exclusions-list li { font-size: 1.5rem; font-weight: 300; margin-bottom: 1.5rem; color: var(--c-muted); }
    .exclusions-list s { text-decoration-color: var(--c-navy); }
    
    .memo-card {
        background: #F1F5F9; border: 1px solid rgba(2,6,13,0.1); padding: 3rem;
        font-family: var(--font-mono); box-shadow: inset 0 0 20px rgba(0,0,0,0.02);
    }
    .memo-header { border-bottom: 1px solid rgba(2,6,13,0.1); padding-bottom: 1.5rem; margin-bottom: 2rem; font-size: 0.8rem; color: var(--c-muted); line-height: 1.8;}
    .memo-body { font-family: var(--font-sans); font-size: 1.25rem; font-weight: 300; line-height: 1.6; }
    .memo-footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--c-cyan); font-size: 0.8rem; }

    /* Utilities */
    .stagger-text { overflow: hidden; display: block; }
    .stagger-text span { display: block; }
    .outline-text { color: transparent; -webkit-text-stroke: 1px var(--c-muted); }
    .bg-giant-text { position: absolute; top: 10%; left: -5%; font-size: 25vw; font-weight: 100; line-height: 0.8; color: transparent; -webkit-text-stroke: 1px rgba(255,255,255,0.02); pointer-events: none; z-index: -1; white-space: nowrap; }
    .light-sec .bg-giant-text { -webkit-text-stroke: 1px rgba(2,6,13,0.03); }

    .progress-bar { position: fixed; top: 0; left: 0; height: 2px; background: var(--c-cyan); width: 0%; z-index: 100; transform-origin: left; }
</style>
</head>
<body>

<div class="cursor-dot" id="cursorDot"></div>
<div class="cursor-ring" id="cursorRing"></div>
<div class="progress-bar" id="progressBar"></div>

<nav>
    <a href="/" class="brand hover-target">Solvus</a>
    <div class="nav-links">
        <span class="hover-target">Process</span>
